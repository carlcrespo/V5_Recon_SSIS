  DTS:VersionBuild="5"
  DTS:VersionGUID="{C29F21B2-FB4E-4989-9975-AB0BD8D1B607}">
  <DTS:Property
    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\15B DiscountingTarget"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{58B02A57-C744-4B51-A67A-6460D80BF25B}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="15B DiscountingTarget"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 TargetDiscountingsRecon&#xA;&#xA;--USE Insight_UAT&#xA;--GO&#xA;&#xA;--CREATE OR ALTER   PROC [dbo].[TargetDiscountingsRecon]&#xA;--AS&#xA;--BEGIN&#xA;&#xA;&#x9;DECLARE @MigrationCutoffDate DATE = (SELECT TOP (1) Date FROM Migration_Intermediate..Transactiondate)&#xA;DROP TABLE IF EXISTS #TargetDiscountingDetails&#xA;DROP TABLE IF EXISTS #DiscountingRepaymentScheduleSummary&#xA;DROP TABLE IF EXISTS #DiscountingAmortizationScheduleSummary&#xA;DROP TABLE IF EXISTS #PayableDetails&#xA;DROP TABLE IF EXISTS #InterestSumDetails&#xA;DROP TABLE IF EXISTS #FinalInterestAccrualBalance_Amount&#xA;DROP TABLE IF EXISTS #TargetBlendedItems&#xA;&#x9;CREATE TABLE #TargetDiscountingDetails&#xA;&#x9;(&#xA;&#x9;&#x9; DiscountingId bigint &#xA;&#x9;&#x9;, DiscountingFinanceId bigint&#xA;&#x9;&#x9;, FunderId bigint&#xA;&#x9;&#x9;,T_AssociatedLeaseSequenceNumber nvarchar(max)&#xA;&#x9;&#x9;,T_DiscountingSequenceNumber nvarchar(max) &#xA;&#x9;&#x9;,T_LoanNumber nvarchar(max)&#xA;&#x9;&#x9;,T_FundingSourceNumber nvarchar(50)&#xA;&#x9;&#x9;,T_FundingSource nvarchar(max)&#xA;&#x9;&#x9;,T_BookingStatus nvarchar(max)&#xA;&#x9;&#x9;,T_RepaymentFrequency nvarchar(max)&#xA;&#x9;&#x9;,T_IsAutoPaymentAllowed bit&#xA;&#x9;&#x9;,T_DiscountRate decimal(14,9) DEFAULT (0)&#xA;&#x9;&#x9;,T_DueDay Int&#xA;&#x9;&#x9;,T_Advance bit&#xA;&#x9;&#x9;,T_CompoundingFrequency NVarChar(13) NULL&#xA;&#x9;&#x9;,T_Yield decimal(14,9) DEFAULT (0)&#xA;&#x9;&#x9;,T_CommencementDate datetime&#xA;&#x9;&#x9;,T_MaturityDate datetime&#xA;&#x9;&#x9;,T_FacilityExpirationDate datetime&#xA;&#x9;&#x9;,T_ProcessThroughDate datetime &#xA;&#x9;&#x9;,T_LoanAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalPaymentAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingPaymentAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalPrincipalAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalCapitalizedInterestAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingPrincipalAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingCapitalizedInterestAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalInterestAccrualAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_AccumulatedInterestAccrualAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingInterestAccrualAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_DebtFinancingCostAmount  decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_AccumulatedDebtFinancingCostAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingDebtFinancingCostAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_Currency Nvarchar(40) NULL&#xA;&#x9;&#x9;,T_LastPaymentDueDate datetime&#xA;&#x9;&#x9;,T_AccruedInterestBalance decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_LegalEntityNumber Nvarchar(40) NULL&#xA;&#x9;&#x9;,T_LoanDate DateTime&#xA;&#x9;&#x9;,T_NetTermBasis Nvarchar(6) &#xA;&#x9;&#x9;,T_NetTerms INT&#xA;&#x9;&#x9;,T_TValueComputeMethod Nvarchar(8)&#xA;&#x9;&#x9;,T_TValueDateCounting  Nvarchar(13)&#xA;&#x9;&#x9;,T_RRPPaymentsFrom INT&#xA;&#x9;&#x9;,T_RRPPaymentFrequency  Nvarchar(13)&#xA;&#x9;&#x9;,T_RRPRegularPaymentAmount_Amount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_PerfectPayPool BIT&#xA;&#xA;&#x9;)&#xA;&#xA;&#x9;INSERT INTO #TargetDiscountingDetails&#xA;&#x9;(&#xA;&#x9;&#x9;DiscountingId, &#xA;&#x9;&#x9;T_IsAutoPaymentAllowed,&#xA;&#x9;&#x9;T_RepaymentFrequency,&#xA;&#x9;&#x9;T_BookingStatus,&#xA;&#x9;&#x9;T_AssociatedLeaseSequenceNumber,&#xA;&#x9;&#x9;T_DiscountingSequenceNumber,&#xA;&#x9;&#x9;T_Advance,&#xA;&#x9;&#x9;T_CompoundingFrequency,&#xA;&#x9;&#x9;DiscountingFinanceId,&#xA;&#x9;&#x9;T_LoanNumber,&#xA;&#x9;&#x9;FunderId,&#xA;&#x9;&#x9;T_FundingSourceNumber,&#xA;&#x9;&#x9;T_FundingSource,&#xA;&#x9;&#x9;T_CommencementDate,&#xA;&#x9;&#x9;T_MaturityDate,&#xA;&#x9;&#x9;T_ProcessThroughDate,&#xA;&#x9;&#x9;T_DueDay,&#xA;&#x9;&#x9;T_DiscountRate,&#xA;&#x9;&#x9;T_LoanAmount,&#xA;&#x9;&#x9;T_Yield,&#xA;&#x9;&#x9;T_Currency,&#xA;&#x9;&#x9;T_LegalEntityNumber,&#xA;&#x9;&#x9;T_LoanDate,&#xA;&#x9;&#x9;T_NetTermBasis,&#xA;&#x9;&#x9;T_NetTerms,&#xA;&#x9;&#x9;T_TValueComputeMethod,&#xA;&#x9;&#x9;T_TValueDateCounting,&#xA;&#x9;&#x9;T_RRPPaymentsFrom,&#xA;&#x9;&#x9;T_RRPPaymentFrequency,&#xA;&#x9;&#x9;T_RRPRegularPaymentAmount_Amount,&#xA;&#x9;&#x9;T_PerfectPayPool &#xA;&#x9;&#x9;)&#xA;&#x9;SELECT &#xA;&#x9;&#x9;Discountings.Id AS DiscountingId,&#xA;&#x9;&#x9;CASE WHEN DiscountingServicingDetails.Collected = 0 THEN 1 ELSE 0 END AS T_IsAutoPaymentAllowed,&#xA;&#x9;&#x9;CASE WHEN DiscountingFinances.PaymentFrequency = 'HalfYearly' THEN 'Half-Yearly' ELSE DiscountingFinances.PaymentFrequency END AS T_RepaymentFrequency,&#xA;&#x9;&#x9;DiscountingFinances.BookingStatus AS T_BookingStatus,&#xA;&#x9;&#x9;Contracts.Sequencenumber AS T_AssociatedLeaseSequenceNumber,&#xA;&#x9;&#x9;Discountings.Sequencenumber AS T_DiscountingSequenceNumber,&#xA;&#x9;&#x9;DiscountingFinances.Advance AS T_Advance,&#xA;&#x9;&#x9;DiscountingFinances.CompoundingFrequency AS T_CompoundingFrequency,&#xA;&#xA;&#x9;&#x9;DiscountingFinances.Id AS DiscountingFinanceId,&#xA;&#x9;&#x9;CASE WHEN Discountings.Alias IS NULL THEN '' ELSE LTRIM(Discountings.Alias) END AS T_LoanNumber,&#xA;&#x9;&#x9;DiscountingFinances.FunderId,&#xA;&#x9;&#x9;Parties.PartyNumber AS T_FundingSourceNumber,&#xA;&#x9;&#x9;Parties.PartyName AS T_FundingSource,&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;DiscountingFinances.CommencementDate AS T_CommencementDate,&#xA;&#x9;&#x9;DiscountingFinances.MaturityDate AS T_MaturityDate,&#xA;&#x9;&#x9;NULL AS T_ProcessThroughDate,&#xA;&#x9;&#x9;DiscountingFinances.DueDay AS T_DueDay,&#xA;&#x9;&#x9;DiscountingFinances.DiscountRate AS T_DiscountRate,&#xA;&#x9;&#x9;DiscountingFinances.DiscountingProceedsAmount_Amount AS T_LoanAmount,&#xA;&#x9;&#x9;DiscountingFinances.Yield AS T_Yield,&#xA;&#x9;&#x9;Currencies.Name AS T_Currency,&#xA;&#x9;&#x9;LegalEntities.LegalEntityNumber AS T_LegalEntityNumber,&#xA;&#x9;&#x9;DiscountingFinances.LoanDate,&#xA;&#x9;&#x9;DiscountingFinances.NetTermBasis,&#xA;&#x9;&#x9;DiscountingFinances.NetTerms,&#xA;&#x9;&#x9;DiscountingFinances.TValueComputeMethod,&#xA;&#x9;&#x9;DiscountingFinances.TValueDateCounting,&#xA;&#x9;&#x9;DiscountingFinances.RRPPaymentsFrom,&#xA;&#x9;&#x9;DiscountingFinances.RRPPaymentFrequency,&#xA;&#x9;&#x9;DiscountingFinances.RRPRegularPaymentAmount_Amount,&#xA;&#x9;&#x9;DiscountingFinances.PerfectPayPool &#xA;&#x9;&#x9;FROM &#xA;&#x9;&#x9;Discountings&#xA;&#xA;&#x9;&#x9;INNER JOIN DiscountingFinances&#xA;&#x9;&#x9;&#x9;ON DiscountingFinances.DiscountingId = Discountings.Id&#xA;&#x9;&#x9;&#x9;AND DiscountingFinances.IsCurrent = 1&#xA;&#xA;&#x9;&#x9;INNER JOIN LegalEntities&#xA;&#x9;&#x9;&#x9;ON DiscountingFinances.LegalEntityId = LegalEntities.Id&#xA;&#xA;&#x9;&#x9;INNER JOIN Currencies&#xA;&#x9;&#x9;&#x9;ON Currencies.Id = Discountings.CurrencyId&#xA;&#xA;&#x9;&#x9;INNER JOIN DiscountingServicingDetails&#xA;&#x9;&#x9;&#x9;ON DiscountingServicingDetails.DiscountingFinanceId = DiscountingFinances.Id&#xA;&#xA;&#x9;&#x9;LEFT JOIN Parties&#xA;&#x9;&#x9;&#x9;ON Parties.Id = DiscountingFinances.FunderId&#xA;&#xA;&#x9;&#x9;LEFT JOIN DiscountingContracts&#xA;&#x9;&#x9;&#x9;ON DiscountingContracts.DiscountingFinanceId =  DiscountingFinances.Id&#xA;&#xA;&#x9;&#x9;LEFT JOIN Contracts&#xA;&#x9;&#x9;&#x9;ON Contracts.Id = DiscountingContracts.ContractId&#xA;&#x9;WHERE &#xA;&#x9;&#x9;DiscountingContracts.ContractID = Contracts.Id&#xA;&#x9;&#x9; &#xA;&#x9;/* START Total (Payment, Principal, Interest) and Remaining Payment &amp; Principal Calculation*/&#xA;&#x9;SELECT&#xA;&#x9;&#x9;DiscountingFinances.Id AS DiscountingFinanceId,&#xA;&#x9;&#x9;SUM(DiscountingRepaymentSchedules.Amount_Amount) AS Payment_Amount,&#xA;&#x9;&#x9;SUM(DiscountingRepaymentSchedules.Principal_Amount) AS Principal_Amount,&#xA;&#x9;&#x9;SUM(DiscountingRepaymentSchedules.Interest_Amount) AS Interest_Amount,&#xA;&#x9;&#x9;SUM(DiscountingRepaymentSchedules.PrincipalProcessed_Amount) AS PrincipalProcessed_Amount,&#xA;&#x9;&#x9;SUM(DiscountingRepaymentSchedules.InterestProcessed_Amount) AS InterestProcessed_Amount,&#xA;&#x9;&#x9;MAX(DiscountingRepaymentSchedules.PaymentNumber) AS LastPaymentNumber&#xA;&#x9;INTO #DiscountingRepaymentScheduleSummary&#xA;&#x9;FROM &#xA;&#x9;&#x9;DiscountingRepaymentSchedules&#xA;&#xA;&#x9;&#x9;INNER JOIN DiscountingFinances&#xA;&#x9;&#x9;&#x9;ON DiscountingRepaymentSchedules.DiscountingFinanceId = DiscountingFinances.Id&#xA;&#x9;&#x9;&#x9;AND DiscountingRepaymentSchedules.IsActive = 1&#xA;&#x9;GROUP BY&#xA;&#x9;&#x9;DiscountingFinances.Id&#xA;&#xA;&#xA;&#x9;UPDATE &#xA;&#x9;&#x9;#TargetDiscountingDetails&#xA;&#x9;SET &#xA;&#x9;&#x9;T_LastPaymentDueDate = DiscountingRepaymentSchedules.DueDate,&#xA;&#x9;&#x9;T_MaturityDate = DiscountingRepaymentSchedules.DueDate&#xA;&#x9;FROM &#xA;&#x9;&#x9;#TargetDiscountingDetails &#xA;&#x9;&#x9;INNER JOIN #DiscountingRepaymentScheduleSummary DiscountingRepaymentScheduleSummary&#xA;&#x9;&#x9;ON DiscountingRepaymentScheduleSummary.DiscountingFinanceId = #TargetDiscountingDetails.DiscountingFinanceId&#xA;&#x9;&#x9;INNER JOIN DiscountingRepaymentSchedules ON DiscountingRepaymentScheduleSummary.DiscountingFinanceId = DiscountingRepaymentSchedules.DiscountingFinanceId&#xA;&#x9;&#x9;AND DiscountingRepaymentScheduleSummary.LastPaymentNumber = DiscountingRepaymentSchedules.PaymentNumber&#xA;&#xA;&#xA;&#x9;UPDATE &#xA;&#x9;&#x9;#TargetDiscountingDetails&#xA;&#x9;SET &#xA;&#x9;&#x9;T_TotalPaymentAmount = Payment_Amount,&#xA;&#x9;&#x9;T_TotalPrincipalAmount = Principal_Amount,&#xA;&#x9;&#x9;T_TotalInterestAccrualAmount = Interest_Amount,&#xA;&#x9;&#x9;T_RemainingPaymentAmount = Payment_Amount - (PrincipalProcessed_Amount + InterestProcessed_Amount),&#xA;&#x9;&#x9;T_RemainingPrincipalAmount = Principal_Amount - PrincipalProcessed_Amount&#xA;&#x9;&#x9;&#xA;&#x9;FROM &#xA;&#x9;&#x9;#TargetDiscountingDetails &#xA;&#x9;&#x9;INNER JOIN #DiscountingRepaymentScheduleSummary DiscountingRepaymentScheduleSummary&#xA;&#x9;&#x9;ON DiscountingRepaymentScheduleSummary.DiscountingFinanceId = #TargetDiscountingDetails.DiscountingFinanceId &#xA;&#xA;&#x9;/* END Total (Payment, Principal, Interest) and Remaining Payment &amp; Principal Calculation*/&#xA;&#xA;&#x9;/* START Interest calculation from Amortization schedules*/&#xA;&#x9;SELECT&#xA;&#x9;&#x9;DiscountingFinanceId,&#xA;&#x9;&#x9;MAX(ProcessThroughDate) AS ProcessThroughDate,&#xA;&#x9;&#x9;SUM(AccumulatedInterest_Amount) AS AccumulatedInterest_Amount,&#xA;&#x9;&#x9;SUM(RemainingInterest_Amount) AS RemainingInterest_Amount,&#xA;&#x9;&#x9;SUM(TotalCapitalizedInterest_Amount) AS TotalCapitalizedInterest_Amount,&#xA;&#x9;&#x9;SUM(RemainingCapitalizedInterest_Amount) AS RemainingCapitalizedInterest_Amount&#xA;&#x9;--&#x9;MAX(PostDate) AS MaxPostDate&#xA;&#x9;INTO #DiscountingAmortizationScheduleSummary&#xA;&#x9;FROM&#xA;&#x9;&#x9;(&#xA;&#x9;&#x9;&#x9;SELECT&#xA;&#x9;&#x9;&#x9;&#x9;DiscountingFinances.Id AS DiscountingFinanceId,&#xA;&#x9;&#x9;&#x9;&#x9;CASE WHEN DiscountingAmortizationSchedules.IsGLPosted = 1 THEN DiscountingAmortizationSchedules.ExpenseDate ELSE NULL END AS ProcessThroughDate,&#xA;&#x9;&#x9;&#x9;&#x9;CASE WHEN DiscountingAmortizationSchedules.IsGLPosted = 1 THEN DiscountingAmortizationSchedules.InterestAccrued_Amount ELSE 0 END AS AccumulatedInterest_Amount,&#xA;&#x9;&#x9;&#x9;&#x9;CASE WHEN DiscountingAmortizationSchedules.IsGLPosted = 0 THEN DiscountingAmortizationSchedules.InterestAccrued_Amount ELSE 0 END AS RemainingInterest_Amount,&#xA;&#x9;&#x9;&#x9;&#x9;DiscountingAmortizationSchedules.CapitalizedInterest_Amount AS TotalCapitalizedInterest_Amount,&#xA;&#x9;&#x9;&#x9;&#x9;CASE WHEN DiscountingAmortizationSchedules.IsGLPosted = 0 THEN DiscountingAmortizationSchedules.CapitalizedInterest_Amount ELSE 0 END AS RemainingCapitalizedInterest_Amount&#xA;&#x9;&#x9;&#x9;--&#x9;DiscountingAmortizationSchedules.PostDate&#xA;&#x9;&#x9;&#x9;FROM &#xA;&#x9;&#x9;&#x9;&#x9;DiscountingAmortizationSchedules&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;INNER JOIN DiscountingFinances&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;ON DiscountingAmortizationSchedules.DiscountingFinanceId = DiscountingFinances.Id&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;AND DiscountingAmortizationSchedules.IsSchedule = 1&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;AND DiscountingAmortizationSchedules.IsAccounting = 1&#xA;&#x9;&#x9;) RS1&#xA;&#x9;GROUP BY&#xA;&#x9;&#x9;DiscountingFinanceId&#xA;&#x9;&#x9; &#xA;&#x9;&#x9;SELECT DiscountingFinances.Id,&#xA;&#x9;&#x9;&#x9;SUM(Payables.Amount_Amount) PayableAmount&#xA;&#x9;&#x9;INTO #PayableDetails&#xA;&#x9;&#x9;FROM DiscountingFinances&#xA;&#x9;&#x9;&#x9;JOIN Payables&#xA;&#x9;&#x9;&#x9;&#x9;ON DiscountingFinances.Id = Payables.EntityId&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;AND EntityType = 'DT'&#xA;&#x9;&#x9;&#x9;JOIN PayableCodes&#xA;&#x9;&#x9;&#x9;&#x9;ON Payables.PayableCodeId = PayableCodes.Id&#xA;&#x9;&#x9;&#x9;JOIN PayableTypes&#xA;&#x9;&#x9;&#x9;&#x9;ON PayableCodes.PayableTypeId = PayableTypes.Id&#xA;&#x9;&#x9;&#x9;&#x9;&#x9;AND PayableTypes.Name = 'DiscountingInterest'&#xA;&#x9;&#x9;GROUP BY DiscountingFinances.Id&#xA;&#xA;&#x9;&#x9;SELECT DiscountingFinances.Id,&#xA;&#x9;&#x9;&#x9;&#x9;SUM(DiscountingAmortizationSchedules.InterestAccrued_Amount) AS FinalInterestAccrued_Amount&#xA;&#x9;&#x9;INTO #InterestSumDetails&#xA;&#x9;&#x9;FROM DiscountingFinances&#xA;&#x9;&#x9;&#x9;JOIN DiscountingAmortizationSchedules&#xA;&#x9;&#x9;&#x9;&#x9;ON DiscountingAmortizationSchedules.DiscountingFinanceId = DiscountingFinances.Id&#xA;&#x9;&#x9;WHERE ExpenseDate &lt;= @MigrationCutoffDate&#xA;&#x9;&#x9;GROUP BY DiscountingFinances.Id&#xA;&#xA;&#x9;&#x9;SELECT DiscountingFinances.Id AS DiscountingFinanceId,&#xA;&#x9;&#x9;&#x9;&#x9;ISNULL(FinalInterestAccrued_Amount, 0) - ISNULL(PayableAmount, 0) AS FinalInterestAccrualBalance_Amount&#xA;&#x9;&#x9;INTO #FinalInterestAccrualBalance_Amount&#xA;&#x9;&#x9;FROM DiscountingFinances&#xA;&#x9;&#x9;&#x9;LEFT JOIN #PayableDetails&#xA;&#x9;&#x9;&#x9;&#x9;ON DiscountingFinances.Id = #PayableDetails.Id&#xA;&#x9;&#x9;&#x9;LEFT JOIN #InterestSumDetails&#xA;&#x9;&#x9;&#x9;&#x9;ON DiscountingFinances.Id = #InterestSumDetails.Id&#xA;&#xA;&#x9;UPDATE &#xA;&#x9;&#x9;#TargetDiscountingDetails&#xA;&#x9;SET &#xA;&#x9;&#x9;T_ProcessThroughDate = DiscountingAmortizationScheduleSummary.ProcessThroughDate,&#xA;&#x9;&#x9;T_TotalCapitalizedInterestAmount = TotalCapitalizedInterest_Amount,&#xA;&#x9;&#x9;T_RemainingCapitalizedInterestAmount = RemainingCapitalizedInterest_Amount,&#xA;&#x9;&#x9;T_AccumulatedInterestAccrualAmount = AccumulatedInterest_Amount,&#xA;&#x9;&#x9;T_RemainingInterestAccrualAmount = RemainingInterest_Amount,&#xA;&#x9;&#x9;T_AccruedInterestBalance = #FinalInterestAccrualBalance_Amount.FinalInterestAccrualBalance_Amount&#xA;&#x9;&#x9;&#xA;&#x9;FROM &#xA;&#x9;&#x9;#TargetDiscountingDetails &#xA;&#xA;&#x9;&#x9;INNER JOIN #DiscountingAmortizationScheduleSummary DiscountingAmortizationScheduleSummary&#xA;&#x9;&#x9;&#x9;ON DiscountingAmortizationScheduleSummary.DiscountingFinanceId = #TargetDiscountingDetails.DiscountingFinanceId&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;LEFT JOIN #FinalInterestAccrualBalance_Amount &#xA;&#x9;&#x9;&#x9;ON DiscountingAmortizationScheduleSummary.DiscountingFinanceId = #FinalInterestAccrualBalance_Amount.DiscountingFinanceId&#xA;&#xA;&#x9;/* END Interest calculation from Amortization schedules */&#xA;&#xA;&#x9;/* START Debt Financing Cost */&#xA;&#x9;&#xA;&#x9;SELECT&#xA;&#x9;&#x9;TargetDiscountingDetails.DiscountingFinanceId&#xA;&#x9;&#x9;, DiscountingBlendedItems.BlendeditemId&#xA;&#x9;&#x9;, Amount_Amount BlendedAmount&#xA;&#x9;INTO #TargetBlendedItems&#xA;&#x9;FROM &#xA;&#x9;&#x9;#TargetDiscountingDetails TargetDiscountingDetails&#xA;&#xA;&#x9;&#x9;INNER JOIN DiscountingBlendedItems&#xA;&#x9;&#x9;&#x9;ON TargetDiscountingDetails.DiscountingFinanceId = DiscountingBlendedItems.DiscountingFinanceId&#xA;&#xA;&#x9;&#x9;INNER JOIN Blendeditems&#xA;&#x9;&#x9;&#x9;ON Blendeditems.Id = DiscountingBlendedItems.BlendeditemId&#xA;&#x9;&#x9;&#x9;AND Blendeditems.IsActive = 1&#xA;&#x9;&#xA;&#x9;&#x9;INNER JOIN BlendeditemCodes&#xA;&#x9;&#x9;&#x9;ON BlendeditemCodes.Id = Blendeditems.BlendeditemCodeId&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;UPDATE #TargetDiscountingDetails &#xA;&#x9;&#x9;SET T_DebtFinancingCostAmount = TargetBlendedItems.BlendedAmount &#xA;&#x9;FROM &#xA;&#x9;&#x9;#TargetDiscountingDetails TD&#xA;&#x9;&#xA;&#x9;&#x9;INNER JOIN #TargetBlendedItems TargetBlendedItems&#xA;&#x9;&#x9;&#x9;ON TargetBlendedItems.DiscountingFinanceId = TD.DiscountingFinanceId&#xA;&#xA;&#x9; &#xA;&#xA;&#x9;--SELECT * FROM #TargetDiscountingDetails&#xA;&#xA;-- 15B. DiscountingTarget.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.DBO.TargetDiscountingDetailsRecon&#xA;&#xA;SELECT 'TargetDiscountingDetails' Recon, *&#xA;INTO V5_Recon.DBO.TargetDiscountingDetailsRecon&#xA;FROM #TargetDiscountingDetails&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.DBO.TargetDiscountingDetailsRecon&#xA;&#xA;&#x9;--DROP TABLE #RemainingDebtFinancingCostdetails&#xA;&#x9;DROP TABLE #TargetBlendedItems&#xA;&#x9;DROP TABLE #DiscountingAmortizationScheduleSummary&#xA;&#x9;DROP TABLE #DiscountingRepaymentScheduleSummary&#xA;&#x9;--DROP TABLE #TargetDiscountingDetails&#xA;&#x9;DROP TABLE #FinalInterestAccrualBalance_Amount&#xA;&#x9;&#xA;--END&#xA;--GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
  <DTS:DesignTimeProperties><![CDATA[<?xml version="1.0"?>
