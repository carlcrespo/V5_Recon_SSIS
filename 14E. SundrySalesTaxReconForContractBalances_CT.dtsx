  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\14E SundrySalesTaxReconForContractBalances_CT"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{87901E2C-31EC-4D89-937B-C060D2826B95}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="14E SundrySalesTaxReconForContractBalances_CT"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 SundrySalesTaxReconForActiveContractBalances&#xA;&#xA;DROP TABLE IF EXISTS ##SundrySource&#xA;DROP TABLE IF EXISTS ##SundryTarget&#xA;DROP TABLE IF EXISTS ##Sundry&#xA;DROP TABLE IF EXISTS SundrySalesTaxReconForActiveContractBalances&#xA;DROP TABLE IF EXISTS #LeaseTemp&#xA;&#xA; DECLARE @TWStartDate DATE = (&#xA;    SELECT&#xA;      Date&#xA;    FROM&#xA;      Migration_Intermediate..TransactionDate&#xA;  )&#xA;SELECT&#xA;  Lease_Profile.LeaseID,&#xA;  Lease_InventoryInLease.InventoryID,&#xA;  Lease_InventoryInLease.IsInLease,&#xA;  Customer_Profile.Accountnumber AS CustomerNumber,&#xA;  Currency_Index.ISO,&#xA;  AccountingTreatmentTypeId,&#xA;  Lease_Profile.Sequencenumber,&#xA;  L.LegalentityNumber,&#xA;  L.LineOfBusinessName AS LOB,&#xA;  L.RemitToUniqueIdentifier AS RemitTo&#xA;Into&#xA;  #LeaseTemp&#xA;FROM&#xA;  Insight_Source..Lease_Profile&#xA;  INNER JOIN Insight_Source..Lease_Investment on Lease_Profile.LeaseID = Lease_Investment.LeaseId&#xA;  AND Insight_Source..Lease_Investment.IsActive = 1&#xA;  AND Lease_Profile.StatusId = 2&#xA;  INNER JOIN Insight_Source..Lease_InventoryInLease on Lease_Profile.LeaseID = Lease_InventoryInLease.LeaseID&#xA;  INNER JOIN Insight_Source..Customer_Profile on Insight_Source..Customer_Profile.CustomerID = Lease_Profile.CustomerID&#xA;  INNER JOIN Insight_Source..LLC_Profile on Insight_Source..LLC_Profile.LLCID = Lease_Profile.LLCID&#xA;  INNER JOIN Insight_Source..Currency_Index ON LLC_Profile.CurrencyIndexID = Currency_Index.CurrencyIndexID&#xA;  LEFT JOIN Migration_Intermediate..Lease L on L.SequenceNumber = CAST(Lease_Profile.SequenceNumber AS nvarchar(40))&#xA;GROUP BY&#xA;  Lease_Profile.LeaseID,&#xA;  Lease_InventoryInLease.InventoryID,&#xA;  Lease_InventoryInLease.IsInLease,&#xA;  Customer_Profile.Accountnumber,&#xA;  Currency_Index.ISO,&#xA;  AccountingTreatmentTypeId,&#xA;  Lease_Profile.Sequencenumber,&#xA;  L.LegalentityNumber,&#xA;  L.LineOfBusinessName,&#xA;  L.RemitToUniqueIdentifier&#xA;SELECT&#xA;  sum(Amount_Amount) AS Amount_Amount,&#xA;  Amount_Currency,&#xA;  sum(BalanceAmount_Amount) AS BalanceAmount_Amount,&#xA;  BalanceAmount_Currency,&#xA;  ContractSequenceNumber,&#xA;  CustomerPartyNumber,&#xA;  LegalEntityNumber,&#xA;  ReceivableDueDate,&#xA;  EntityType,&#xA;  ReceivableCodeName,&#xA;  ReceivableRemitToUniqueIdentifier,&#xA;  CurrencyCode,&#xA;  ReceivableHeaderID,&#xA;  CASE WHEN  ReceivableDueDate&lt;@TWStartDate THEN&#xA;  ('SundrySalesTax-CT-NTW-') + Cast(ReceivableHeaderID AS nvarchar)&#xA;  ELSE &#xA;&#x9;('SundrySalesTax-CT-TW-') + Cast(ReceivableHeaderID AS nvarchar) END AS UniqueIdentifier&#xA;INTO&#xA;  ##SundrySource&#xA;FROM&#xA;  (&#xA;    SELECT&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS Amount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS Amount_Currency,&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS BalanceAmount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS BalanceAmount_Currency,&#xA;      SequenceNumber AS ContractSequenceNumber,&#xA;      (CAST(CustomerNumber AS nvarchar(20))) AS CustomerPartyNumber,&#xA;      (CAST(LegalEntityNumber AS nvarchar(100))) AS LegalEntityNumber,&#xA;      (CAST(ph.DueDate AS date)) AS ReceivableDueDate,&#xA;      ('CT') AS EntityType, --&#xA;     'MIG Sales Tax-Sundry' AS ReceivableCodeName,&#xA;      RemitTo AS ReceivableRemitToUniqueIdentifier,&#xA;      CAST(ISO AS nvarchar(3)) AS CurrencyCode,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;    FROM&#xA;      #LeaseTemp&#xA;      INNER JOIN Insight_Source..Receivable_LeasePaymentHeader PH on PH.LeaseID = #LeaseTemp.LeaseID&#xA;      AND PH.IsActive = 1&#xA;      INNER JOIN Insight_Source..Receivable_LeasePaymentDetail PD on PH.ReceivableHeaderID = PD.ReceivableHeaderID&#xA;      AND PD.IsDummy = 0&#xA;      AND PD.ReceivableAdjustmentID IS NULL&#xA;      AND PD.InventoryID = #LeaseTemp.InventoryID&#xA;      AND PH.DueDate &lt; @TWStartDate&#xA;      INNER JOIN Insight_Source..Receivable_Tax on Receivable_Tax.ReceivableId = PD.ReceivableID&#xA;      AND Receivable_Tax.ReceivableTypeID = 1&#xA;      AND Receivable_Tax.IsActive = 1&#xA;    WHERE&#xA;      Receivable_Tax.TaxBalance &lt;&gt; 0&#xA;    GROUP BY&#xA;      PH.LeaseID,&#xA;      Sequencenumber,&#xA;      PH.DueDate,&#xA;      CustomerNumber,&#xA;      ISO,&#xA;      LOB,&#xA;      LegalEntityNumber,&#xA;      RemitTo,&#xA;      AccountingTreatmentTypeId,&#xA;      InvoiceGroupID,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;    HAVING&#xA;      SUM(Receivable_Tax.TaxBalance) &gt; 0&#xA;    UNION&#xA;    SELECT&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS Amount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS Amount_Currency,&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS BalanceAmount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS BalanceAmount_Currency,&#xA;      SequenceNumber AS ContractSequenceNumber,&#xA;      (CAST(CustomerNumber AS nvarchar(20))) AS CustomerPartyNumber,&#xA;      (CAST(LegalEntityNumber AS nvarchar(100))) AS LegalEntityNumber,&#xA;      (CAST(ph.DueDate AS date)) AS ReceivableDueDate,&#xA;      ('CT') AS EntityType, --&#xA;     'MIG Sales Tax-Sundry' AS ReceivableCodeName,&#xA;      RemitTo AS ReceivableRemitToUniqueIdentifier,&#xA;      CAST(ISO AS nvarchar(3)) AS CurrencyCode,&#xA;&#x9;  PH.ReceivableHeaderID &#xA;    FROM&#xA;      #LeaseTemp&#xA;      INNER JOIN Insight_Source..Receivable_LeasePaymentHeader PH on PH.LeaseID = #LeaseTemp.LeaseID&#xA;      AND PH.IsActive = 1&#xA;      INNER JOIN Insight_Source..Receivable_LeasePaymentDetail PD on PH.ReceivableHeaderID = PD.ReceivableHeaderID&#xA;      AND PD.IsDummy = 0&#xA;      AND PD.ReceivableAdjustmentID IS NULL&#xA;      AND PD.InventoryID = #LeaseTemp.InventoryID&#xA;      AND PH.DueDate &gt;= @TWStartDate&#xA;      AND #LeaseTemp.IsInLease = 0&#xA;      INNER JOIN Insight_Source..Receivable_Tax on Receivable_Tax.ReceivableId = PD.ReceivableID&#xA;      AND Receivable_Tax.ReceivableTypeID = 1&#xA;      AND Receivable_Tax.IsActive = 1&#xA;    WHERE&#xA;      Receivable_Tax.TaxBalance &lt;&gt; 0&#xA;    GROUP BY&#xA;      PH.LeaseID,&#xA;      Sequencenumber,&#xA;      PH.DueDate,&#xA;      CustomerNumber,&#xA;      ISO,&#xA;      LOB,&#xA;      LegalEntityNumber,&#xA;      RemitTo,&#xA;      AccountingTreatmentTypeId,&#xA;      InvoiceGroupID,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;    HAVING&#xA;      SUM(Receivable_Tax.TaxBalance) &gt; 0&#xA;    UNION&#xA;    SELECT&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS Amount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS Amount_Currency,&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS BalanceAmount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS BalanceAmount_Currency,&#xA;      SequenceNumber AS ContractSequenceNumber,&#xA;      (CAST(CustomerNumber AS nvarchar(20))) AS CustomerPartyNumber,&#xA;      (CAST(LegalEntityNumber AS nvarchar(100))) AS LegalEntityNumber,&#xA;      (CAST(ph.DueDate AS date)) AS ReceivableDueDate,&#xA;      ('CT') AS EntityType, --&#xA;      'MIG Sales Tax-Sundry' AS ReceivableCodeName,&#xA;      RemitTo AS ReceivableRemitToUniqueIdentifier,&#xA;      CAST(ISO AS nvarchar(3)) AS CurrencyCode,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;&#x9;  &#xA;    FROM&#xA;      #LeaseTemp&#xA;      INNER JOIN Insight_Source..Receivable_OtherPaymentHeader PH on PH.LeaseID = #LeaseTemp.LeaseID&#xA;      AND PH.IsActive = 1&#xA;      INNER JOIN Insight_Source..Receivable_OtherPaymentDetail PD on PH.ReceivableHeaderID = PD.ReceivableHeaderID&#xA;      AND PD.IsDummy = 0&#xA;      AND PD.ReceivableAdjustmentID IS NULL&#xA;      AND PD.InventoryID = #LeaseTemp.InventoryID&#xA;      AND PH.DueDate &lt; @TWStartDate&#xA;      INNER JOIN Insight_Source..Receivable_Tax on Receivable_Tax.ReceivableId = PD.ReceivableID&#xA;      AND Receivable_Tax.ReceivableTypeID = PD.ReceivableTypeID&#xA;      AND Receivable_Tax.IsActive = 1&#xA;    WHERE&#xA;      Receivable_Tax.TaxBalance &lt;&gt; 0&#xA;    GROUP BY&#xA;      ph.LeaseID,&#xA;      SequenceNumber,&#xA;      ph.DueDate,&#xA;      CustomerNumber,&#xA;      ISO,&#xA;      InvoiceGroupID,&#xA;      AccountingTreatmentTypeId,&#xA;      ph.Receivabletypeid,&#xA;      LegalentityNumber,&#xA;      LOB,&#xA;      RemitTo,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;    HAVING&#xA;      SUM(Receivable_Tax.TaxBalance) &gt; 0&#xA;    UNION&#xA;    SELECT&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS Amount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS Amount_Currency,&#xA;      (&#xA;        CAST(SUM(Receivable_Tax.TaxBalance) AS Decimal(16, 2))&#xA;      ) AS BalanceAmount_Amount,&#xA;      CAST(ISO AS nvarchar(3)) AS BalanceAmount_Currency,&#xA;      SequenceNumber AS ContractSequenceNumber,&#xA;      (CAST(CustomerNumber AS nvarchar(20))) AS CustomerPartyNumber,&#xA;      (CAST(LegalEntityNumber AS nvarchar(100))) AS LegalEntityNumber,&#xA;      (CAST(ph.DueDate AS date)) AS ReceivableDueDate,&#xA;      ('CT') AS EntityType,&#xA;      'MIG Sales Tax-Sundry' AS ReceivableCodeName,&#xA;      RemitTo AS ReceivableRemitToUniqueIdentifier,&#xA;      CAST(ISO AS nvarchar(3)) AS CurrencyCode,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;    FROM&#xA;      #LeaseTemp&#xA;      INNER JOIN Insight_Source..Receivable_OtherPaymentHeader PH on PH.LeaseID = #LeaseTemp.LeaseID&#xA;      AND PH.IsActive = 1&#xA;      INNER JOIN Insight_Source..Receivable_OtherPaymentDetail PD on PH.ReceivableHeaderID = PD.ReceivableHeaderID&#xA;      AND PD.IsDummy = 0&#xA;      AND PD.ReceivableAdjustmentID IS NULL&#xA;      AND PD.InventoryID = #LeaseTemp.InventoryID&#xA;      AND PH.DueDate &gt;= @TWStartDate&#xA;      AND #LeaseTemp.IsInLease = 0&#xA;      INNER JOIN Insight_Source..Receivable_Tax on Receivable_Tax.ReceivableId = PD.ReceivableID&#xA;      AND Receivable_Tax.ReceivableTypeID = PD.ReceivableTypeID&#xA;      AND Receivable_Tax.IsActive = 1&#xA;    WHERE&#xA;      Receivable_Tax.TaxBalance &lt;&gt; 0&#xA;    GROUP BY&#xA;      ph.LeaseID,&#xA;      SequenceNumber,&#xA;      ph.DueDate,&#xA;      CustomerNumber,&#xA;      ISO,&#xA;      InvoiceGroupID,&#xA;      AccountingTreatmentTypeId,&#xA;      ph.Receivabletypeid,&#xA;      LegalentityNumber,&#xA;      LOB,&#xA;      RemitTo,&#xA;&#x9;  PH.ReceivableHeaderID&#xA;    HAVING&#xA;      SUM(Receivable_Tax.TaxBalance) &gt; 0&#xA;  ) AS SundrySource&#xA;GROUP BY&#xA;  Amount_Currency,&#xA;  BalanceAmount_Currency,&#xA;  ContractSequenceNumber,&#xA;  CustomerPartyNumber,&#xA;  LegalEntityNumber,&#xA;  ReceivableDueDate,&#xA;  EntityType,&#xA;  ReceivableCodeName,&#xA;  ReceivableRemitToUniqueIdentifier,&#xA;  CurrencyCode,&#xA;  ReceivableHeaderID&#xA;SELECT&#xA;  Sum(Sundries.Amount_Amount) Amount_Amount,&#xA;  Sundries.Amount_Currency,&#xA;  sum(Receivables.TotalBalance_Amount) AS BalanceAmount_Amount,&#xA;  Receivables.TotalBalance_Currency AS BalanceAmount_Currency,&#xA;  Contracts.SequenceNumber ContractSequenceNumber,&#xA;  Parties.PartyNumber CustomerPartyNumber,&#xA;  LegalEntityNumber,&#xA;  ReceivableDueDate,&#xA;  (Sundries.Entitytype) AS EntityType,&#xA;  ReceivableCodes.Name ReceivableCodeName,&#xA;  RemitToes.UniqueIdentifier ReceivableRemitToUniqueIdentifier,&#xA;  CurrencyCode,&#xA;  Receivables.UniqueIdentifier&#xA;INTO&#xA;  ##SundryTarget&#xA;FROM&#xA;  Insight_UAT..Sundries&#xA;  JOIN Insight_UAT..Receivables on Sundries.ReceivableId = Receivables.Id&#xA;  AND Receivables.UniqueIdentifier LIKE 'SundrySalesTax-%CT-%'&#xA;  LEFT JOIN Insight_UAT..Parties on Parties.Id = Receivables.CustomerId&#xA;  JOIN Insight_UAT..LegalEntities on LegalEntities.Id = Receivables.LegalEntityId&#xA;  AND LegalEntities.BusinessUnitId = 1&#xA;  LEFT JOIN Insight_UAT..Contracts on Contracts.Id = Sundries.ContractId&#xA;  LEFT JOIN Insight_UAT..ReceivableCodes on ReceivableCodes.Id = Receivables.ReceivableCodeId&#xA;  LEFT JOIN Insight_UAT..RemitToes on RemitToes.Id = Sundries.ReceivableRemitToId&#xA;  LEFT JOIN Insight_UAT..ReceivableDetails on Receivables.id = ReceivableDetails.ReceivableId&#xA;  LEFT JOIN Insight_UAT..BillToes on BillToes.Id = ReceivableDetails.BillToId&#xA;WHERE&#xA;  sundries.InvoiceComment IS NULL&#xA;GROUP BY&#xA;  Sundries.Amount_Currency,&#xA;  Receivables.TotalBalance_Currency,&#xA;  Contracts.SequenceNumber,&#xA;  Parties.PartyNumber,&#xA;  LegalEntityNumber,&#xA;  ReceivableDueDate,&#xA;  Sundries.Entitytype,&#xA;  ReceivableCodes.Name,&#xA;  RemitToes.UniqueIdentifier,&#xA;  CurrencyCode,&#xA;  Receivables.UniqueIdentifier&#xA;SELECT&#xA;  Source.ReceivableHeaderID,&#xA;  Source.Amount_Amount S_Amount_Amount,&#xA;  Target.Amount_Amount T_Amount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Amount_Amount, 0) &lt;&gt; ISNULL(Target.Amount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Amount_Amount_Matched,&#xA;  Source.Amount_Currency S_Amount_Currency,&#xA;  Target.Amount_Currency T_Amount_Currency,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Amount_Currency, 0) &lt;&gt; ISNULL(Target.Amount_Currency, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Amount_Currency_Matched,&#xA;  Source.BalanceAmount_Amount S_BalanceAmount_Amount,&#xA;  Target.BalanceAmount_Amount T_BalanceAmount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.BalanceAmount_Amount, 0) &lt;&gt; ISNULL(Target.BalanceAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; BalanceAmount_Amount_Matched,&#xA;  Source.BalanceAmount_Currency S_BalanceAmount_Currency,&#xA;  Target.BalanceAmount_Currency T_BalanceAmount_Currency,&#xA;  CASE&#xA;    WHEN ISNULL(Source.BalanceAmount_Amount, 0) &lt;&gt; ISNULL(Target.BalanceAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; BalanceAmount_Currency_Matched,&#xA;  Source.ContractSequenceNumber S_ContractSequenceNumber,&#xA;  Target.ContractSequenceNumber T_ContractSequenceNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ContractSequenceNumber, 0) &lt;&gt; ISNULL(Target.ContractSequenceNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ContractSequenceNumber_Matched,&#xA;  Source.CustomerPartyNumber S_CustomerPartyNumber,&#xA;  Target.CustomerPartyNumber T_CustomerPartyNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerPartyNumber, 0) &lt;&gt; ISNULL(Target.CustomerPartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerPartyNumber_Matched,&#xA;  Source.LegalEntityNumber S_LegalEntityNumber,&#xA;  Target.LegalEntityNumber T_LegalEntityNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.LegalEntityNumber, 0) &lt;&gt; ISNULL(Target.LegalEntityNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LegalEntityNumber_Matched,&#xA;  Source.ReceivableDueDate S_ReceivableDueDate,&#xA;  Target.ReceivableDueDate T_ReceivableDueDate,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ReceivableDueDate, '1900-01-01') &lt;&gt; ISNULL(Target.ReceivableDueDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ReceivableDueDate_Matched&#xA;  --,Source.SundryType SundryType&#xA;  --,Target.SundryType SundryType&#xA;  --,CASE WHEN ISNULL(Source.SundryType,0) &lt;&gt; ISNULL(Target.SundryType,0) THEN 'FALSE' ELSE 'TRUE' ENDÃ‚Â SundryType_Matched&#xA;,&#xA;  Source.EntityType S_EntityType,&#xA;  Target.EntityType T_EntityType,&#xA;  CASE&#xA;    WHEN ISNULL(Source.EntityType, 0) &lt;&gt; ISNULL(Target.EntityType, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; EntityType_Matched,&#xA;  Source.ReceivableCodeName S_ReceivableCodeName,&#xA;  Target.ReceivableCodeName T_ReceivableCodeName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ReceivableCodeName, 0) &lt;&gt; ISNULL(Target.ReceivableCodeName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ReceivableCodeName_Matched,&#xA;  Source.ReceivableRemitToUniqueIdentifier S_ReceivableRemitToUniqueIdentifier,&#xA;  Target.ReceivableRemitToUniqueIdentifier T_ReceivableRemitToUniqueIdentifier,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ReceivableRemitToUniqueIdentifier, 0) &lt;&gt; ISNULL(Target.ReceivableRemitToUniqueIdentifier, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ReceivableRemitToUniqueIdentifier_Matched,&#xA;  Source.CurrencyCode S_CurrencyCode,&#xA;  Target.CurrencyCode T_CurrencyCode,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CurrencyCode, 0) &lt;&gt; ISNULL(Target.CurrencyCode, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CurrencyCode_Matched&#xA;into&#xA;  ##Sundry&#xA;FROM&#xA;  ##SundrySource Source&#xA;  INNER JOIN ##SundryTarget Target ON Source.ContractSequenceNumber = Target.ContractSequenceNumber&#xA;  --AND Source.ReceivableDueDate = Target.ReceivableDueDate --AND (Source.CustomerPartyNumber IS NULL OR Source.CustomerPartyNumber = Target.CustomerPartyNumber)&#xA;  AND SOURCE.UniqueIdentifier = TARGET.UniqueIdentifier&#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE SundrySalesTaxReconForActiveContractBalances  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##Sundry'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript&#xA;&#xA;-- 14E. SundrySalesTaxReconForContractBalances_CT.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.SundrySalesTaxReconForActiveContractBalances&#xA;&#xA;--INSERT INTO&#xA;--  SundrySalesTaxReconForActiveContractBalances&#xA;&#xA;SELECT 'SundrySalesTaxReconForActiveContractBalances' Recon, *&#xA;INTO V5_Recon.dbo.SundrySalesTaxReconForActiveContractBalances&#xA;FROM ##Sundry&#xA;&#xA;--SELECT * FROM SundrySalesTaxReconForActiveContractBalances&#xA;&#xA;SELECT * &#xA;FROM V5_Recon.dbo.SundrySalesTaxReconForActiveContractBalances" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
