ransferMonth T_PractTitleTransferMonth&#xA;,CASE WHEN ISNULL(Source.PractTitleTransferMonth,0) &lt;&gt; ISNULL(Target.PractTitleTransferMonth,0) THEN 'FALSE' ELSE 'TRUE' END PractTitleTransferMonth_Matched&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;--,Source.NonStandard S_NonStandard&#xA;--,Target.NonStandard T_NonStandard&#xA;--,CASE WHEN ISNULL(Source.NonStandard,0) &lt;&gt; ISNULL(Target.NonStandard,0) THEN 'FALSE' ELSE 'TRUE' END NonStandard_Matched&#xA;&#xA;&#xA; &#xA;--,Source.PractNonStandard S_PractNonStandard&#xA;--,Target.PractNonStandard T_PractNonStandard&#xA;--,CASE WHEN ISNULL(Source.PractNonStandard,0) &lt;&gt; ISNULL(Target.PractNonStandard,0) THEN 'FALSE' ELSE 'TRUE' END PractNonStandard_Matched&#xA;&#xA;&#xA; &#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;,Source.IsPractSpecialEOTProvisionsAndRestrictions S_IsPractSpecialEOTProvisionsAndRestrictions&#xA;,Target.IsPractSpecialEOTProvisionsAndRestrictions T_IsPractSpecialEOTProvisionsAndRestrictions&#xA;,CASE WHEN ISNULL(Source.IsPractSpecialEOTProvisionsAndRestrictions,0) &lt;&gt; ISNULL(Target.IsPractSpecialEOTProvisionsAndRestrictions,0) THEN 'FALSE' ELSE 'TRUE' END IsPractSpecialEOTProvisionsAndRestrictions_Matched&#xA;&#xA;,Source.IsPractSpecialEarlyTermProvisions S_IsPractSpecialEarlyTermProvisions&#xA;,Target.IsPractSpecialEarlyTermProvisions T_IsPractSpecialEarlyTermProvisions&#xA;,CASE WHEN ISNULL(Source.IsPractSpecialEarlyTermProvisions,0) &lt;&gt; ISNULL(Target.IsPractSpecialEarlyTermProvisions,0) THEN 'FALSE' ELSE 'TRUE' END IsPractSpecialEarlyTermProvisions_Matched&#xA;&#xA;,Source.PractEOTPAndRDetails S_PractEOTPAndRDetails&#xA;,Target.PractEOTPAndRDetails T_PractEOTPAndRDetails&#xA;,CASE WHEN ISNULL(Source.PractEOTPAndRDetails,0) &lt;&gt; ISNULL(Target.PractEOTPAndRDetails,0) THEN 'FALSE' ELSE 'TRUE' END PractEOTPAndRDetails_Matched&#xA;&#xA;,Source.PractEarlyTermProvisionsDetails S_PractEarlyTermProvisionsDetails&#xA;,Target.PractEarlyTermProvisionsDetails T_PractEarlyTermProvisionsDetails&#xA;,CASE WHEN ISNULL(Source.PractEarlyTermProvisionsDetails,0) &lt;&gt; ISNULL(Target.PractEarlyTermProvisionsDetails,0) THEN 'FALSE' ELSE 'TRUE' END PractEarlyTermProvisionsDetails_Matched&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA;&#xA; &#xA;&#xA; &#xA;&#xA;into ##MasterAgreement&#xA; from ##MasterAgreementSource Source inner join ##MasterAgreementTarget Target on Source.MLAID=Target.ID&#xA;   order by Source.Number asc&#xA;&#xA;&#xA;DECLARE @CreateTableScript NVARCHAR(max) = 'CREATE TABLE MasterAgreementRecon (';&#xA;&#xA;DECLARE @Columns NVARCHAR(max);&#xA;&#xA;SELECT @Columns = ISNULL(@Columns + ', ', '') +&#xA;    COLUMN_NAME +&#xA;    ' ' +&#xA;    DATA_TYPE +&#xA;    CASE&#xA;        WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;        WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;        WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;        ELSE ''&#xA;    END&#xA;FROM tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;WHERE TABLE_NAME = '##MasterAgreement';&#xA;&#xA;SET @CreateTableScript = @CreateTableScript + @Columns + ');';&#xA;&#xA;EXEC sp_executesql @CreateTableScript;&#xA;&#xA;-- MLARecon-Latest&#xA;Drop table IF EXISTS V5_Recon.dbo.MasterAgreementRecon&#xA;&#xA;--use insight_uat&#xA;&#xA;--Insert into MasterAgreementRecon &#xA;&#xA;select 'MLARecon' Recon,* &#xA;into V5_Recon.dbo.MasterAgreementRecon&#xA;from ##MasterAgreement&#xA;&#xA;Select *&#xA;From V5_Recon.dbo.MasterAgreementRecon&#xA;  &#xA;--DROP TABLE IF EXISTS  ##MasterAgreementSource&#xA;--DROP TABLE IF EXISTS  ##MasterAgreementTarget&#xA;--DROP TABLE IF EXISTS  ##MasterAgreement&#xA;&#xA; " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
