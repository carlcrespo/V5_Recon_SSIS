      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="DROP TABLE IF EXISTS  ##MasterAgreementSource&#xA;DROP TABLE IF EXISTS  ##MasterAgreementTarget&#xA;DROP TABLE IF EXISTS  ##MasterAgreement&#xA;DROP TABLE IF EXISTS  MasterAgreementRecon&#xA;&#xA;SELECT&#xA;Insight_Source.dbo.MLA_Profile.MLAID ,&#xA;(CAST(Insight_Source.dbo.MLA_Profile.MLADate AS date)) AS ActivationDate, &#xA;(CAST(Insight_Source.dbo.MLA_Profile.MLAName AS nvarchar(40))) AS MLAName, &#xA;(CAST(Insight_Source.dbo.MLA_Profile.MLADate AS date)) AS AgreementDate, &#xA;(CAST(Template_MLAType_CnfgMasterAgreement.Description AS nvarchar(40))) AS AgreementTypeName,   &#xA; &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.EarlyTermConditions AS nvarchar(4000)),0) AS EOTOptionEarlyTermProvisionsDetails, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.Conditions AS nvarchar(4000)),0) AS EOTOptionEOTPAndRDetails, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FirstReminderNoticeDays AS BigInt),0) AS EOTOptionLessorNoticeDays, &#xA;--ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FTNoticePeriod AS BigInt),0) AS EOTOptionMaxNoticePeriod, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FTNoticePeriod AS BigInt),0) AS EOTOptionMinNoticePeriod, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.OTPFrequencyID = 1 THEN 'Monthly' WHEN Insight_Source.dbo.MLA_Profile.OTPFrequencyID = 2 THEN 'Quarterly' WHEN Insight_Source.dbo.MLA_Profile.OTPFrequencyID = 3 THEN 'HalfYearly' WHEN Insight_Source.dbo.MLA_Profile.OTPFrequencyID = 4 THEN 'Yearly' WHEN Insight_Source.dbo.MLA_Profile.OTPFrequencyID = 5 THEN '_' END ) AS EOTOptionOTPFrequency, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.OTPNoticePeriod AS BigInt),0) AS EOTOptionOTPLesseeNoticePeriod, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.Conditions AS nvarchar(100)),0) AS EOTPAndRDetails, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FirstReductionPeriod AS nvarchar(20)),0) AS FirstReductionMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FirstReductionPercent AS Decimal(5,2)),0) AS FirstReductionPercent  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FirstReminderNoticeDays AS BigInt),0) AS FirstReminderNoticeDays, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.FreightResponsibilityID = 1 THEN 'Customer' WHEN Insight_Source.dbo.MLA_Profile.FreightResponsibilityID = 2 THEN 'Other' WHEN Insight_Source.dbo.MLA_Profile.FreightResponsibilityID = 3 THEN 'Insight' WHEN Insight_Source.dbo.MLA_Profile.FreightResponsibilityID = 4 THEN 'NA' END ) AS FreightResponsibility  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.LeaseFrequencyID = 1 THEN 'Monthly' WHEN Insight_Source.dbo.MLA_Profile.LeaseFrequencyID = 2 THEN 'Quarterly' WHEN Insight_Source.dbo.MLA_Profile.LeaseFrequencyID = 3 THEN 'HalfYearly' WHEN Insight_Source.dbo.MLA_Profile.LeaseFrequencyID = 4 THEN 'Yearly' WHEN Insight_Source.dbo.MLA_Profile.LeaseFrequencyID = 5 THEN '_' END ) AS Frequency  , &#xA;(CAST(Insight_Source.dbo.MLA_Profile.MLAID AS BigInt)) AS Id, &#xA;(CAST(Insight_Source.dbo.MLA_Profile.InterimAcceptanceDays AS BigInt)) AS InterimAcceptanceDays  , &#xA;(CAST(Insight_Source.dbo.MLA_Profile.LeaseAdvancePayment AS BigInt)) AS IsAdvance, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsDoubleInArrears AS bit),0) AS IsEOTOptionDelayedInvoicing, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.OTPAdvancePayment AS bit),0) AS IsEOTOptionOTPAdvancePayment, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsOTPAllowed AS bit),0) AS IsEOTOptionOTPAllowed, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsSpecialEarlyTermProvisions AS bit),0) AS IsEOTOptionSpecialEarlyTermProvisions, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsSpecialEOTProvision AS bit),0) AS IsEOTOptionSpecialEOTProvisionsAndRestrictions, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsInterimBilling AS bit),0) AS IsInterimBillingApplies  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsDoubleInArrears AS bit),0) AS IsPractDelayedInvoicing, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractOTPAdvancePayment AS bit),0) AS IsPractOTPAdvancePayment, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsOTPAllowed AS bit),0) AS IsPractOTPAllowed, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsSpecialEarlyTermProvisions AS bit),0) AS IsPractSpecialEarlyTermProvisions, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsSpecialEOTProvision AS bit),0) AS IsPractSpecialEOTProvisionsAndRestrictions, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsSuspendOTPBilling AS bit),0) AS IsPractSuspendOTPBilling  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractOTPNoticePeriod AS BigInt),0) AS PractOTPLesseeNoticePeriod, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsSuspendOTPBilling AS bit),0) AS IsSuspendOTPBilling  , &#xA;(CAST(Insight_Source.dbo.MLA_Profile.LeaseLeadDays AS BigInt)) AS LeadDays   , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PurchaseID = 1 THEN 'Partial' WHEN Insight_Source.dbo.MLA_Profile.PurchaseID = 2 THEN 'All but not less than all' WHEN Insight_Source.dbo.MLA_Profile.PurchaseID = 3 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.PurchaseID = 4 THEN 'NA' END ) AS Purchase  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.RenewID = 1 THEN 'Partial' WHEN Insight_Source.dbo.MLA_Profile.RenewID = 2 THEN 'All but not less than all' WHEN Insight_Source.dbo.MLA_Profile.RenewID = 3 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.RenewID = 4 THEN 'NA' END ) AS Renew  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.ReturnID = 1 THEN 'Partial' WHEN Insight_Source.dbo.MLA_Profile.ReturnID = 2 THEN 'All but not less than all' WHEN Insight_Source.dbo.MLA_Profile.ReturnID = 3 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.ReturnID = 4 THEN 'NA' END ) AS ReturnOption  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsLesseeDeterminedFMV AS bit),0) AS IsLesseeDeterminedFMV  ,&#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsFMVCap AS bit),0) AS IsFMVCap  ,&#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FMVCapPercent AS BigInt),0) AS FMVCapPercent, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FMVCapDetails AS nvarchar(1000)),0) AS FMVCapDetails , &#xA;&#xA;&#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.LKEAllowedId = 1 THEN 'PCEquipmentOnly' WHEN Insight_Source.dbo.MLA_Profile.LKEAllowedId = 2 THEN 'AllITEquipment' WHEN Insight_Source.dbo.MLA_Profile.LKEAllowedId = 3 THEN 'AllEquipment' WHEN Insight_Source.dbo.MLA_Profile.LKEAllowedId = 4 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.LKEAllowedId = 5 THEN 'NA' END ) AS LKEAllowed  , &#xA;(0) AS NonStandard, &#xA;CAST(ClientMLANumber AS nvarchar(40)) AS Number, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsStructure AS bit),0) AS OtherStructure  , &#xA;(Insight_Source.dbo.MLA_Profile.StructureDescription) AS OtherStructureDescription, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractEarlyTermConditions AS nvarchar(4000)),0) AS PractEarlyTermProvisionsDetails, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractConditions AS nvarchar(4000)),0) AS PractEOTPAndRDetails, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFirstReductionPeriod AS nvarchar(20)),0) AS PractFirstReductionMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFirstReductionPercent AS Decimal(5,2)),0) AS PractFirstReductionPercent  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractFreightResponsibilityID = 1 THEN 'Customer' WHEN Insight_Source.dbo.MLA_Profile.PractFreightResponsibilityID = 2 THEN 'Other' WHEN Insight_Source.dbo.MLA_Profile.PractFreightResponsibilityID = 3 THEN 'Insight' WHEN Insight_Source.dbo.MLA_Profile.PractFreightResponsibilityID = 4 THEN 'NA' END ) AS PractFreightResponsibility  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFirstReminderNoticeDays AS BigInt),0) AS PractLessorNoticeDays,&#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractLKEAllowedId = 1 THEN 'PCEquipmentOnly' WHEN Insight_Source.dbo.MLA_Profile.PractLKEAllowedId = 2 THEN 'AllITEquipment' WHEN Insight_Source.dbo.MLA_Profile.PractLKEAllowedId = 3 THEN 'AllEquipment' WHEN Insight_Source.dbo.MLA_Profile.PractLKEAllowedId = 4 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.PractLKEAllowedId = 5 THEN 'NA' END ) AS PractLKEAllowed  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFTNoticePeriod AS BigInt),0) AS PractMaxNoticePeriod, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFTNoticePeriod AS BigInt),0) AS PractMinNoticePeriod, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsStructure AS bit),0) AS PractOtherStructure  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractPurchaseID = 1 THEN 'Partial' WHEN Insight_Source.dbo.MLA_Profile.PractPurchaseID = 2 THEN 'All but not less than all' WHEN Insight_Source.dbo.MLA_Profile.PractPurchaseID = 3 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.PractPurchaseID = 4 THEN 'NA' END ) AS PractPurchase  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractRenewID = 1 THEN 'Partial' WHEN Insight_Source.dbo.MLA_Profile.PractRenewID = 2 THEN 'All but not less than all' WHEN Insight_Source.dbo.MLA_Profile.PractRenewID = 3 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.PractRenewID = 4 THEN 'NA' END ) AS PractRenew  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractReturnID = 1 THEN 'Partial' WHEN Insight_Source.dbo.MLA_Profile.PractReturnID = 2 THEN 'All but not less than all' WHEN Insight_Source.dbo.MLA_Profile.PractReturnID = 3 THEN 'None' WHEN Insight_Source.dbo.MLA_Profile.PractReturnID = 4 THEN 'NA' END ) AS PractReturnOption  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsLesseeDeterminedFMV AS bit),0) AS PractIsLesseeDeterminedFMV  ,&#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsFMVCap AS bit),0) AS PractIsFMVCap  ,&#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFMVCapPercent AS BigInt),0) AS PractFMVCapPercent, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractFMVCapDetails AS nvarchar(1000)),0) AS PractFMVCapDetails , &#xA;&#xA;&#xA;&#xA;&#xA;&#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractStructureDescription AS nvarchar(1000)),0) AS PractOtherStructureDescription , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.RecertificationReqdID = 1 THEN '1' WHEN Insight_Source.dbo.MLA_Profile.RecertificationReqdID = 2 THEN '0' WHEN Insight_Source.dbo.MLA_Profile.RecertificationReqdID = 3 THEN '0' END ) AS RecertificationRequired, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.DataSecurityReqdID = 1 THEN '1' WHEN Insight_Source.dbo.MLA_Profile.DataSecurityReqdID = 2 THEN '0' WHEN Insight_Source.dbo.MLA_Profile.DataSecurityReqdID = 3 THEN '0' END ) AS DataSecurityRequired, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.DecontaminationReqdID = 1 THEN '1' WHEN Insight_Source.dbo.MLA_Profile.DecontaminationReqdID = 2 THEN '0' WHEN Insight_Source.dbo.MLA_Profile.DecontaminationReqdID = 3 THEN '0' END ) AS DecontaminationRequired, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractRecertificationReqdID = 1 THEN '1' WHEN Insight_Source.dbo.MLA_Profile.PractRecertificationReqdID = 2 THEN '0' WHEN Insight_Source.dbo.MLA_Profile.PractRecertificationReqdID = 3 THEN '0' END ) AS PractRecertificationRequired, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractDataSecurityReqdID = 1 THEN '1' WHEN Insight_Source.dbo.MLA_Profile.PractDataSecurityReqdID = 2 THEN '0' WHEN Insight_Source.dbo.MLA_Profile.PractDataSecurityReqdID = 3 THEN '0' END ) AS PractDataSecurityRequired, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractDecontaminationReqdID = 1 THEN '1' WHEN Insight_Source.dbo.MLA_Profile.PractDecontaminationReqdID = 2 THEN '0' WHEN Insight_Source.dbo.MLA_Profile.PractDecontaminationReqdID = 3 THEN '0' END ) AS PractDecontaminationRequired, &#xA;Insight_Source.dbo.MLA_Profile.EOTPartialGracePeriod AS EOTPartialGracePeriod, &#xA;Insight_Source.dbo.MLA_Profile.EOTABNLTAGracePeriod  AS EOTABNLTAGracePeriod, &#xA;Insight_Source.dbo.MLA_Profile.OTPGracePeriod  OTPGracePeriod, &#xA;Insight_Source.dbo.MLA_Profile.PractEOTPartialGracePeriod  AS PractEOTPartialGracePeriod, &#xA;Insight_Source.dbo.MLA_Profile.PractEOTABNLTAGracePeriod  AS PractEOTABNLTAGracePeriod, &#xA;Insight_Source.dbo.MLA_Profile.PractOTPGracePeriod AS PractOTPGracePeriod, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractOTPFrequencyID = 1 THEN 'Monthly' WHEN Insight_Source.dbo.MLA_Profile.PractOTPFrequencyID = 2 THEN 'Quarterly' WHEN Insight_Source.dbo.MLA_Profile.PractOTPFrequencyID = 3 THEN 'HalfYearly' WHEN Insight_Source.dbo.MLA_Profile.PractOTPFrequencyID = 4 THEN 'Yearly' WHEN Insight_Source.dbo.MLA_Profile.PractOTPFrequencyID = 5 THEN '_' END ) AS PractOTPFrequency, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractSecondReductionPeriod AS nvarchar(20)),0) AS PractSecondReductionMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractSecondReductionPercent AS Decimal(5,2)),0) AS PractSecondReductionPercent  , &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.PractSoftcostOTPTreatmentID = 1 THEN 'No' WHEN Insight_Source.dbo.MLA_Profile.PractSoftcostOTPTreatmentID = 2 THEN 'YesDropallEXCEPTSOFTWARE' WHEN Insight_Source.dbo.MLA_Profile.PractSoftcostOTPTreatmentID = 3 THEN 'YesDropAll' WHEN Insight_Source.dbo.MLA_Profile.PractSoftcostOTPTreatmentID = 4 THEN 'No' ELSE 'No' END ) AS PractSoftCostOTPTreatment  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractThirdReductionPeriod AS nvarchar(20)),0) AS PractThirdReductionMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractThirdReductionPercent AS Decimal(5,2)),0) AS PractThirdReductionPercent  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsTitleTransfer AS bit),0) AS PractTitleTransfer  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractTitleTransferPeriod AS nvarchar(20)),0) AS PractTitleTransferMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.TitleTransferPeriod AS nvarchar(20)),0) AS TitleTransferMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractTransitionDays AS BigInt),0) AS PractTransitionDays  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.PractIsTransitionLease AS bit),0) AS PractTransitionLease   , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.SecondReductionPeriod AS nvarchar(20)),0) AS SecondReductionMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.SecondReductionPercent AS Decimal(5,2)),0) AS SecondReductionPercent  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.SecondReminderNoticeDays AS BigInt),0) AS SecondReminderNoticeDays, &#xA;(CASE  WHEN Insight_Source.dbo.MLA_Profile.SoftcostOTPTreatmentID = 1 THEN 'No' WHEN Insight_Source.dbo.MLA_Profile.SoftcostOTPTreatmentID = 2 THEN 'YesDropallEXCEPTSOFTWARE' WHEN Insight_Source.dbo.MLA_Profile.SoftcostOTPTreatmentID = 3 THEN 'YesDropAll' WHEN Insight_Source.dbo.MLA_Profile.SoftcostOTPTreatmentID = 4 THEN 'No' ELSE 'No' END ) AS SoftCostOTPTreatment  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsSpecialEarlyTermProvisions AS bit),0) AS SpecialEarlyTermProvisions, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsSpecialEOTProvision AS bit),0) AS SpecialEOTProvisionsAndRestrictions, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.ThirdReductionPeriod AS nvarchar(20)),0) AS ThirdReductionMonth, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.ThirdReductionPercent AS Decimal(5,2)),0) AS ThirdReductionPercent  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.ThirdReminderNoticeDays AS BigInt),0) AS ThirdReminderNoticeDays, &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsTitleTransfer AS bit),0) AS TitleTransfer  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.TransitionDays AS BigInt),0) AS TransitionDays  , &#xA;ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsTransitionLease AS bit),0) AS TransitionLease  ,  &#xA; Case When Insight_Source.dbo.MLA_Profile.IsActive=1 Then 'Active' else 'Inactive' end as Status,&#xA;ISNULL(CAST(Insight_Source.dbo.Customer_Profile.AccountNumber AS nvarchar(20)),0) AS PartyNumber, &#xA;&#xA; Insight_Source.dbo.MLA_Profile.DeActivationDate&#xA; --ISNULL(CAST(Insight_Source.dbo.MLA_Profile.IsFMVCap AS bit),0) AS IsFMVCap  , &#xA;--ISNULL(CAST(Insight_Source.dbo.MLA_Profile.FMVCapDetails AS nvarchar(400)),'') AS FMVCapDetails &#xA;Into ##MasterAgreementSource&#xA;FROM Insight_Source.dbo.MLA_Profile&#xA; INNER JOIN Insight_Source.dbo.Customer_Profile ON Insight_Source.dbo.MLA_Profile.CustomerId = Insight_Source.dbo.Customer_Profile.CustomerId&#xA; inner JOIN Insight_Source.dbo.Template_MLAType_Cnfg Template_MLAType_CnfgMasterAgreement  ON Insight_Source.dbo.MLA_Profile.MLATypeId = Template_MLAType_CnfgMasterAgreement.MLATypeId AND Template_MLAType_CnfgMasterAgreement.IsActive=1&#xA; WHERE   Insight_Source.dbo.Customer_Profile.CustomerStatusID=1&#xA; ORDER BY Insight_Source.dbo.MLA_Profile.MLAID&#xA;&#xA;&#xA;&#xA; select &#xA;ActivationDate&#xA;,MLAName&#xA;,AgreementDate&#xA;,AgreementTypeId&#xA;,LegalEntityId&#xA;,EOTOptionEarlyTermProvisionsDetails&#xA;,EOTOptionEOTPAndRDetails&#xA;,EOTOptionFollowUpLeadDays&#xA;,EOTOptionLessorNoticeDays&#xA;,EOTOptionMaxNoticePeriod&#xA;,EOTOptionMinNoticePeriod&#xA;,EOTOptionOTPFrequency&#xA;,EOTOptionOTPLesseeNoticePeriod &#xA;,ISNULL(FirstReductionMonth,0) as FirstReductionMonth&#xA;,FirstReductionPercent&#xA;,FirstReminderNoticeDays&#xA;,FreightResponsibility&#xA;,Frequency&#xA; ,Id&#xA;,InterimAcceptanceDays&#xA;,IsAdvance&#xA;,IsEOTOptionDelayedInvoicing&#xA;,IsEOTOptionOTPAdvancePayment&#xA;,IsEOTOptionOTPAllowed&#xA;,IsEOTOptionSpecialEarlyTermProvisions&#xA;,IsEOTOptionSpecialEOTProvisionsAndRestrictions&#xA;,InterimBillingApplies&#xA;,RecertificationRequired&#xA;,DataSecurityRequired&#xA;,DecontaminationRequired&#xA;,IsPractDelayedInvoicing&#xA;,IsPractOTPAdvancePayment&#xA;,IsPractOTPAllowed&#xA;,IsPractSpecialEarlyTermProvisions&#xA;,IsPractSpecialEOTProvisionsAndRestrictions&#xA;,PractSuspendOTPBilling&#xA;,PractRecertificationRequired&#xA;,PractDataSecurityRequired&#xA;,PractDecontaminationRequired&#xA;,SuspendOTPBilling&#xA;,GracePeriodDescription&#xA;,PractGracePeriodDescription&#xA;,LeadDays &#xA;,LKEAllowed&#xA;,NonStandard&#xA;,ClientMLANumber&#xA;,OtherStructure&#xA;,OtherStructureDescription&#xA;,PractEarlyTermProvisionsDetails&#xA;,PractEOTPAndRDetails&#xA;,ISNULL(PractFirstReductionMonth,0) as PractFirstReductionMonth&#xA;,PractFirstReductionPercent&#xA;,PractFollowUpLeadDays&#xA;,PractFreightResponsibility&#xA;,PractLessorNoticeDays&#xA;,PractLKEAllowed&#xA;,PractMaxNoticePeriod&#xA;,PractMinNoticePeriod&#xA;,PractNonStandard&#xA;,PractOtherStructure&#xA;,PractOtherStructureDescription&#xA;,PractOTPFrequency&#xA;,PractOTPLesseeNoticePeriod&#xA;,ISNULL(PractSecondReductionMonth,0) as PractSecondReductionMonth&#xA;,PractSecondReductionPercent&#xA;,PractSoftCostOTPTreatment&#xA;,ISNULL(PractThirdReductionMonth,0) as PractThirdReductionMonth&#xA;,PractThirdReductionPercent&#xA;,PractTitleTransfer&#xA;,PractTitleTransferMonth&#xA;,TitleTransferMonth&#xA;,PractTransitionDays&#xA;,PractTransitionLease&#xA;,ISNULL(SecondReductionMonth,0) as SecondReductionMonth&#xA;,SecondReductionPercent&#xA;,SecondReminderNoticeDays&#xA;,SoftCostOTPTreatment &#xA;,ISNULL(ThirdReductionMonth,0) as ThirdReductionMonth&#xA;,ThirdReductionPercent&#xA;,ThirdReminderNoticeDays&#xA;,TitleTransfer&#xA;,TransitionDays&#xA;,TransitionLease&#xA;,IsPractLesseeFirmTermNotice&#xA;,IsEOTOptionLesseeFirmTermNotice&#xA;,Status&#xA;,DeActivationDate&#xA; Into ##MasterAgreementTarget &#xA;from Insight_UAT..masteragreements &#xA; &#xA; select &#xA;Source.Number S_Number&#xA;,Target.ClientMLANumber T_Number&#xA;,CASE WHEN ISNULL(Source.Number,0) &lt;&gt; ISNULL(Target.ClientMLANumber,0) THEN 'FALSE' ELSE 'TRUE' END Number_Matched&#xA;&#xA;,Source.MLaName S_MLaName&#xA;,Target.MLaName T_MLaName&#xA;,CASE WHEN ISNULL(Source.MLaName,0) &lt;&gt; ISNULL(Target.MLaName,0) THEN 'FALSE' ELSE 'TRUE' END MLaName_Matched&#xA;&#xA;,Source.AgreementDate S_AgreementDate&#xA;,Target.AgreementDate T_AgreementDate&#xA;,CASE WHEN ISNULL(Source.AgreementDate,getdate()) &lt;&gt; ISNULL(Target.AgreementDate,getdate()) THEN 'FALSE' ELSE 'TRUE' END Agreeme