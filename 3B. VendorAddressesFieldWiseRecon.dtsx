  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\3B VendorAddressesFieldWiseRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{CADE8DB0-76D1-40DC-A2C3-C742AADE371C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="3B VendorAddressesFieldWiseRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 VendorAddressRecon&#xA;&#xA;DROP TABLE IF EXISTS ##VendorAddressSource&#xA;DROP TABLE IF EXISTS ##VendorAddressTarget&#xA;DROP TABLE IF EXISTS ##VendorAddress&#xA;DROP TABLE IF EXISTS VendorAddressRecon&#xA;SELECT&#xA;  vp.VendorAlias 'PartyNumber',&#xA;  ca.ContactAddressId 'UniqueIdentifier',&#xA;  ca.Address 'AddressLine1',&#xA;  CASE&#xA;    WHEN ISNULL(ca.Address2, '') = '' THEN NULL&#xA;    ELSE ca.Address2&#xA;  &#xA;END&#xA; AS 'AddressLine2',&#xA;  ca.City,&#xA;  CASE&#xA;    WHEN ISNULL(ca.County, '') = '' THEN NULL&#xA;    ELSE ca.County&#xA;  &#xA;END&#xA; AS 'County',&#xA;  CASE&#xA;    WHEN ISNULL(ca.ZIP, '') = '' THEN NULL&#xA;    ELSE ca.ZIP&#xA;  &#xA;END&#xA; AS PostalCode,&#xA;  CASE&#xA;    WHEN ISNULL(ca.Description, '') = '' THEN NULL&#xA;    ELSE ca.Description&#xA;  &#xA;END&#xA; AS 'Description',&#xA;  ca.IsMainAddress 'IsMain',&#xA; (&#xA;  CASE WHEN SSCM.StateID IS NOT NULL THEN SSCM.LW5StateShortName&#xA;&#x9;&#x9;ELSE StateShortName&#xA;END&#xA;  )&#xA; AS State,&#xA;  (&#xA;    Ca.CountryShortCode&#xA;    &#xA;  ) AS Country,&#xA;  ca.IsForDocumentation,&#xA;  ca.EntityId 'PartyId'&#xA;INTO&#xA;  ##VendorAddressSource&#xA;FROM&#xA;  Insight_Source..ContactAddressView ca&#xA;  INNER JOIN Insight_Source..Contact_Address c ON ca.ContactAddressID = c.ContactAddressID&#xA;  INNER JOIN Insight_Source..Vendor_Profile vp ON vp.VendorId = c.EntityID&#xA;  AND vp.VendorStatusID not IN (4)&#xA;  LEFT JOIN Migration_Intermediate.dbo.StatesShortCodeMapping SSCM on SSCM.StateID = ca.StateID&#xA;WHERE&#xA;  ca.EntityTypeID = 8&#xA;  AND c.IsActive = 1&#xA;SELECT&#xA;  p.PartyNumber,&#xA;  pa.UniqueIdentifier,&#xA;  pa.AddressLine1,&#xA;  CASE&#xA;    WHEN ISNULL(pa.AddressLine2, '') = '' THEN NULL&#xA;    ELSE pa.AddressLine2&#xA;  &#xA;END&#xA; AS 'AddressLine2',&#xA;  pa.City,&#xA;  CASE&#xA;    WHEN ISNULL(pa.Division, '') = '' THEN NULL&#xA;    ELSE pa.Division&#xA;  &#xA;END&#xA; AS 'County',&#xA;  pa.PostalCode,&#xA;  CASE&#xA;    WHEN ISNULL(pa.Description, '') = '' THEN NULL&#xA;    ELSE pa.Description&#xA;  &#xA;END&#xA; AS 'Description',&#xA;  pa.IsMain,&#xA;  s.ShortName AS State,&#xA;  c.ShortName AS Country,&#xA;  pa.IsForDocumentation,&#xA;  pa.PartyId&#xA;INTO&#xA;  ##VendorAddressTarget&#xA;FROM&#xA;  Insight_UAT..Partyaddresses pa&#xA;  INNER JOIN Insight_UAT..Parties p ON pa.PartyId = p.Id&#xA;  INNER JOIN Insight_UAT..Vendors v ON v.Id = p.Id&#xA;  AND p.PortfolioId = 1&#xA;  INNER JOIN Insight_UAT..States s ON s.Id = pa.StateId&#xA;  INNER JOIN Insight_UAT..Countries c on c.id = s.countryid&#xA;  LEFT JOIN Insight_UAT..Customers   on Customers.ID = P.ID&#xA;  Where Customers.ID is NULL&#xA;&#xA;SELECT Distinct&#xA;  source.PartyNumber AS 'S_PartyNumber',&#xA;  target.PartyNumber AS 'T_PartyNumber',&#xA;  CASE&#xA;    WHEN (&#xA;      ISNULL(Source.partynumber, 0) = ISNULL(Target.partynumber, 0)&#xA;      OR (&#xA;        ISNULL(concat(Source.PartyNumber, '_V'), 0) = ISNULL(Target.PartyNumber, 0)&#xA;      )&#xA;    ) THEN 'TRUE'&#xA;    ELSE 'FALSE'&#xA;  &#xA;END&#xA; partynumber_Matched,&#xA;  source.UniqueIdentifier AS 'S_UniqueIdentifier',&#xA;  target.UniqueIdentifier AS 'T_UniqueIdentifier',&#xA;  CASE&#xA;    WHEN ISNULL(Source.UniqueIdentifier, 0) &lt;&gt; ISNULL(Target.UniqueIdentifier, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; UniqueIdentifier_Matched,&#xA;  source.AddressLine1 AS 'S_AddressLine1',&#xA;  target.AddressLine1 AS 'T_AddressLine1',&#xA;  CASE&#xA;    WHEN ISNULL(Source.AddressLine1, 0) &lt;&gt; ISNULL(Target.AddressLine1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AddressLine1_Matched,&#xA;  source.AddressLine2 AS 'S_AddressLine2',&#xA;  target.AddressLine2 AS 'T_AddressLine2',&#xA;  CASE&#xA;    WHEN ISNULL(Source.AddressLine2, 0) &lt;&gt; ISNULL(Target.AddressLine2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AddressLine2_Matched,&#xA;  source.City AS 'S_City',&#xA;  target.City AS 'T_City',&#xA;  CASE&#xA;    WHEN ISNULL(Source.City, 0) &lt;&gt; ISNULL(Target.City, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; City_Matched,&#xA;  source.County AS 'S_County',&#xA;  target.County AS 'T_County',&#xA;  CASE&#xA;    WHEN ISNULL(Source.County, 0) &lt;&gt; ISNULL(Target.County, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; County,&#xA;  source.PostalCode AS 'S_PostalCode',&#xA;  target.PostalCode AS 'T_PostalCode',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PostalCode, 0) &lt;&gt; ISNULL(Target.PostalCode, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PostalCode_Matched,&#xA;  source.Description AS 'S_Description',&#xA;  target.Description AS 'T_Description',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Description, 0) &lt;&gt; ISNULL(Target.Description, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Description_Matched,&#xA;  source.IsMain AS 'S_IsMain',&#xA;  target.IsMain AS 'T_IsMain',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsMain, 0) &lt;&gt; ISNULL(Target.IsMain, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsMain_Matched,&#xA;  source.State AS 'S_State',&#xA;  target.State AS 'T_State',&#xA;  CASE&#xA;    WHEN ISNULL(Source.State, 0) &lt;&gt; ISNULL(Target.State, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; State_Matched,&#xA;  source.Country AS 'S_Country',&#xA;  target.Country AS 'T_Country',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Country, 0) &lt;&gt; ISNULL(Target.Country, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Country_Matched,&#xA;  source.IsForDocumentation AS 'S_IsForDocumentation',&#xA;  target.IsForDocumentation AS 'T_IsForDocumentation',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsForDocumentation, 0) &lt;&gt; ISNULL(Target.IsForDocumentation, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsForDocumentation_Matched&#xA;into&#xA;  ##VendorAddress&#xA;FROM&#xA;  ##VendorAddressSource source&#xA;  INNER JOIN ##VendorAddressTarget target ON (&#xA;    Source.partynumber = Target.partynumber&#xA;    OR concat(Source.partynumber, '_V') = Target.partynumber&#xA;  )&#xA;  AND source.UniqueIdentifier = target.UniqueIdentifier&#xA;  --AND source.FirstName= target.FirstName&#xA;  --AND source.LastName= target.LastName&#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE VendorAddressRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##VendorAddress'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_ExecuteSql @CreateTableScript&#xA;&#xA;--  3B. VendorAddressesFieldWiseRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.VendorAddressRecon&#xA;&#xA;--INSERT INTO&#xA;--  VendorAddressRecon&#xA;&#xA;SELECT 'VendorAddressRecon' Recon,*&#xA;INTO V5_Recon.dbo.VendorAddressRecon&#xA;FROM ##VendorAddress&#xA;&#xA;  --SELECT * FROM VendorAddressRecon&#xA;SELECT * &#xA;FROM V5_Recon.dbo.VendorAddressRecon&#xA;&#xA;DROP TABLE IF EXISTS ##VendorAddressSource&#xA;DROP TABLE IF EXISTS ##VendorAddressTarget&#xA;DROP TABLE IF EXISTS ##VendorAddress&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
