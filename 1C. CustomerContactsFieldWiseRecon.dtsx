  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\1C CustomerContactsFieldWiseRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B7581F0B-A224-4654-B5C9-AB55EAF0BA09}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="1C CustomerContactsFieldWiseRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 CustomerContactRecon&#xA;&#xA;DROP TABLE IF EXISTS ##CustomerContactSource&#xA;DROP TABLE IF EXISTS ##CustomerContactTarget&#xA;DROP TABLE IF EXISTS ##CustomerContact&#xA;DROP TABLE IF EXISTS CustomerContactRecon&#xA;--Source&#xA;SELECT&#xA;  Customer_Profile.AccountNumber 'PartyNumber',&#xA;  Contact_PersonCustomerContact.Prefix,&#xA;  Contact_PersonCustomerContact.FirstName,&#xA;  Contact_PersonCustomerContact.MiddleName,&#xA;  CASE&#xA;    WHEN ISNULL(&#xA;      (&#xA;        CAST(&#xA;          Contact_PersonCustomerContact.LastName AS NVARCHAR(40)&#xA;        )&#xA;      ),&#xA;      ''&#xA;    ) = '' THEN NULL&#xA;    ELSE (&#xA;      CAST(&#xA;        Contact_PersonCustomerContact.LastName AS NVARCHAR(40)&#xA;      )&#xA;    )&#xA;  &#xA;END&#xA; AS LastName,&#xA;  CASE&#xA;    WHEN len(Contact_PersonCustomerContact.Phonenumber1) IN (14, 11) THEN RIGHT(&#xA;      STUFF(&#xA;        CAST(&#xA;          Contact_PersonCustomerContact.Phonenumber1 AS NVARCHAR(15)&#xA;        ),&#xA;        5,&#xA;        2,&#xA;        '-'&#xA;      ),&#xA;      CASE&#xA;        WHEN len(Contact_PersonCustomerContact.Phonenumber1) = 11 THEN 9&#xA;        ELSE 12&#xA;      &#xA;END&#xA;&#xA;    )&#xA;    WHEN CHARINDEX('-', Contact_PersonCustomerContact.Phonenumber1) = 0 THEN RIGHT(&#xA;      STUFF(&#xA;        STUFF(&#xA;          CAST(&#xA;            Contact_PersonCustomerContact.Phonenumber1 AS NVARCHAR(15)&#xA;          ),&#xA;          4,&#xA;          0,&#xA;          '-'&#xA;        ),&#xA;        8,&#xA;        0,&#xA;        '-'&#xA;      ),&#xA;      12&#xA;    )&#xA;    ELSE Contact_PersonCustomerContact.Phonenumber1&#xA;  &#xA;END&#xA; AS PhoneNumber1,&#xA;  Contact_PersonCustomerContact.ExtensionNumber1,&#xA;  (&#xA;    CAST(&#xA;      (&#xA;        CASE&#xA;          WHEN Contact_PersonCustomerContact.PhoneNumber2 = '' THEN NULL&#xA;          ELSE RIGHT(&#xA;            STUFF(&#xA;              CAST(&#xA;                Contact_PersonCustomerContact.PhoneNumber2 AS NVARCHAR(15)&#xA;              ),&#xA;              5,&#xA;              2,&#xA;              '-'&#xA;            ),&#xA;            12&#xA;          )&#xA;        &#xA;END&#xA;&#xA;      ) AS NVARCHAR(15)&#xA;    )&#xA;  ) AS PhoneNumber2,&#xA;  Contact_PersonCustomerContact.ExtensionNumber2,&#xA;  (&#xA;    CAST(&#xA;      (&#xA;        CASE&#xA;          WHEN Contact_PersonCustomerContact.CellPhoneNumber = '' THEN NULL&#xA;          ELSE RIGHT(&#xA;            STUFF(&#xA;              CAST(&#xA;                Contact_PersonCustomerContact.CellPhoneNumber AS NVARCHAR(15)&#xA;              ),&#xA;              5,&#xA;              2,&#xA;              '-'&#xA;            ),&#xA;            12&#xA;          )&#xA;        &#xA;END&#xA;&#xA;      ) AS NVARCHAR(15)&#xA;    )&#xA;  ) AS MobilePhoneNumber,&#xA;  IIF(Contact_PersonCustomerContact.FaxNumber='',NULL,REPLACE(Contact_PersonCustomerContact.FaxNumber, ' ', '')) AS FaxNumber,&#xA;  Contact_PersonCustomerContact.EmailId,&#xA;  Contact_PersonCustomerContact.Description,&#xA;  Contact_EntityPersonRelation.ContactPersonId AS 'UniqueIdentifier',&#xA;  Customer_Profile.CustomerID 'Id'&#xA;INTO&#xA;  ##CustomerContactSource&#xA;FROM&#xA;  Insight_Source.dbo.Contact_EntityPersonRelation&#xA;  INNER JOIN Insight_Source.dbo.Customer_Profile Customer_Profile ON Insight_Source.dbo.Contact_EntityPersonRelation.EntityId = Customer_Profile.CustomerId&#xA;  INNER JOIN Insight_Source.dbo.Contact_Person Contact_PersonCustomerContact ON Insight_Source.dbo.Contact_EntityPersonRelation.ContactPersonId = Contact_PersonCustomerContact.ContactPersonId&#xA;WHERE&#xA;  Insight_Source.dbo.Contact_EntityPersonRelation.EntityTypeId = 1&#xA;  AND Insight_Source.dbo.Contact_EntityPersonRelation.IsActive = 1&#xA;  AND Customer_Profile.CustomerStatusID = 1&#xA;ORDER BY&#xA;  Insight_Source.dbo.Contact_EntityPersonRelation.EntityId&#xA;  --Target&#xA;SELECT&#xA;  p.PartyNumber,&#xA;  pc.Prefix,&#xA;  pc.FirstName,&#xA;  pc.MiddleName,&#xA;  pc.LastName,&#xA;  replace(pc.PhoneNumber1, '+1-', '') AS PhoneNumber1,&#xA;  pc.ExtensionNumber1,&#xA;  replace(pc.PhoneNumber2, '+1-', '') AS PhoneNumber2,&#xA;  pc.ExtensionNumber2,&#xA;  replace(pc.MobilePhoneNumber, '+1-', '') AS MobilePhoneNumber,&#xA;  replace(pc.FaxNumber, '+1-', '') AS FaxNumber,&#xA;  pc.EmailId,&#xA;  pc.Description,&#xA;  pc.UNIQUEIDENTIFIER 'UniqueIdentifier'&#xA;INTO&#xA;  ##CustomerContactTarget&#xA;FROM&#xA;  Insight_UAT..Partycontacts pc&#xA;  INNER JOIN Insight_UAT..Parties p ON pc.partyid = p.id&#xA;  AND p.Portfolioid = 1&#xA;  INNER JOIN Insight_UAT..Customers c ON c.id = p.id&#xA;  --Recon&#xA;SELECT DISTINCT&#xA;  source.PartyNumber AS 'S_PartyNumber',&#xA;  target.PartyNumber AS 'T_PartyNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PartyNumber, 0) &lt;&gt; ISNULL(Target.PartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  source.Prefix AS 'S_Prefix',&#xA;  target.Prefix AS 'T_Prefix',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Prefix, 0) &lt;&gt; ISNULL(Target.Prefix, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Prefix_Matched,&#xA;  source.FirstName AS 'S_FirstName',&#xA;  target.FirstName AS 'T_FirstName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.FirstName, 0) &lt;&gt; ISNULL(Target.FirstName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; FirstName_Matched,&#xA;  source.MiddleName AS 'S_MiddleName',&#xA;  target.MiddleName AS 'T_MiddleName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.MiddleName, 0) &lt;&gt; ISNULL(Target.MiddleName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; MiddleName_Matched,&#xA;  source.LastName AS 'S_LastName',&#xA;  target.LastName AS 'T_LastName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.LastName, 0) &lt;&gt; ISNULL(Target.LastName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LastName_Matched,&#xA;  source.PhoneNumber1 AS 'S_PhoneNumber1',&#xA;  target.PhoneNumber1 AS 'T_PhoneNumber1',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PhoneNumber1, 0) &lt;&gt; ISNULL(Target.PhoneNumber1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PhoneNumber1_Matched,&#xA;  source.ExtensionNumber1 AS 'S_ExtensionNumber1',&#xA;  target.ExtensionNumber1 AS 'T_ExtensionNumber1',&#xA;  CASE&#xA;    WHEN ISNULL(Source.ExtensionNumber1, 0) &lt;&gt; ISNULL(Target.ExtensionNumber1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ExtensionNumber1_Matched,&#xA;  source.PhoneNumber2 AS 'S_PhoneNumber2',&#xA;  target.PhoneNumber2 AS 'T_PhoneNumber2',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PhoneNumber2, 0) &lt;&gt; ISNULL(Target.PhoneNumber2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PhoneNumber2_Matched,&#xA;  source.ExtensionNumber2 AS 'S_ExtensionNumber2',&#xA;  target.ExtensionNumber2 AS 'T_ExtensionNumber2',&#xA;  CASE&#xA;    WHEN ISNULL(Source.ExtensionNumber2, 0) &lt;&gt; ISNULL(Target.ExtensionNumber2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ExtensionNumber2_Matched,&#xA;  source.MobilePhoneNumber AS 'S_MobilePhoneNumber',&#xA;  target.MobilePhoneNumber AS 'T_MobilePhoneNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.MobilePhoneNumber, 0) &lt;&gt; ISNULL(Target.MobilePhoneNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; MobilePhoneNumber_Matched,&#xA;  source.FaxNumber AS 'S_FaxNumber',&#xA;  target.FaxNumber AS 'T_FaxNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.FaxNumber, 0) &lt;&gt; ISNULL(Target.FaxNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; FaxNumber_Matched,&#xA;  source.EmailId AS 'S_EmailId',&#xA;  target.EmailId AS 'T_EmailId',&#xA;  CASE&#xA;    WHEN ISNULL(Source.EmailId, 0) &lt;&gt; ISNULL(Target.EmailId, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; EmailId_Matched,&#xA;  source.Description AS 'S_Description',&#xA;  target.Description AS 'T_Description',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Description, 0) &lt;&gt; ISNULL(Target.Description, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Description_Matched,&#xA;  source.UNIQUEIDENTIFIER AS 'S_UniqueIdentifier',&#xA;  target.UNIQUEIDENTIFIER AS 'T_UniqueIdentifier',&#xA;  CASE&#xA;    WHEN ISNULL(Source.UNIQUEIDENTIFIER, 0) &lt;&gt; ISNULL(Target.UNIQUEIDENTIFIER, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; UniqueIdentifier_Matched&#xA;INTO&#xA;  ##CustomerContact&#xA;FROM&#xA;  ##CustomerContactSource source&#xA;  INNER JOIN ##CustomerContactTarget target ON source.UNIQUEIDENTIFIER = target.UNIQUEIDENTIFIER&#xA;  &#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE CustomerContactRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##CustomerContact'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_Executesql @CreateTableScript&#xA;&#xA;-- 1C. CustomerContactsFieldWiseRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.CustomerContactRecon&#xA;&#xA;--INSERT INTO&#xA;--  CustomerContactRecon&#xA;&#xA;SELECT 'CustomerContactRecon' Recon, *&#xA;INTO V5_Recon.dbo.CustomerContactRecon&#xA;FROM ##CustomerContact&#xA;&#xA;--SELECT * FROM CustomerContactRecon&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.CustomerContactRecon&#xA;&#xA;DROP TABLE IF EXISTS ##CustomerContactSource&#xA;DROP TABLE IF EXISTS ##CustomerContactTarget&#xA;DROP TABLE IF EXISTS ##CustomerContact&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
