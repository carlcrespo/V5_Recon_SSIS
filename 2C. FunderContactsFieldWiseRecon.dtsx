      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 FunderContactRecon&#xA;&#xA;DROP TABLE IF EXISTS ##FunderContactSource&#xA;DROP TABLE IF EXISTS ##FunderContactTarget&#xA;DROP TABLE IF EXISTS ##FunderContact&#xA;DROP TABLE IF EXISTS FunderContactRecon&#xA;SELECT&#xA;  fp.FundingSourceNumber 'PartyNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Contact_PersonFunderContact.Prefix, '') = '' THEN NULL&#xA;    ELSE Contact_PersonFunderContact.Prefix&#xA;  &#xA;END&#xA; AS Prefix,&#xA;  Contact_PersonFunderContact.FirstName,&#xA;  CASE&#xA;    WHEN ISNULL(Contact_PersonFunderContact.MiddleName, '') = '' THEN NULL&#xA;    ELSE Contact_PersonFunderContact.MiddleName&#xA;  &#xA;END&#xA; AS MiddleName,&#xA;  CASE&#xA;    WHEN ISNULL(&#xA;      (&#xA;        CAST(&#xA;          Contact_PersonFunderContact.LastName AS nvarchar(40)&#xA;        )&#xA;      ),&#xA;      ''&#xA;    ) = '' THEN NULL&#xA;    ELSE (&#xA;      CAST(&#xA;        Contact_PersonFunderContact.LastName AS nvarchar(40)&#xA;      )&#xA;    )&#xA;  &#xA;END&#xA; AS LastName,&#xA;  (&#xA;    CASE&#xA;      WHEN Contact_PersonFunderContact.PhoneNumber1 = '' THEN NULL&#xA;      ELSE RIGHT(&#xA;        STUFF(&#xA;          CAST(&#xA;            Contact_PersonFunderContact.PhoneNumber1 AS nvarchar(15)&#xA;          ),&#xA;          5,&#xA;          2,&#xA;          '-'&#xA;        ),&#xA;        12&#xA;      )&#xA;    &#xA;END&#xA;&#xA;  ) AS PhoneNumber1,&#xA;  CASE&#xA;    WHEN Contact_PersonFunderContact.ExtensionNumber1 IN ('', '`') THEN NULL&#xA;    ELSE Contact_PersonFunderContact.ExtensionNumber1&#xA;  &#xA;END&#xA; AS ExtensionNumber1,&#xA;  (&#xA;    CASE&#xA;      WHEN Contact_PersonFunderContact.PhoneNumber2 = '' THEN NULL&#xA;      ELSE RIGHT(&#xA;        STUFF(&#xA;          CAST(&#xA;            Contact_PersonFunderContact.PhoneNumber2 AS nvarchar(15)&#xA;          ),&#xA;          5,&#xA;          2,&#xA;          '-'&#xA;        ),&#xA;        12&#xA;      )&#xA;    &#xA;END&#xA;&#xA;  ) AS PhoneNumber2,&#xA;  CASE&#xA;    WHEN ISNULL(Contact_PersonFunderContact.ExtensionNumber2, '') = '' THEN NULL&#xA;    ELSE Contact_PersonFunderContact.ExtensionNumber2&#xA;  &#xA;END&#xA; AS ExtensionNumber2,&#xA;  (&#xA;    CASE&#xA;      WHEN Contact_PersonFunderContact.CellPhoneNumber = '' THEN NULL&#xA;      ELSE RIGHT(&#xA;        STUFF(&#xA;          CAST(&#xA;            Contact_PersonFunderContact.CellPhoneNumber AS nvarchar(15)&#xA;          ),&#xA;          5,&#xA;          2,&#xA;          '-'&#xA;        ),&#xA;        12&#xA;      )&#xA;    &#xA;END&#xA;&#xA;  ) AS MobilePhoneNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Contact_PersonFunderContact.FaxNumber, '') = '' THEN NULL&#xA;    ELSE REPLACE(Contact_PersonFunderContact.FaxNumber, ' ', '')&#xA;  &#xA;END&#xA; AS FaxNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Contact_PersonFunderContact.EmailID, '') = '' THEN NULL&#xA;    ELSE Contact_PersonFunderContact.EmailID&#xA;  &#xA;END&#xA; AS EmailID,&#xA;  CASE&#xA;    WHEN ISNULL(Contact_PersonFunderContact.Description, '') = '' THEN NULL&#xA;    ELSE Contact_PersonFunderContact.Description&#xA;  &#xA;END&#xA; AS Description,&#xA;  Contact_EntityPersonRelation.ContactRelationId 'UniqueIdentifier'&#xA;INTO&#xA;  ##FunderContactSource&#xA;FROM&#xA;  Insight_Source.dbo.Contact_EntityPersonRelation&#xA;  INNER JOIN Insight_Source.dbo.FundingSource_Profile fp ON Insight_Source.dbo.Contact_EntityPersonRelation.EntityId = fp.FundingSourceId&#xA;  INNER JOIN Insight_Source.dbo.Contact_Person Contact_PersonFunderContact ON Insight_Source.dbo.Contact_EntityPersonRelation.ContactPersonId = Contact_PersonFunderContact.ContactPersonId&#xA;WHERE&#xA;  Insight_Source.dbo.Contact_EntityPersonRelation.EntityTypeId = 3&#xA;  AND Insight_Source.dbo.Contact_EntityPersonRelation.IsActive = 1&#xA;  AND fp.StatusId = 2&#xA;ORDER BY&#xA;  Insight_Source.dbo.Contact_EntityPersonRelation.EntityId&#xA;SELECT&#xA;  p.PartyNumber,&#xA;  pc.Prefix,&#xA;  pc.FirstName,&#xA;  pc.MiddleName,&#xA;  pc.LastName,&#xA;  CASE&#xA;    WHEN pc.PhoneNumber1 = '' THEN NULL&#xA;    ELSE Replace(pc.PhoneNumber1, '+1-', '')&#xA;  &#xA;END&#xA; AS PhoneNumber1,&#xA;  CASE&#xA;    WHEN pc.ExtensionNumber1 = '' THEN NULL&#xA;    ELSE pc.ExtensionNumber1&#xA;  &#xA;END&#xA; AS ExtensionNumber1,&#xA;  CASE&#xA;    WHEN pc.PhoneNumber2 = '' THEN NULL&#xA;    ELSE Replace(pc.PhoneNumber2, '+1-', '')&#xA;  &#xA;END&#xA; AS PhoneNumber2,&#xA;  pc.ExtensionNumber2,&#xA;  CASE&#xA;    WHEN pc.MobilePhoneNumber = '' THEN NULL&#xA;    ELSE Replace(pc.MobilePhoneNumber, '+1-', '')&#xA;  &#xA;END&#xA; AS MobilePhoneNumber,&#xA;  pc.FaxNumber,&#xA;  pc.EmailId,&#xA;  pc.Description,&#xA;  pc.UniqueIdentifier 'UniqueIdentifier'&#xA;INTO&#xA;  ##FunderContactTarget&#xA;FROM&#xA;  Insight_UAT..Partycontacts pc&#xA;  INNER JOIN Insight_UAT..Parties p ON pc.partyid = p.id&#xA;  AND p.portfolioid = 1&#xA;  INNER JOIN Insight_UAT..Funders f ON f.id = p.id&#xA;SELECT Distinct&#xA;  source.PartyNumber AS 'S_PartyNumber',&#xA;  target.PartyNumber AS 'T_PartyNumber',&#xA;  CASE&#xA;    WHEN (&#xA;      (&#xA;        ISNULL(Source.PartyNumber, 0) = ISNULL(Target.PartyNumber, 0)&#xA;      )&#xA;      OR (&#xA;        ISNULL(concat(Source.PartyNumber, '_F'), 0) = ISNULL(Target.PartyNumber, 0)&#xA;      )&#xA;    ) THEN 'TRUE'&#xA;    ELSE 'FALSE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  source.Prefix AS 'S_Prefix',&#xA;  target.Prefix AS 'T_Prefix',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Prefix, 0) &lt;&gt; ISNULL(Target.Prefix, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Prefix_Matched,&#xA;  source.FirstName AS 'S_FirstName',&#xA;  target.FirstName AS 'T_FirstName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.FirstName, 0) &lt;&gt; ISNULL(Target.FirstName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; FirstName_Matched,&#xA;  source.MiddleName AS 'S_MiddleName',&#xA;  target.MiddleName AS 'T_MiddleName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.MiddleName, 0) &lt;&gt; ISNULL(Target.MiddleName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; MiddleName_Matched,&#xA;  source.LastName AS 'S_LastName',&#xA;  target.LastName AS 'T_LastName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.LastName, 0) &lt;&gt; ISNULL(Target.LastName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LastName_Matched,&#xA;  source.PhoneNumber1 AS 'S_PhoneNumber1',&#xA;  target.PhoneNumber1 AS 'T_PhoneNumber1',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PhoneNumber1, 0) &lt;&gt; ISNULL(Target.PhoneNumber1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PhoneNumber1_Matched,&#xA;  source.ExtensionNumber1 AS 'S_ExtensionNumber1',&#xA;  target.ExtensionNumber1 AS 'T_ExtensionNumber1',&#xA;  CASE&#xA;    WHEN ISNULL(Source.ExtensionNumber1, 0) &lt;&gt; ISNULL(Target.ExtensionNumber1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ExtensionNumber1_Matched,&#xA;  source.PhoneNumber2 AS 'S_PhoneNumber2',&#xA;  target.PhoneNumber2 AS 'T_PhoneNumber2',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PhoneNumber2, 0) &lt;&gt; ISNULL(Target.PhoneNumber2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PhoneNumber2_Matched,&#xA;  source.ExtensionNumber2 AS 'S_ExtensionNumber2',&#xA;  target.ExtensionNumber2 AS 'T_ExtensionNumber2',&#xA;  CASE&#xA;    WHEN ISNULL(Source.ExtensionNumber2, 0) &lt;&gt; ISNULL(Target.ExtensionNumber2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ExtensionNumber2_Matched,&#xA;  source.MobilePhoneNumber AS 'S_MobilePhoneNumber',&#xA;  target.MobilePhoneNumber AS 'T_MobilePhoneNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.MobilePhoneNumber, 0) &lt;&gt; ISNULL(Target.MobilePhoneNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; MobilePhoneNumber_Matched,&#xA;  source.FaxNumber AS 'S_FaxNumber',&#xA;  target.FaxNumber AS 'T_FaxNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.FaxNumber, 0) &lt;&gt; ISNULL(Target.FaxNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; FaxNumber_Matched,&#xA;  source.EmailId AS 'S_EmailId',&#xA;  target.EmailId AS 'T_EmailId',&#xA;  CASE&#xA;    WHEN ISNULL(Source.EmailId, 0) &lt;&gt; ISNULL(Target.EmailId, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; EmailId_Matched,&#xA;  source.Description AS 'S_Description',&#xA;  target.Description AS 'T_Description',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Description, 0) &lt;&gt; ISNULL(Target.Description, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Description_Matched,&#xA;  source.UniqueIdentifier AS 'S_UniqueIdentifier',&#xA;  target.UniqueIdentifier AS 'T_UniqueIdentifier',&#xA;  CASE&#xA;    WHEN ISNULL(Source.UniqueIdentifier, 0) &lt;&gt; ISNULL(Target.UniqueIdentifier, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; UniqueIdentifier_Matched&#xA;into&#xA;  ##FunderContact&#xA;FROM&#xA;  ##FunderContactSource source&#xA;  INNER JOIN ##FunderContactTarget target on (&#xA;    source.PartyNumber = target.PartyNumber&#xA;    OR concat(source.Partynumber, '_F') = Target.PartyNumber&#xA;  )&#xA;  AND source.UniqueIdentifier = target.UniqueIdentifier&#xA;  --AND source.FirstName= target.FirstName&#xA;  --AND source.LastName= target.LastName&#xA;&#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE FunderContactRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##FunderContact'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_ExecuteSql @CreateTableScript&#xA;&#xA;-- 2C. FunderContactsFieldWiseRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.FunderContactRecon&#xA;&#xA;--INSERT INTO&#xA;--  FunderContactRecon&#xA;&#xA;SELECT 'FunderContactRecon' Recon,*&#xA;INTO V5_Recon.dbo.FunderContactRecon&#xA;FROM ##FunderContact&#xA;&#xA;  --SELECT * FROM FunderContactRecon&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.FunderContactRecon&#xA;&#xA;DROP TABLE IF EXISTS ##FunderContactSource&#xA;DROP TABLE IF EXISTS ##FunderContactTarget&#xA;DROP TABLE IF EXISTS ##FunderContact&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
