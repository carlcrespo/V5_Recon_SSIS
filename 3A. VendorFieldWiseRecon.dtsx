    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\3A VendorFieldWiseRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{B000B061-5B86-4C34-8AA8-6EB1BECCB28C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="3A VendorFieldWiseRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="--VendorFieldWiseRecon:&#xA;DROP TABLE IF EXISTS ##VendorSource&#xA;DROP TABLE IF EXISTS ##VendorTarget&#xA;DROP TABLE IF EXISTS ##Vendor&#xA;DROP TABLE IF EXISTS VendorRecon&#xA;-- Vendor Source&#xA;SELECT&#xA;  [VendorAlias] partynumber,&#xA;  [VendorCompanyName] PartyName,&#xA;  [CreatedOn] CreationDate,&#xA;  [SocialSecurityNumber] TaxId,&#xA;  [ActivatedOn] ActivationDate,&#xA;  VendorID,&#xA;  (&#xA;    CASE&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.Status1099ID = 1 THEN 'Nota1099Vendor'&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.Status1099ID = 2 THEN 'Dividend'&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.Status1099ID = 3 THEN 'Interest'&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.Status1099ID = 4 THEN 'Miscellaneous'&#xA;      ELSE 'Nota1099Vendor'&#xA;    &#xA;END&#xA;&#xA;  ) AS 'Status1099',&#xA;  VendorCompanyName,&#xA;  CASE&#xA;    WHEN ISNULL(DoingBusinessAs, '') = '' THEN NULL&#xA;    ELSE DoingBusinessAs&#xA;  &#xA;END&#xA; AS 'DoingBusinessAs',&#xA;  VendorTypeID AS 'Type',&#xA;  (&#xA;    CASE&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.VendorStatusId = 1 THEN 'Pending'&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.VendorStatusId = 2 THEN 'Active'&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.VendorStatusId = 3 THEN 'Active'&#xA;      WHEN Insight_Source.dbo.Vendor_Profile.VendorStatusId = 4 THEN 'Inactive'&#xA;      ELSE 'Active'&#xA;    &#xA;END&#xA;&#xA;  ) AS 'Status'&#xA;into&#xA;  ##VendorSource&#xA;FROM&#xA;  Insight_Source..Vendor_profile&#xA;WHERE&#xA;  VendorStatusid not IN (4)&#xA;ORDER BY&#xA;  [VendorNumber]&#xA;  -- Vendor Target&#xA;SELECT&#xA;  p.partynumber,&#xA;  p.PartyName,&#xA;  p.CreationDate,&#xA;  v.id,&#xA;  v.ActivationDate,&#xA;  v.VendorCategoryId,&#xA;  v.Status1099,&#xA;  p.CompanyName,&#xA;  CASE&#xA;    WHEN ISNULL(p.DoingBusinessAs, '') = '' THEN NULL&#xA;    ELSE p.DoingBusinessAs&#xA;  &#xA;END&#xA; AS 'DoingBusinessAs',&#xA;  v.Type,&#xA;  v.Status&#xA;into&#xA;  ##VendorTarget&#xA;FROM&#xA;  Insight_UAT..Vendors V&#xA;  INNER JOIN Insight_UAT..parties p on v.id = p.id&#xA;  left Join Insight_UAT..Customers  C on C.ID = P.ID&#xA;  AND p.portfolioid = 1&#xA;  Where C.ID is NULL&#xA;ORDER BY&#xA;  p.partynumber&#xA;SELECT&#xA;  Source.partynumber S_Partynumber,&#xA;  Target.partynumber T_Partynumber,&#xA;  CASE&#xA;    WHEN (&#xA;      ISNULL(Source.partynumber, 0) = ISNULL(Target.partynumber, 0)&#xA;      OR (&#xA;        ISNULL(concat(Source.PartyNumber, '_V'), 0) = ISNULL(Target.PartyNumber, 0)&#xA;      )&#xA;    ) THEN 'TRUE'&#xA;    ELSE 'FALSE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  Source.PartyName S_PartyName,&#xA;  Target.PartyName T_PartyName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.PartyName, 0) &lt;&gt; ISNULL(Target.PartyName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyName_Matched,&#xA;  Source.CreationDate S_CreationDate,&#xA;  Target.CreationDate T_CreationDate,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CreationDate, '2002-02-05') &lt;&gt; ISNULL(Target.CreationDate, '2002-02-05') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CreationDate_Matched,&#xA;  Source.ActivationDate S_ActivationDate,&#xA;  Target.ActivationDate T_ActivationDate,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ActivationDate, '2002-02-05') &lt;&gt; ISNULL(Target.ActivationDate, '2002-02-05') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ActivationDate_Matched,&#xA;  Source.Status1099 S_Status1099,&#xA;  Target.Status1099 T_Status1099,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Status1099, 0) &lt;&gt; ISNULL(Target.Status1099, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Status1099_Matched,&#xA;  Source.Status S_Status,&#xA;  Target.Status T_Status,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Status, 0) &lt;&gt; ISNULL(Target.Status, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Status_Matched,&#xA;  Source.DoingBusinessAs S_DoingBusinessAs,&#xA;  Target.DoingBusinessAs T_DoingBusinessAs,&#xA;  CASE&#xA;    WHEN ISNULL(Source.DoingBusinessAs, 0) &lt;&gt; ISNULL(Target.DoingBusinessAs, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; DoingBusinessAs_Matched,&#xA;  Source.VendorCompanyName S_VendorCompanyName,&#xA;  Target.CompanyName T_CompanyName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.VendorCompanyName, 0) &lt;&gt; ISNULL(Target.CompanyName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CompanyName_Matched&#xA;INTO&#xA;  ##Vendor&#xA;FROM&#xA;  ##VendorSource Source&#xA;  INNER JOIN ##VendorTarget Target ON Source.partynumber = Target.partynumber&#xA;  OR concat(Source.partynumber, '_V') = Target.partynumber &#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE VendorRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##Vendor'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_ExecuteSql @CreateTableScript&#xA;INSERT INTO&#xA;  VendorRecon&#xA;SELECT&#xA;  *&#xA;FROM&#xA;  ##Vendor&#xA;  SELECT * FROM VendorRecon&#xA;DROP TABLE IF EXISTS ##VendorSource&#xA;DROP TABLE IF EXISTS ##VendorTarget&#xA;DROP TABLE IF EXISTS ##Vendor&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
