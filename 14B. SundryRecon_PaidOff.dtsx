  DTS:VersionBuild="2"
  DTS:VersionGUID="{E6B83B40-6FC5-46C2-8188-80463D879109}">
  <DTS:Property
    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\14B SundryRecon_PaidOff"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{DC38EA33-C8C9-4DF2-A9AC-913A7957CCD7}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="14B SundryRecon_PaidOff"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 14B. SundryRecon_PaidOff&#xA;&#xA;DROP TABLE IF EXISTS ##SundrySourcePaidoff&#xA;DROP TABLE IF EXISTS ##SundryTargetPaidoff&#xA;DROP TABLE IF EXISTS ##SundryPaidoff&#xA;DROP TABLE IF EXISTS SundryReconPaidoff&#xA;--Sundry For Paid Off Leases / Assets&#xA;SELECT DISTINCT&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.Receivable_Sundry.Balance AS Decimal(16, 2)&#xA;    )&#xA;  ) AS Amount_Amount,&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.Receivable_Sundry.Balance AS Decimal(16, 2)&#xA;    )&#xA;  ) AS Balance_Amount,&#xA;  CAST(Currency_Index.ISO AS nvarchar(3)) AS Amount_Currency,&#xA;  (&#xA;    CAST(&#xA;      InvoiceGroup_ProfileSundry.InvoiceGroupId AS nvarchar(100)&#xA;    )&#xA;  ) AS BillToName,&#xA;  CASE&#xA;    WHEN Lease_Profile.StatusId = 2 THEN (&#xA;      CAST(&#xA;        Insight_Source.dbo.Lease_Profile.SequenceNumber AS nvarchar(40)&#xA;      )&#xA;    )&#xA;    ELSE NULL&#xA;  &#xA;END&#xA; AS ContractSequenceNumber,&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.Customer_Profile.AccountNumber AS nvarchar(20)&#xA;    )&#xA;  ) AS CustomerPartyNumber,&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.Receivable_Sundry.DueDate AS date&#xA;    )&#xA;  ) AS ReceivableDueDate,&#xA;  CASE&#xA;    WHEN Lease_Profile.StatusId = 2 THEN 'CT'&#xA;    ELSE ('CU')&#xA;  &#xA;END&#xA; AS EntityType,&#xA;  0 AS IsAssetBased,&#xA;  (1) AS IsServiced,&#xA;  (1) AS IsCollected,&#xA;  (0) AS IsPrivateLabel,&#xA;  (1) AS IsOwned,&#xA;  (0) AS IsAssignAtAssetLevel,&#xA;  CAST('Sundry-PaidOff-' AS NVARCHAR) + Cast(Receivable_Sundry.ReceivableID AS nvarchar) AS UniqueIdentifier,&#xA; CASE&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Chargeback - Deal Based' THEN 'Chargeback'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Chargeback - Asset Based' THEN 'Chargeback'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Ewaste Charge - Asset Based' THEN 'eWaste Charge'&#xA;  WHEN SundryCode.SundryCodeTemplateName IN (&#xA;    'IFS Freight Rebill - Deal Based',&#xA;    'IFS Freight Rebill - Asset Based'&#xA;  ) THEN 'Red8 Freight Rebill'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'ISE Freight Rebill - Deal Based' THEN 'Red8 Freight Rebill'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'OH CAT' THEN 'OH CAT'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Pass-Thru Rent' THEN 'Pass-Thru Rent'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'PSTHRU1' THEN 'Pass-Thru Rent'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'PSTHRU2' THEN 'Pass-Thru Rent'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'PSTHRU3' THEN 'Pass-Thru Rent'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'RED8 Freight Rebill - Deal Based' THEN 'Red8 Freight Rebill'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Sales Tax Reimbursement' THEN 'Sales Tax Reimbursement (Not Upfront)'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Softcost Rebill - NonTaxable' THEN 'Softcost Rebill (Non-Taxable)'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Softcost Rebill - Taxable' THEN 'Softcost Rebill (Taxable)'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Sundry - Late Fees - Deal Based' THEN 'Late Fees'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Upfront PPTX' THEN 'Upfront Property Tax'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Upfront Tax Reimbursement' THEN 'Upfront Sales Tax Reimbursement'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Admin Fee - Deal Based' THEN 'Admin Fee'&#xA;  WHEN SundryCode.SundryCodeTemplateName = 'Documentation Fee - Deal Based' THEN 'Documentation Fee'&#xA;  ELSE NULL&#xA;&#xA;END&#xA; AS ReceivableCodeName,&#xA;  CAST(Currency_Index.ISO AS nvarchar(3)) AS CurrencyCode&#xA;into&#xA;  ##SundrySourcePaidoff&#xA;FROM&#xA;  Insight_Source.dbo.Receivable_Sundry&#xA;  INNER JOIN Insight_Source..Sundry_Code SundryCode on Receivable_Sundry.SundryCodeTemplateID = SundryCode.SundryCodeTemplateID&#xA;  INNER JOIN Insight_Source.dbo.InvoiceGroup_Profile InvoiceGroup_ProfileSundry ON Insight_Source.dbo.Receivable_Sundry.InvoiceGroupID = InvoiceGroup_ProfileSundry.InvoiceGroupID&#xA;  INNER JOIN Insight_Source..Lease_Profile on Insight_Source..Lease_Profile.LeaseID = Insight_Source..Receivable_Sundry.EntityId&#xA;  LEFT JOIN Insight_Source..Customer_Profile on Insight_Source..Customer_Profile.CustomerID = Insight_Source..Lease_Profile.CustomerID&#xA;  LEFT JOIN Insight_Source..LLC_Profile on Insight_Source..LLC_Profile.LLCID = Insight_Source..Lease_Profile.LLCID&#xA;  LEFT JOIN Insight_Source..Currency_Index ON LLC_Profile.CurrencyIndexID = Currency_Index.CurrencyIndexID&#xA;  LEFT JOIN Insight_Source..Lease_InventoryInLease on Insight_Source..Lease_InventoryInLease.LeaseID = Insight_Source..Lease_Profile.LeaseID&#xA;  AND Insight_Source..Lease_InventoryInLease.InventoryID = Receivable_Sundry.InventoryID&#xA;WHERE&#xA;  Receivable_Sundry.ReceivableTypeID IN (9, 12, 27, 28)&#xA;  AND Receivable_Sundry.EntityTypeId IN (5)&#xA;  AND (&#xA;    Lease_Profile.StatusId = 3&#xA;    OR (&#xA;      Lease_Profile.StatusId = 2&#xA;      AND Insight_Source..Lease_InventoryInLease.IsInLease = 0&#xA;    )&#xA;  )&#xA;  AND Receivable_Sundry.Balance &lt;&gt; 0&#xA;  AND Receivable_Sundry.IsActive = 1&#xA;  AND SundryRecurringReceivableID IS NULL&#xA;SELECT&#xA;  Sundries.Amount_Amount,&#xA;  Receivables.TotalBalance_Amount AS Balance_Amount,&#xA;  Sundries.Amount_Currency,&#xA;  BillToes.BillToName,&#xA;  Contracts.SequenceNumber ContractSequenceNumber,&#xA;  Parties.PartyNumber CustomerPartyNumber,&#xA;  --LegalEntityNumber, &#xA;  ReceivableDueDate,&#xA;  (Sundries.Entitytype) AS EntityType,&#xA;  IsAssetBased,&#xA;  Sundries.IsServiced,&#xA;  Sundries.IsCollected,&#xA;  Sundries.IsPrivateLabel,&#xA;  IsOwned,&#xA;  IsAssignAtAssetLevel,&#xA;  Receivables.UniqueIdentifier,&#xA;  ReceivableCodes.Name ReceivableCodeName&#xA;  --RemitToes.UniqueIdentifier ReceivableRemitToUniqueIdentifie&#xA;INTO&#xA;  ##SundryTargetPaidoff&#xA;FROM&#xA;  Insight_UAT..Sundries&#xA;  JOIN Insight_UAT..Receivables on Sundries.ReceivableId = Receivables.Id&#xA;  AND Receivables.UniqueIdentifier LIKE 'Sundry-PaidOff-[0-9]%'&#xA;  LEFT JOIN Insight_UAT..Parties on Parties.Id = Receivables.CustomerId&#xA;  --JOIN Insight_UAT..LegalEntities on LegalEntities.Id = Receivables.LegalEntityId AND LegalEntities.BusinessUnitId = 1&#xA;  LEFT JOIN Insight_UAT..Contracts on Contracts.Id = Sundries.ContractId&#xA;  LEFT JOIN Insight_UAT..ReceivableCodes on ReceivableCodes.Id = Receivables.ReceivableCodeId&#xA;  LEFT JOIN Insight_UAT..RemitToes on RemitToes.Id = Sundries.ReceivableRemitToId&#xA;  LEFT JOIN Insight_UAT..ReceivableDetails on Receivables.id = ReceivableDetails.ReceivableId&#xA;  LEFT JOIN Insight_UAT..BillToes on BillToes.Id = ReceivableDetails.BillToId&#xA;WHERE&#xA;  sundries.InvoiceComment IS NULL&#xA;SELECT&#xA;  Source.Amount_Amount S_Amount_Amount,&#xA;  Target.Amount_Amount T_Amount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Amount_Amount, 0) &lt;&gt; ISNULL(Target.Amount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Amount_Amount_Matched,&#xA;  Source.Balance_Amount S_Balance_Amount,&#xA;  Target.Balance_Amount T_Balance_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Balance_Amount, 0) &lt;&gt; ISNULL(Target.Balance_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Balance_Amount_Matched,&#xA;  Source.Amount_Currency S_Amount_Currency,&#xA;  Target.Amount_Currency T_Amount_Currency,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Amount_Currency, 0) &lt;&gt; ISNULL(Target.Amount_Currency, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Amount_Currency_Matched,&#xA;  Source.BillToName S_BillToName,&#xA;  Target.BillToName T_BillToName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.BillToName, 0) &lt;&gt; ISNULL(Target.BillToName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; BillToName_Matched,&#xA;  Source.ContractSequenceNumber S_ContractSequenceNumber,&#xA;  Target.ContractSequenceNumber T_ContractSequenceNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ContractSequenceNumber, 0) &lt;&gt; ISNULL(Target.ContractSequenceNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ContractSequenceNumber_Matched,&#xA;  Source.CustomerPartyNumber S_CustomerPartyNumber,&#xA;  Target.CustomerPartyNumber T_CustomerPartyNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerPartyNumber, 0) &lt;&gt; ISNULL(Target.CustomerPartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerPartyNumber_Matched,&#xA;  Source.ReceivableDueDate S_ReceivableDueDate,&#xA;  Target.ReceivableDueDate T_ReceivableDueDate,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ReceivableDueDate, '1900-01-01') &lt;&gt; ISNULL(Target.ReceivableDueDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ReceivableDueDate_Matched,&#xA;  Source.EntityType S_EntityType,&#xA;  Target.EntityType T_EntityType,&#xA;  CASE&#xA;    WHEN ISNULL(Source.EntityType, 0) &lt;&gt; ISNULL(Target.EntityType, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; EntityType_Matched,&#xA;  Source.IsAssetBased S_IsAssetBased,&#xA;  Target.IsAssetBased T_IsAssetBased,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsAssetBased, 0) &lt;&gt; ISNULL(Target.IsAssetBased, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsAssetBased_Matched,&#xA;  Source.IsServiced S_IsServiced,&#xA;  Target.IsServiced T_IsServiced,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsServiced, 0) &lt;&gt; ISNULL(Target.IsServiced, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsServiced_Matched,&#xA;  Source.IsCollected S_IsCollected,&#xA;  Target.IsCollected T_IsCollected,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsCollected, 0) &lt;&gt; ISNULL(Target.IsCollected, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsCollected_Matched,&#xA;  Source.IsPrivateLabel S_IsPrivateLabel,&#xA;  Target.IsPrivateLabel T_IsPrivateLabel,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsPrivateLabel, 0) &lt;&gt; ISNULL(Target.IsPrivateLabel, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsPrivateLabel_Matched,&#xA;  Source.IsOwned S_IsOwned,&#xA;  Target.IsOwned T_IsOwned,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsOwned, 0) &lt;&gt; ISNULL(Target.IsOwned, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsOwned_Matched,&#xA;  Source.IsAssignAtAssetLevel S_IsAssignAtAssetLevel,&#xA;  Target.IsAssignAtAssetLevel T_IsAssignAtAssetLevel,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsAssignAtAssetLevel, 0) &lt;&gt; ISNULL(Target.IsAssignAtAssetLevel, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsAssignAtAssetLevel,&#xA;  Source.UniqueIdentifier S_UniqueIdentifier,&#xA;  Target.UniqueIdentifier T_UniqueIdentifier,&#xA;  CASE&#xA;    WHEN ISNULL(Source.UniqueIdentifier, 0) &lt;&gt; ISNULL(Target.UniqueIdentifier, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; UniqueIdentifier_Matched,&#xA;  Source.ReceivableCodeName S_ReceivableCodeName,&#xA;  Target.ReceivableCodeName T_ReceivableCodeName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ReceivableCodeName, 0) &lt;&gt; ISNULL(Target.ReceivableCodeName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ReceivableCodeName_Matched&#xA;  --,Source.ReceivableRemitToUniqueIdentifier S_ReceivableRemitToUniqueIdentifier&#xA;  --,Target.ReceivableRemitToUniqueIdentifier T_ReceivableRemitToUniqueIdentifier&#xA;  --,CASE WHEN ISNULL(Source.ReceivableRemitToUniqueIdentifier,0) &lt;&gt; ISNULL(Target.ReceivableRemitToUniqueIdentifier,0) THEN 'FALSE' ELSE 'TRUE' ENDÃ‚Â ReceivableRemitToUniqueIdentifier_Matched&#xA;  --,Source.CurrencyCode S_CurrencyCode&#xA;  --,Target.CurrencyCode T_CurrencyCode&#xA;  --,CASE WHEN ISNULL(Source.CurrencyCode,0) &lt;&gt; ISNULL(Target.CurrencyCode,0) THEN 'FALSE' ELSE 'TRUE' ENDÃ‚Â CurrencyCode_Matched&#xA;into&#xA;  ##SundryPaidoff&#xA;FROM&#xA;  ##SundrySourcePaidoff Source&#xA;  INNER JOIN ##SundryTargetPaidoff Target ON Source.UniqueIdentifier = Target.UniqueIdentifier --AND (Source.CustomerPartyNumber IS NULL OR Source.CustomerPartyNumber = Target.CustomerPartyNumber)&#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE SundryReconPaidoff  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##SundryPaidoff'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript&#xA;&#xA;-- 14B. SundryRecon_PaidOff.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.SundryReconPaidoff&#xA;&#xA;--INSERT INTO&#xA;--  SundryReconPaidoff&#xA;&#xA;SELECT 'SundryReconPaidoff' Recon, *&#xA;INTO V5_Recon.dbo.SundryReconPaidoff&#xA;FROM ##SundryPaidoff&#xA; &#xA;--SELECT * FROM SundryReconPaidoff&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.SundryReconPaidoff&#xA;&#xA;DROP TABLE IF EXISTS ##SundrySourcePaidoff&#xA;DROP TABLE IF EXISTS ##SundryTargetPaidoff&#xA;DROP TABLE IF EXISTS ##SundryPaidoff&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
