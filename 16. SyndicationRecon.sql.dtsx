  <DTS:Property
    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\16 SyndicationRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{CA1355CC-6B95-41E6-A3AC-2A5AE33710FC}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="16 SyndicationRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250930 SyndicationRecon&#xA; DROP TABLE IF EXISTS ##SyndicationSource&#xA; DROP TABLE IF EXISTS ##SyndicationTarget&#xA; DROP TABLE IF EXISTS ##SyndicationRecon&#xA; DROP TABLE IF EXISTS SyndicationRecon&#xA;&#xA;--Source&#xA;Select  QuoteName as SyndicationQuoteName, &#xA;Lease_Profile.SequenceNumber,&#xA;LEL.LegalEntityNumber AS LegalEntityNumber,&#xA;LEL.RemitTo,&#xA;CAST(FundDate AS DateTime) as FundingDate,&#xA; (&#xA;    CASE&#xA;      WHEN DaysInYear = 360 THEN CAST('_30By360' AS nvarchar)&#xA;      ELSE CAST('ActualBy365' AS nvarchar)&#xA;    &#xA;END&#xA;&#xA;  ) AS DayCountConvention,&#xA;   CAST(&#xA;      Insight_Source.dbo.Syndication_Quote.DiscountRate AS Decimal(8, 4)&#xA;    ) DiscountRate,&#xA; (&#xA;CASE&#xA;    WHEN SyndicationTransactionTypeID = 1 THEN 'FinancingGain'&#xA;    WHEN SyndicationTransactionTypeID = 2 THEN 'EquitySale'&#xA;    WHEN SyndicationTransactionTypeID = 3 THEN 'LeverageEquitySale'&#xA;    &#xA;END&#xA;&#xA;) AS FullSaleSyndicationType,&#xA;'FullSale' as ReceivableForTransferType,&#xA;CASE WHEN SyndicationQuoteStatusID=2 THEN 'Approved' Else 'Pending' END as ApprovalStatus,&#xA;SyndicationProceeds as ActualProceeds_Amount ,&#xA;(CASE  WHEN Lease_Profile.LLCID = 1 THEN 'USD' WHEN Lease_Profile.LLCID = 2 THEN 'CAD' WHEN Lease_Profile.LLCID = 3 THEN 'AED' WHEN Lease_Profile.LLCID = 4 THEN 'GBP' WHEN Lease_Profile.LLCID = 5 THEN 'AUD' WHEN Lease_Profile.LLCID = 6 THEN 'EUR' WHEN Lease_Profile.LLCID = 7 THEN 'CZK' WHEN Lease_Profile.LLCID = 8 THEN 'JPY' END ) AS Currency, &#xA;Company as FunderName,&#xA;100 as ParticipationPercentage,&#xA;1 AS IsServiced,&#xA; 1 as IsCollected,&#xA; 'DoNotRemit' as PropertyTaxResponsibility,&#xA; ServiceFee as ServiceFee_Amount,&#xA; CASE when Servicefee&gt;0 THEN 'RecognizeImmediately' ELSE NULL End as  BookRecognitionMode,&#xA; ISNULL(SSD.AllowSyndicationSharing,1)  AS AllowSyndicationSharing,&#xA; SharingStartDate AS SharingStartDate,&#xA; ISNULL(SSD.DebtRate,0) AS DebtRate,&#xA; ISNULL(SSD.SyndicationRate,0) AS SyndicationRate,&#xA; PoolName AS PoolName&#xA;INTO ##SyndicationSource&#xA;FROM  Insight_Source.dbo.Syndication_quote&#xA; Inner JOIN Insight_Source.dbo.Lease_Profile ON Insight_Source.dbo.Syndication_quote.EntityId = Insight_Source.dbo.Lease_Profile.LeaseId&#xA; inner JOIN Insight_Source.dbo.Lease_investment    ON Insight_Source.dbo.Syndication_Quote.EntityID = Lease_investment.Leaseid AND Lease_investment.IsActive=1 &#xA; Inner JOIN Insight_Source.dbo.Syndication_Type_Cnfg    ON Insight_Source.dbo.Syndication_Quote.TypeId = Syndication_Type_Cnfg.TypeID AND Syndication_Type_Cnfg.IsActive=1&#xA; Inner JOIN Insight_Source.dbo.FundingSource_Profile ON Insight_Source.dbo.Syndication_Quote.FundingSourceId=Insight_Source.dbo.FundingSource_Profile.FundingSourceId&#xA; INNER JOIN Migration_Intermediate..LegalEntityLease LEL on LEL.SequenceNumber = Lease_Profile.SequenceNumber&#xA; LEFT JOIN Migration_Intermediate..SyndicationSharingDetails SSD on SSD.SequenceNumber = Lease_Profile.SequenceNumber&#xA; left JOIN Insight_Source.dbo.SyndicationView    ON Insight_Source.dbo.Syndication_Quote.SyndicationID = SyndicationView.SyndicationID&#xA; WHERE Insight_Source.dbo.Syndication_quote.SyndicationQuoteStatusID in (2) AND Insight_Source.dbo.Lease_Profile.StatusId in (2)  &#xA; ORDER BY Insight_Source.dbo.Syndication_quote.EntityId&#xA;&#xA; --- Target&#xA;Select Distinct RFT.Name As SyndicationQuoteName,&#xA;C.SequenceNumber As SequenceNumber,&#xA;RT.UniqueIdentifier AS RemitTo,&#xA;LE.LegalEntityNumber AS LegalEntityNumber,&#xA;RFT.FundingDate,&#xA;RFT.DayCountConvention,&#xA;RFT.DiscountRate,&#xA;RFT.FullSaleSyndicationType,&#xA;RFT.ReceivableForTransferType,&#xA;RFT.ApprovalStatus,&#xA;RFT.ActualProceeds_Amount,&#xA;RFT.ActualProceeds_Currency AS Currency,&#xA;P.CompanyName As FunderName,&#xA;RFTS.ParticipationPercentage, &#xA;IsServiced,&#xA;IsCollected,&#xA;PropertyTaxResponsibility,&#xA;ISNUll(BI.Amount_Amount,0) As ServiceFee_Amount,&#xA;BI.BookRecognitionMode,&#xA;RFT.AllowSyndicationSharing,&#xA;RFT.SharingStartDate,&#xA;DebtRate,&#xA;SyndicationRate,&#xA;PoolName&#xA;&#xA;INTO ##SyndicationTarget &#xA;FROM Insight_UAT.dbo.ReceivableForTransfers RFT &#xA;Inner Join Insight_UAT..RemitToes RT on RT.Id = RFT.RemitToId&#xA;Inner Join Insight_UAT..LegalEntities LE on LE.Id = RFT.LegalEntityId&#xA;Inner join Insight_UAT.dbo.Contracts C on C.Id=RFT.ContractId And ApprovalStatus='Approved'&#xA;Inner join Insight_UAT.dbo.ReceivableForTransferFundingSources RFTS ON RFT.ID=RFTS.ReceivableForTransferId&#xA;Inner Join Insight_UAT.dbo.Funders F on RFTS.Funderid=F.id&#xA;Inner Join Insight_UAT.dbo.Parties P ON P.Id=F.id&#xA;Inner Join Insight_UAT.dbo.ReceivableForTransferServicings RFS ON&#x9;RFT.ID=RFS.ReceivableForTransferId&#xA;left Join Insight_UAT.dbo.ReceivableForTransferBlendedItems RFTBI ON RFT.ID=RFTBI.ReceivableForTransferId --and RFTBI.FundingSourceID is not  null&#xA;left Join Insight_UAT.dbo.BlendedItems BI on RFTBI.BlendedItemId=BI.Id and BI.EntityType='Syndication' and BI.SystemConfigType='_'&#xA;&#xA;&#xA;&#xA; &#xA;&#xA; select&#xA;Source.SyndicationQuoteName S_SyndicationQuoteName&#xA;,Target.SyndicationQuoteName T_SyndicationQuoteName&#xA;,CASE WHEN ISNULL(Source.SyndicationQuoteName,0) &lt;&gt; ISNULL(Target.SyndicationQuoteName,0) THEN 'FALSE' ELSE 'TRUE' END SyndicationQuoteName_Matched&#xA;,Source.SequenceNumber S_SequenceNumber&#xA;,Target.SequenceNumber T_SequenceNumber&#xA;,CASE WHEN ISNULL(Source.SequenceNumber,0) &lt;&gt; ISNULL(Target.SequenceNumber,0) THEN 'FALSE' ELSE 'TRUE' END SequenceNumber_Matched&#xA;,Source.LegalEntityNumber S_LegalEntityNumber&#xA;,Target.LegalEntityNumber T_LegalEntityNumber&#xA;,CASE WHEN ISNULL(Source.LegalEntityNumber,0) &lt;&gt; ISNULL(Target.LegalEntityNumber,0) THEN 'FALSE' ELSE 'TRUE' END LegalEntityNumber_Matched&#xA;,Source.RemitTo S_RemitTo&#xA;,Target.RemitTo T_RemitTo&#xA;,CASE WHEN ISNULL(Source.RemitTo,0) &lt;&gt; ISNULL(Target.RemitTo,0) THEN 'FALSE' ELSE 'TRUE' END RemitTo_Matched&#xA;,Source.FundingDate S_FundingDate&#xA;,Target.FundingDate T_FundingDate&#xA;,CASE WHEN ISNULL(Source.FundingDate,getdate()) &lt;&gt; ISNULL(Target.FundingDate,getdate()) THEN 'FALSE' ELSE 'TRUE' END FundingDate_Matched&#xA;,Source.DayCountConvention S_DayCountConvention&#xA;,Target.DayCountConvention T_DayCountConvention&#xA;,CASE WHEN ISNULL(Source.DayCountConvention,'') &lt;&gt; ISNULL(Target.DayCountConvention,'') THEN 'FALSE' ELSE 'TRUE' END DayCountConvention_Matched&#xA;,Source.DiscountRate S_DiscountRate&#xA;,Target.DiscountRate T_DiscountRate&#xA;,CASE WHEN ISNULL(Source.DiscountRate,0) &lt;&gt; ISNULL(Target.DiscountRate,0) THEN 'FALSE' ELSE 'TRUE' END DiscountRate_Matched&#xA;,Source.FullSaleSyndicationType S_FullSaleSyndicationType&#xA;,Target.FullSaleSyndicationType T_FullSaleSyndicationType&#xA;,CASE WHEN ISNULL(Source.FullSaleSyndicationType,'') &lt;&gt; ISNULL(Target.FullSaleSyndicationType,'') THEN 'FALSE' ELSE 'TRUE' END FullSaleSyndicationType_Matched&#xA;,Source.ReceivableForTransferType S_ReceivableForTransferType&#xA;,Target.ReceivableForTransferType T_ReceivableForTransferType&#xA;,CASE WHEN ISNULL(Source.ReceivableForTransferType,0) &lt;&gt; ISNULL(Target.ReceivableForTransferType,0) THEN 'FALSE' ELSE 'TRUE' END ReceivableForTransferType_Matched&#xA;,Source.ApprovalStatus S_ApprovalStatus&#xA;,Target.ApprovalStatus T_ApprovalStatus&#xA;,CASE WHEN ISNULL(Source.ApprovalStatus,0) &lt;&gt; ISNULL(Target.ApprovalStatus,0) THEN 'FALSE' ELSE 'TRUE' END ApprovalStatus_Matched&#xA;,Source.ActualProceeds_Amount S_ActualProceeds_Amount&#xA;,Target.ActualProceeds_Amount T_ActualProceeds_Amount&#xA;,CASE WHEN ISNULL(Source.ActualProceeds_Amount,0) &lt;&gt; ISNULL(Target.ActualProceeds_Amount,0) THEN 'FALSE' ELSE 'TRUE' END ActualProceeds_Amount_Matched&#xA;,Source.Currency S_Currency&#xA;,Target.Currency T_Currency&#xA;,CASE WHEN ISNULL(Source.Currency,0) &lt;&gt; ISNULL(Target.Currency,0) THEN 'FALSE' ELSE 'TRUE' END Currency_Matched&#xA;,Source.FunderName S_FunderName&#xA;,Target.FunderName T_FunderName&#xA;,CASE WHEN ISNULL(Source.FunderName,0) &lt;&gt; ISNULL(Target.FunderName,0) THEN 'FALSE' ELSE 'TRUE' END FunderName_Matched&#xA;,Source.ParticipationPercentage S_ParticipationPercentage&#xA;,Target.ParticipationPercentage T_ParticipationPercentage&#xA;,CASE WHEN ISNULL(Source.ParticipationPercentage,0) &lt;&gt; ISNULL(Target.ParticipationPercentage,0) THEN 'FALSE' ELSE 'TRUE' END ParticipationPercentage_Matched&#xA;,Source.IsServiced S_IsServiced&#xA;,Target.IsServiced T_IsServiced&#xA;,CASE WHEN ISNULL(Source.IsServiced,0) &lt;&gt; ISNULL(Target.IsServiced,0) THEN 'FALSE' ELSE 'TRUE' END IsServiced_Matched&#xA;,Source.IsCollected S_IsCollected&#xA;,Target.IsCollected T_IsCollected&#xA;,CASE WHEN ISNULL(Source.IsCollected,0) &lt;&gt; ISNULL(Target.IsCollected,0) THEN 'FALSE' ELSE 'TRUE' END IsCollected_Matched&#xA;,Source.PropertyTaxResponsibility S_PropertyTaxResponsibility&#xA;,Target.PropertyTaxResponsibility T_PropertyTaxResponsibility&#xA;,CASE WHEN ISNULL(Source.PropertyTaxResponsibility,0) &lt;&gt; ISNULL(Target.PropertyTaxResponsibility,0) THEN 'FALSE' ELSE 'TRUE' END PropertyTaxResponsibility_Matched&#xA;,Source.ServiceFee_Amount S_ServiceFee_Amount&#xA;,Target.ServiceFee_Amount T_ServiceFee_Amount&#xA;,CASE WHEN ISNULL(Source.ServiceFee_Amount,0) &lt;&gt; ISNULL(Target.ServiceFee_Amount,0) THEN 'FALSE' ELSE 'TRUE' END  ServiceFee_Amount_Matched&#xA;,Source.BookRecognitionMode S_BookRecognitionMode&#xA;,Target.BookRecognitionMode T_BookRecognitionMode&#xA;,CASE WHEN ISNULL(Source.BookRecognitionMode,0) &lt;&gt; ISNULL(Target.BookRecognitionMode,0) THEN 'FALSE' ELSE 'TRUE' END  BookRecognitionMode_Matched&#xA;,Source.AllowSyndicationSharing S_AllowSyndicationSharing&#xA;,Target.AllowSyndicationSharing T_AllowSyndicationSharing&#xA;,CASE WHEN ISNULL(Source.AllowSyndicationSharing,0) &lt;&gt; ISNULL(Target.AllowSyndicationSharing,0) THEN 'FALSE' ELSE 'TRUE' END  AllowSyndicationSharing_Matched&#xA;,Source.SharingStartDate S_SharingStartDate&#xA;,Target.SharingStartDate T_SharingStartDate&#xA;,CASE WHEN ISNULL(Source.SharingStartDate,Getdate()) &lt;&gt; ISNULL(Target.SharingStartDate,Getdate()) THEN 'FALSE' ELSE 'TRUE' END  SharingStartDate_Matched&#xA;,Source.DebtRate S_DebtRate&#xA;,Target.DebtRate T_DebtRate&#xA;,CASE WHEN ISNULL(Source.DebtRate,0) &lt;&gt; ISNULL(Target.DebtRate,0) THEN 'FALSE' ELSE 'TRUE' END  DebtRate_Matched&#xA;,Source.SyndicationRate S_SyndicationRate&#xA;,Target.SyndicationRate T_SyndicationRate&#xA;,CASE WHEN ISNULL(Source.SyndicationRate,0) &lt;&gt; ISNULL(Target.SyndicationRate,0) THEN 'FALSE' ELSE 'TRUE' END  SyndicationRate_Matched&#xA;,Source.PoolName S_PoolName&#xA;,Target.PoolName T_PoolName&#xA;,CASE WHEN ISNULL(Source.PoolName,0) &lt;&gt; ISNULL(Target.PoolName,0) THEN 'FALSE' ELSE 'TRUE' END  PoolName_Matched&#xA;INTO ##SyndicationRecon&#xA;FROM&#xA;##SyndicationSource Source&#xA;INNER JOIN ##SyndicationTarget Target&#xA;ON  Source.SyndicationQuoteName=Target.SyndicationQuoteName&#xA;AND Source.SequenceNumber=Target.SequenceNumber&#xA;&#xA;&#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE SyndicationRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##SyndicationRecon'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript&#xA;&#xA;-- 16. SyndicationRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.SyndicationRecon&#xA;&#xA;--INSERT INTO&#xA;--  SyndicationRecon&#xA;&#xA;SELECT 'SyndicationRecon' Recon, *&#xA;INTO V5_Recon.dbo.SyndicationRecon&#xA;FROM ##SyndicationRecon&#xA;&#xA;--SELECT&#xA;--  *&#xA;--FROM&#xA;--  SyndicationRecon &#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.SyndicationRecon&#xA;&#xA;DROP Table ##SyndicationSource&#xA;DROP Table ##SyndicationTarget&#xA;DROP Table ##SyndicationRecon" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
