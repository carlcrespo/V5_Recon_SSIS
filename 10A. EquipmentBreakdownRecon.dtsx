    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\10A EquipmentBreakdownRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{03C1FA64-3920-47E9-B7CB-4EEADDFE2519}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="10A EquipmentBreakdownRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 EquipmentBreakdownsRecon&#xA;&#xA;DROP TABLE IF EXISTS ##EquipmentBreakdownsSource&#xA;DROP TABLE IF EXISTS ##EquipmentBreakdownsTarget&#xA;DROP TABLE IF EXISTS ##EquipmentBreakdownsRecon&#xA;DROP TABLE IF EXISTS EquipmentBreakdownsRecon&#xA;SELECT &#xA;   &#xA;  Cast(&#xA;    LeaseTransaction_EquipmentBreakDown.Description AS Nvarchar(200)&#xA;  ) AS Description,&#xA;  CASE&#xA;    WHEN LeaseTransaction_EquipmentBreakDown.UsageConditionID = 1 THEN 'New'&#xA;    WHEN LeaseTransaction_EquipmentBreakDown.UsageConditionID = 2 THEN 'Used'&#xA;    WHEN LeaseTransaction_EquipmentBreakDown.UsageConditionID = 3 THEN 'Used'&#xA;  &#xA;END&#xA; AS UsageCondition,&#xA;  Cast(&#xA;    Sum(LeaseTransaction_EquipmentBreakDown.InsightCost) AS decimal(16, 2)&#xA;  ) AS InsightCost_Amount,&#xA;  (&#xA;    CASE&#xA;      WHEN Lease_Profile.LLCID = 1 THEN 'USD'&#xA;      WHEN Lease_Profile.LLCID = 2 THEN 'CAD'&#xA;      WHEN Lease_Profile.LLCID = 3 THEN 'AED'&#xA;      WHEN Lease_Profile.LLCID = 4 THEN 'GBP'&#xA;      WHEN Lease_Profile.LLCID = 5 THEN 'AUD'&#xA;      WHEN Lease_Profile.LLCID = 6 THEN 'EUR'&#xA;      WHEN Lease_Profile.LLCID = 7 THEN 'CZK'&#xA;      WHEN Lease_Profile.LLCID = 8 THEN 'JPY'&#xA;    &#xA;END&#xA;&#xA;  ) AS Currency,&#xA;  Cast(&#xA;    Sum(LeaseTransaction_EquipmentBreakDown.MarkUpAmount) AS decimal(16, 2)&#xA;  ) AS MarkupAmount_Amount,&#xA;  Cast(&#xA;    Sum(LeaseTransaction_EquipmentBreakDown.CustomerCost) AS decimal(16, 2)&#xA;  ) AS CustomerCost_Amount,&#xA;  Cast(&#xA;    LeaseTransaction_EquipmentBreakDown.OriginalLeaseRentFactor AS decimal(18, 8)&#xA;  ) AS RentFactor,&#xA;  Cast(&#xA;    Sum(LeaseTransaction_EquipmentBreakDown.OriginalLeaseRentAmount) AS decimal(16, 2)&#xA;  ) AS RentAmount_Amount,&#xA;  Cast(&#xA;    LeaseTransaction_EquipmentBreakDown.IndexedLRF AS decimal(18, 8)&#xA;  ) AS IndexedRentFactor,&#xA;  Cast(&#xA;    Sum(LeaseTransaction_EquipmentBreakDown.IndexedRent) AS decimal(16, 2)&#xA;  ) AS IndexedRentAmount_Amount,&#xA;  Cast(&#xA;    LeaseTransaction_EquipmentBreakDown.QuotedPayoutPercent AS decimal(5, 2)&#xA;  ) AS QuotedPayoutPercent,&#xA;  Cast(&#xA;    LeaseTransaction_EquipmentBreakDown.GridPayoutPercent AS decimal(5, 2)&#xA;  ) AS GridPayoutPercent,&#xA;  (&#xA;    CAST(&#xA;      Inventory_TypeTemplate.InventoryTypeName AS nvarchar(100)&#xA;    )&#xA;  ) AS AssetType,&#xA;  (&#xA;    cast(&#xA;      Inventory_ManufacturerTemplate.InventoryManufacturerName AS nvarchar(100)&#xA;    )&#xA;  ) AS AssetManufacturer,&#xA;  Lease_Profile.LeaseID AS LeaseId &#xA;Into&#xA;  ##EquipmentBreakdownsSource&#xA;FROM&#xA;  Insight_Source.dbo.Lease_Profile&#xA;  JOIN Insight_Source.dbo.LeaseTransaction_Profile on Insight_Source.dbo.Lease_Profile.LeaseId = Insight_Source.dbo.LeaseTransaction_Profile.LeaseId&#xA;  JOIN Insight_Source.dbo.LeaseTransaction_EquipmentBreakDown on Insight_Source.dbo.LeaseTransaction_Profile.LeaseTransactionID = Insight_Source.dbo.LeaseTransaction_EquipmentBreakDown.LeaseTransactionID&#xA;  INNER JOIN Migration_Intermediate..legalentitylease LEL on LEL.SequenceNumber = Insight_Source.dbo.Lease_Profile.SequenceNumber&#xA;  INNER JOIN Insight_Source..Inventory_ManufacturerTemplate on Insight_Source.dbo.LeaseTransaction_EquipmentBreakDown.InventoryManufacturerID = Inventory_ManufacturerTemplate.inventorymanufacturerid&#xA;  INNER JOIN Insight_Source.dbo.Inventory_TypeTemplate ON Insight_Source.dbo.LeaseTransaction_EquipmentBreakDown.InventoryTypeID = Inventory_TypeTemplate.InventoryTypeID&#xA;WHERE&#xA;  Insight_Source.dbo.Lease_Profile.StatusId IN (2)&#xA;  AND lel.LegalEntityNumber IS NOT NULL&#xA;GROUP BY &#xA;UsageConditionID,&#xA;Lease_Profile.LLCID,&#xA;Lease_Profile.LeaseID,&#xA;Inventory_ManufacturerTemplate.InventoryManufacturerName,&#xA;Inventory_TypeTemplate.InventoryTypeName,&#xA;LeaseTransaction_EquipmentBreakDown.GridPayoutPercent,&#xA;LeaseTransaction_EquipmentBreakDown.QuotedPayoutPercent,&#xA;LeaseTransaction_EquipmentBreakDown.Description,&#xA;LeaseTransaction_EquipmentBreakDown.IndexedLRF,&#xA;LeaseTransaction_EquipmentBreakDown.OriginalLeaseRentFactor&#xA;&#xA;&#xA;SELECT&#xA;  EB.Description,&#xA;  UsageCondition,&#xA;  Sum(InsightCost_Amount) AS InsightCost_Amount,&#xA;  InsightCost_Currency AS Currency,&#xA;  Sum(MarkupAmount_Amount) AS MarkupAmount_Amount,&#xA;  Sum(CustomerCost_Amount) AS CustomerCost_Amount,&#xA;  RentFactor,&#xA;  Sum(RentAmount_Amount) AS RentAmount_Amount,&#xA;  IndexedRentFactor,&#xA;  Sum(IndexedRentAmount_Amount) AS IndexedRentAmount_Amount,&#xA;  QuotedPayoutPercent,&#xA;  GridPayoutPercent,&#xA;  AT.Name AssetTypeName,&#xA;  M.Name ManufacturerName,&#xA;  ContractId&#xA;into&#xA;  ##EquipmentBreakdownsTarget&#xA;FROM&#xA;  Insight_UAT.dbo.EquipmentBreakdowns EB&#xA;  INNER JOIN Insight_UAT.dbo.LeaseFinances LF on EB.LeaseFinanceId = LF.Id AND LF.BookingStatus='Commenced'&#xA;  INNER JOIN Insight_UAT.dbo.AssetTypes AT on EB.AssetTypeId = AT.Id&#xA;  INNER JOIN Insight_UAT.dbo.Manufacturers M on M.Id = EB.AssetManufacturerId&#xA;Group by&#xA;EB.Description,&#xA;UsageCondition,&#xA;InsightCost_Currency,&#xA;RentFactor,&#xA;IndexedRentFactor,&#xA;QuotedPayoutPercent,&#xA;GridPayoutPercent,&#xA;AT.Name,&#xA;M.Name,&#xA;ContractId&#xA;&#xA;SELECT DISTINCT&#xA; &#xA;  -- EB.Description&#xA; &#xA;  Source.Description S_Description,&#xA;  Target.Description T_Description,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Description, '') &lt;&gt; ISNULL(Target.Description, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Description_Matched&#xA;  -- UsageCondition&#xA;,&#xA;  Source.UsageCondition S_UsageCondition,&#xA;  Target.UsageCondition T_UsageCondition,&#xA;  CASE&#xA;    WHEN ISNULL(Source.UsageCondition, '') &lt;&gt; ISNULL(Target.UsageCondition, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; UsageCondition_Matched&#xA;  -- InsightCost_Amount&#xA;,&#xA;  Source.InsightCost_Amount S_InsightCost_Amount,&#xA;  Target.InsightCost_Amount T_InsightCost_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.InsightCost_Amount, 0) &lt;&gt; ISNULL(Target.InsightCost_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InsightCost_Amount_Matched&#xA;  -- InsightCost_Currency&#xA;,&#xA;  Source.Currency S_Currency,&#xA;  Target.Currency T_Currency,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Currency, '') &lt;&gt; ISNULL(Target.Currency, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Currency_Matched&#xA;  -- MarkupAmount_Amount&#xA;,&#xA;  Source.MarkupAmount_Amount S_MarkupAmount_Amount,&#xA;  Target.MarkupAmount_Amount T_MarkupAmount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.MarkupAmount_Amount, 0) &lt;&gt; ISNULL(Target.MarkupAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; MarkupAmount_Amount_Matched&#xA;  -- CustomerCost_Amount&#xA;,&#xA;  Source.CustomerCost_Amount S_CustomerCost_Amount,&#xA;  Target.CustomerCost_Amount T_CustomerCost_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerCost_Amount, 0) &lt;&gt; ISNULL(Target.CustomerCost_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerCost_Amount_Matched&#xA;, &#xA;  -- RentFactor&#xA;&#xA;  Source.RentFactor S_RentFactor,&#xA;  Target.RentFactor T_RentFactor,&#xA;  CASE&#xA;    WHEN ISNULL(Source.RentFactor, 0) &lt;&gt; ISNULL(Target.RentFactor, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; RentFactor_Matched&#xA;  -- RentAmount_Amount&#xA;,&#xA;  Source.RentAmount_Amount S_RentAmount_Amount,&#xA;  Target.RentAmount_Amount T_RentAmount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.RentAmount_Amount, 0) &lt;&gt; ISNULL(Target.RentAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; RentAmount_Amount_Matched&#xA;  -- IndexedRentFactor&#xA;,&#xA;  Source.IndexedRentFactor S_IndexedRentFactor,&#xA;  Target.IndexedRentFactor T_IndexedRentFactor,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IndexedRentFactor, 0) &lt;&gt; ISNULL(Target.IndexedRentFactor, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IndexedRentFactor_Matched&#xA;  -- IndexedRentAmount_Amount&#xA;,&#xA;  Source.IndexedRentAmount_Amount S_IndexedRentAmount_Amount,&#xA;  Target.IndexedRentAmount_Amount T_IndexedRentAmount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IndexedRentAmount_Amount, 0) &lt;&gt; ISNULL(Target.IndexedRentAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IndexedRentAmount_Amount_Matched&#xA;&#xA; -- QuotedPayoutPercent&#xA;,&#xA;  Source.QuotedPayoutPercent S_QuotedPayoutPercent,&#xA;  Target.QuotedPayoutPercent T_QuotedPayoutPercent,&#xA;  CASE&#xA;    WHEN ISNULL(Source.QuotedPayoutPercent, 0) &lt;&gt; ISNULL(Target.QuotedPayoutPercent, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; QuotedPayoutPercent_Matched&#xA;  -- GridPayoutPercent&#xA;,&#xA;  Source.GridPayoutPercent S_GridPayoutPercent,&#xA;  Target.GridPayoutPercent T_GridPayoutPercent,&#xA;  CASE&#xA;    WHEN ISNULL(Source.GridPayoutPercent, 0) &lt;&gt; ISNULL(Target.GridPayoutPercent, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; GridPayoutPercent_Matched&#xA;  -- AssetTypeName&#xA;,&#xA;  Source.AssetType S_AssetTypeName,&#xA;  Target.AssetTypeName T_AssetTypeName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.AssetType, '') &lt;&gt; ISNULL(Target.AssetTypeName, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AssetTypeName_Matched&#xA;  -- ManufacturerName&#xA;,&#xA;  Source.AssetManufacturer S_ManufacturerName,&#xA;  Target.ManufacturerName T_ManufacturerName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.AssetManufacturer, '') &lt;&gt; ISNULL(Target.ManufacturerName, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ManufacturerName_Matched&#xA;  -- ContractId&#xA;,&#xA;  Source.LeaseId S_ContractId,&#xA;  Target.ContractId T_ContractId,&#xA;  CASE&#xA;    WHEN ISNULL(Source.LeaseId, '') &lt;&gt; ISNULL(Target.ContractId, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ContractId_Matched&#xA;into&#xA;  ##EquipmentBreakdownsRecon&#xA;FROM&#xA;  ##EquipmentBreakdownsSource Source&#xA;  INNER JOIN ##EquipmentBreakdownsTarget Target ON Source.LeaseId = Target.ContractId&#xA;  AND Source.description = target.Description&#xA;  AND TRIM(source.AssetManufacturer) = TRIM(Target.ManufacturerName)&#xA;  AND Source.AssetType = Target.AssetTypeName &#xA;  AND Source.InsightCost_Amount=Target.InsightCost_Amount &#xA;  AND Source.RentFactor = Target.RentFactor&#xA;  AND Source.QuotedPayoutPercent =Target.QuotedPayoutPercent&#xA;  DECLARE @CreateTableScript NVARCHAR(max) = 'CREATE TABLE EquipmentBreakdownsRecon (';&#xA;&#xA;DECLARE @Columns NVARCHAR(max);&#xA;&#xA;SELECT&#xA;  @Columns = ISNULL(@Columns + ', ', '') + COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;    WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;    WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;    WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;    ELSE ''&#xA;  &#xA;END&#xA;&#xA;FROM&#xA;  tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;WHERE&#xA;  TABLE_NAME = '##EquipmentBreakdownsRecon';&#xA;&#xA;SET&#xA;  @CreateTableScript = @CreateTableScript + @Columns + ');';&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript;&#xA;&#xA;-- 10A. EquipmentBreakdownRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.EquipmentBreakdownsRecon&#xA; &#xA;--INSERT INTO&#xA;--  EquipmentBreakdownsRecon&#xA;&#xA;SELECT 'EquipmentBreakdownsRecon' Recon,  *&#xA;INTO V5_Recon.dbo.EquipmentBreakdownsRecon&#xA;FROM ##EquipmentBreakdownsRecon&#xA;&#xA;&#xA;DROP TABLE IF EXISTS ##EquipmentBreakdownsSource&#xA;DROP TABLE IF EXISTS ##EquipmentBreakdownsTarget&#xA;DROP TABLE IF EXISTS ##EquipmentBreakdownsRecon&#xA;&#xA;--SELECT * FROM EquipmentBreakdownsRecon&#xA;&#xA;SELECT * &#xA;FROM V5_Recon.dbo.EquipmentBreakdownsRecon" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
