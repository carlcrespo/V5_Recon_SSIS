  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\12 CreditProfileRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{267A5238-2659-41AB-B86B-9CA88E2EB144}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="12 CreditProfileRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 CreditProfileRecon&#xA;DROP TABLE IF EXISTS ##CreditProfileSource&#xA;DROP TABLE IF EXISTS ##CreditProfileTarget&#xA;DROP TABLE IF EXISTS ##CreditProfile&#xA;DROP TABLE IF EXISTS CreditProfileRecon&#xA;SELECT&#xA;  (&#xA;    CASE&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_Profile.llCID = 1 THEN 'USD'&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_Profile.llCID = 2 THEN 'CAD'&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_Profile.llCID = 6 THEN 'EUR'&#xA;      ELSE 'USD'&#xA;    &#xA;END&#xA;&#xA;  ) AS Currency,&#xA;  (&#xA;    CAST(&#xA;      Customer_ProfileCreditProfile.AccountNumber AS nvarchar(40)&#xA;    )&#xA;  ) AS CustomerNumber,&#xA;  ('Approved') AS Status,&#xA;  ICP.LegalEntityNumber AS LegalEntityNumber,&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.LeaseTransaction_Profile.LeaseTransactionID AS nvarchar(20)&#xA;    )&#xA;  ) AS Number,&#xA;  (CreditProfileView.Amount) AS RequestedAmount_Amount,&#xA;  (CreditProfileView.Amount) AS ApprovedAmount_Amount,&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.LeaseTerm AS BigInt&#xA;    )&#xA;  ) AS CustomerTerm,&#xA;  (CAST('1' AS BigInt)) AS DueDay,&#xA;  (&#xA;    CAST(&#xA;      Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.LeaseCommencementDate AS date&#xA;    )&#xA;  ) AS ExpectedCommencementDate,&#xA;  (CAST('0' AS bit)) AS IsAdvance,&#xA;  (&#xA;    CAST(&#xA;      CASE&#xA;        WHEN RentalFrequencyID = 1 THEN LeaseTerm&#xA;        WHEN RentalFrequencyID = 2 THEN LeaseTerm / 3&#xA;        WHEN RentalFrequencyID = 3 THEN LeaseTerm / 6&#xA;        WHEN RentalFrequencyID = 4 THEN LeaseTerm / 12&#xA;        WHEN RentalFrequencyID = 5 THEN LeaseTerm&#xA;      &#xA;END&#xA; AS BigInt&#xA;    )&#xA;  ) AS NumberofPayments,&#xA;  (&#xA;    CASE&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.RentalFrequencyID = 1 THEN 'Monthly'&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.RentalFrequencyID = 2 THEN 'Quarterly'&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.RentalFrequencyID = 3 THEN 'Half-Yearly'&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.RentalFrequencyID = 4 THEN 'Yearly'&#xA;      WHEN Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.RentalFrequencyID = 5 THEN '_'&#xA;    &#xA;END&#xA;&#xA;  ) AS PaymentFrequency&#xA;Into&#xA;  ##CreditProfileSource&#xA;FROM&#xA;  Insight_Source.dbo.LeaseTransaction_Profile&#xA;  INNER JOIN Insight_Source.dbo.CreditProfileFilterView ON Insight_Source.dbo.LeaseTransaction_Profile.LeaseTransactionId = Insight_Source.dbo.CreditProfileFilterView.LeaseTransactionId&#xA;  INNER JOIN Insight_Source.dbo.CreditProfileView ON Insight_Source.dbo.LeaseTransaction_Profile.LeaseTransactionId = CreditProfileView.LeaseTransactionID&#xA;  INNER JOIN Insight_Source.dbo.Customer_Profile Customer_ProfileCreditProfile ON Insight_Source.dbo.LeaseTransaction_Profile.CustomerId = Customer_ProfileCreditProfile.CustomerId&#xA;  INNER JOIN Insight_Source.dbo.LeaseTransaction_CreditOptionHeader ON Insight_Source.dbo.LeaseTransaction_CreditOptionHeader.LeaseTransactionID = Insight_Source.dbo.LeaseTransaction_Profile.LeaseTransactionId&#xA;  INNER JOIN Insight_Source.dbo.LeaseTransaction_CreditOptionDetail ON Insight_Source.dbo.LeaseTransaction_CreditOptionHeader.CreditOptionHeaderID = Insight_Source.dbo.LeaseTransaction_CreditOptionDetail.CreditOptionHeaderID&#xA;  INNER JOIN Migration_Intermediate..CreditProfile ICP on ICP.Number = LeaseTransaction_Profile.LeaseTransactionID&#xA;ORDER BY&#xA;  Insight_Source.dbo.LeaseTransaction_Profile.LeaseTransactionId,&#xA;  CustomerTerm,&#xA;  NumberofPayments&#xA;  --Target&#xA;SELECT&#xA;  CurrencyCodes.ISO AS Currency,&#xA;  PARTIES.PartyNumber AS CustomerNumber,&#xA;  [CreditProfiles].[Status],&#xA;  LegalEntities.LegalEntityNumber,&#xA;  [CreditProfiles].[Number],&#xA;  [RequestedAmount_Amount],&#xA;  [ApprovedAmount_Amount],&#xA;  [CustomerTerm],&#xA;  [DueDay],&#xA;  [ExpectedCommencementDate],&#xA;  [IsAdvance],&#xA;  [NumberofPayments],&#xA;  [PaymentFrequency]&#xA;INTO&#xA;  ##CreditProfileTarget&#xA;FROM&#xA;  Insight_UAT..[CreditProfiles]&#xA;  INNER JOIN Insight_UAT..Customers ON Customers.Id = [CreditProfiles].CustomerID&#xA;  INNER JOIN Insight_UAT..PARTIES ON PARTIES.Id = Customers.Id&#xA;  AND Parties.PortfolioId = 1&#xA;  INNER JOIN Insight_UAT..LegalEntities ON LegalEntities.ID = [CreditProfiles].[LegalEntityId]&#xA;  INNER JOIN Insight_UAT..Currencies on Currencies.id = [CreditProfiles].CurrencyId&#xA;  INNER JOIN Insight_UAT..CurrencyCodes on CurrencyCodes.Id = Currencies.CurrencyCodeId&#xA;  INNER JOIN Insight_UAT..[CreditApprovedStructures] on [CreditApprovedStructures].CreditProfileId = [CreditProfiles].id&#xA;ORDER BY&#xA;  cast([CreditProfiles].[Number] AS bigint),&#xA;  CustomerTerm,&#xA;  NumberofPayments&#xA;SELECT distinct&#xA;  Source.Currency S_Currency,&#xA;  Target.Currency T_Currency,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Currency, 0) &lt;&gt; ISNULL(Target.Currency, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Currency_Matched,&#xA;  Source.CustomerNumber S_CustomerNumber,&#xA;  Target.CustomerNumber T_CustomerNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerNumber, 0) &lt;&gt; ISNULL(Target.CustomerNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerNumber_Matched,&#xA;  Source.Status S_Status,&#xA;  Target.Status T_Status,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Status, 0) &lt;&gt; ISNULL(Target.Status, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Status_Matched,&#xA;  Source.LegalEntityNumber S_LegalEntityNumber,&#xA;  Target.LegalEntityNumber T_LegalEntityNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.LegalEntityNumber, 0) &lt;&gt; ISNULL(Target.LegalEntityNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LegalEntityNumber_Matched,&#xA;  Source.Number S_CreditProfileNumber,&#xA;  Target.Number T_CreditProfileNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Number, 0) &lt;&gt; ISNULL(Target.Number, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Number_Matched,&#xA;  Source.RequestedAmount_Amount S_RequestedAmount_Amount,&#xA;  Target.RequestedAmount_Amount T_RequestedAmount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.RequestedAmount_Amount, 0) &lt;&gt; ISNULL(Target.RequestedAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; RequestedAmount_Amount_Matched,&#xA;  Source.ApprovedAmount_Amount S_ApprovedAmount_Amount,&#xA;  Target.ApprovedAmount_Amount T_ApprovedAmount_Amount,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ApprovedAmount_Amount, 0) &lt;&gt; ISNULL(Target.ApprovedAmount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ApprovedAmount_Amount_Matched,&#xA;  Source.CustomerTerm S_CustomerTerm,&#xA;  Target.CustomerTerm T_CustomerTerm,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerTerm, 0) &lt;&gt; ISNULL(Target.CustomerTerm, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerTerm_Matched,&#xA;  Source.DueDay S_DueDay,&#xA;  Target.DueDay T_DueDay,&#xA;  CASE&#xA;    WHEN ISNULL(Source.DueDay, 0) &lt;&gt; ISNULL(Target.DueDay, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; DueDay_Matched,&#xA;  Source.ExpectedCommencementDate S_ExpectedCommencementDate,&#xA;  Target.ExpectedCommencementDate T_ExpectedCommencementDate,&#xA;  CASE&#xA;    WHEN ISNULL(Source.ExpectedCommencementDate, getdate()) &lt;&gt; ISNULL(Target.ExpectedCommencementDate, GETDATE()) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ExpectedCommencementDate_Matched,&#xA;  Source.IsAdvance S_IsAdvance,&#xA;  Target.IsAdvance T_IsAdvance,&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsAdvance, 0) &lt;&gt; ISNULL(Target.IsAdvance, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsAdvance_Matched,&#xA;  Source.NumberofPayments S_NumberofPayments,&#xA;  Target.NumberofPayments T_NumberofPayments,&#xA;  CASE&#xA;    WHEN ISNULL(Source.NumberofPayments, 0) &lt;&gt; ISNULL(Target.NumberofPayments, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; NumberofPayments_Matched,&#xA;  Source.PaymentFrequency S_PaymentFrequency,&#xA;  Target.PaymentFrequency T_PaymentFrequency,&#xA;  CASE&#xA;    WHEN ISNULL(Source.PaymentFrequency, 0) &lt;&gt; ISNULL(Target.PaymentFrequency, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PaymentFrequency_Matched&#xA;into&#xA;  ##CreditProfile&#xA;FROM&#xA;  ##CreditProfileSource Source&#xA;  INNER JOIN ##CreditProfileTarget Target on source.number = target.Number&#xA;  --AND source.customerterm=target.customerterm&#xA;  AND source.numberofpayments = target.numberofpayments&#xA;  AND source.ExpectedCommencementDate = target.ExpectedCommencementDate&#xA;  --AND source.number='10522'&#xA;ORDER BY&#xA;  S_creditprofilenumber DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE CreditProfileRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##CreditProfile'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript&#xA;&#xA;-- 12. CreditProfileRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.CreditProfileRecon&#xA;&#xA;--INSERT INTO&#xA;--  CreditProfileRecon&#xA;&#xA;SELECT 'CreditProfileRecon' Recon, *&#xA;INTO V5_Recon.dbo.CreditProfileRecon&#xA;FROM ##CreditProfile&#xA;&#xA;  --SELECT * FROM CreditProfileRecon&#xA;&#xA;SELECT * &#xA;FROM V5_Recon.dbo.CreditProfileRecon&#xA;&#xA;DROP TABLE IF EXISTS ##CreditProfileSource&#xA;DROP TABLE IF EXISTS ##CreditProfileTarget&#xA;DROP TABLE IF EXISTS ##CreditProfile&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
