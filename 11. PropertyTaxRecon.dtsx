      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 PropertyTaxRecon&#xA;&#xA;DROP TABLE IF EXISTS ##SourcePPT&#xA;DROP TABLE IF EXISTS ##TargetPPT&#xA;DROP TABLE IF EXISTS ##PPT&#xA;DROP TABLE IF EXISTS PropertyTaxRecon&#xA;SELECT&#xA;  Inventory_Profile.Alias AS AssetAlias,&#xA;  PropertyTax_Assessment.ReportingYear AS ReportingYear,&#xA;  PropertyTax_Assessment.BillNumber AS BillNumber,&#xA;  PropertyTax_Assessment.TaxDistrict AS TaxDistrict,&#xA;  PropertyTax_Assessment.Collector AS CollectorTitle,&#xA;  Lease_Profile.SequenceNumber AS ContractSequenceNumber,&#xA;  Currency_Index.CurrencyName AS Amount_Currency,&#xA;  Customer_Profile.AccountNumber AS CustomerPartyNumber,&#xA;  PropertyTax_Assessment.AssessedValue AS AssessedValue_Amount,&#xA;  Receivable_Sundry.Amount AS Amount_Amount,&#xA;  Receivable_Sundry.Balance AS Balance_Amount,&#xA;  Receivable_Sundry.DueDate AS DueDate,&#xA;  InvoiceGroup_ProfilePropertyTaxDetail.InvoiceGroupName AS BillToName,&#xA;  PropertyTax_Assessment.LienDate,&#xA;  Receivable_Sundry.ReceivableID AS PropertyTaxID&#xA;INTO&#xA;  ##SourcePPT&#xA;FROM&#xA;  Insight_Source..Receivable_Sundry&#xA;  INNER JOIN Insight_Source..PropertyTax_Assessment on Insight_Source..PropertyTax_Assessment.InventoryID = Insight_Source..Receivable_Sundry.InventoryID&#xA;  AND Insight_Source..PropertyTax_Assessment.PropertyTaxId = Insight_Source..Receivable_Sundry.SourceId&#xA;  INNER JOIN Insight_Source..Inventory_Profile on Insight_Source..PropertyTax_Assessment.InventoryID = Inventory_Profile.InventoryId&#xA;  INNER JOIN Insight_Source..Lease_Profile on Insight_Source..Lease_Profile.LeaseID = Insight_Source..PropertyTax_Assessment.LeaseID&#xA;  INNER JOIN Insight_Source..Lease_InventoryInLease LIL on LIL.LeaseID = Lease_Profile.LeaseID&#xA;  AND Lil.InventoryID = Inventory_Profile.InventoryID&#xA;  AND IsInLease = 1&#xA;  INNER JOIN Insight_Source..Customer_Profile on Insight_Source..Customer_Profile.CustomerID = Insight_Source..Lease_Profile.CustomerID&#xA;  INNER JOIN Insight_Source..LLC_Profile on Insight_Source..LLC_Profile.LLCID = Insight_Source..Lease_Profile.LLCID&#xA;  INNER JOIN Insight_Source..Currency_Index ON LLC_Profile.CurrencyIndexID = Currency_Index.CurrencyIndexID&#xA;  INNER JOIN Insight_Source.dbo.InvoiceGroup_Profile InvoiceGroup_ProfilePropertyTaxDetail ON Insight_Source.dbo.Receivable_Sundry.InvoiceGroupId = InvoiceGroup_ProfilePropertyTaxDetail.InvoiceGroupId&#xA;WHERE&#xA;  Receivable_Sundry.ReceivableTypeID IN (7)&#xA;  AND Receivable_Sundry.EntityTypeId = 5&#xA;  AND Receivable_Sundry.IsActive = 1&#xA;  AND Lease_Profile.StatusId = 2&#xA;  AND Insight_Source..PropertyTax_Assessment.LeaseID = Insight_Source..Receivable_Sundry.EntityId&#xA;  AND Insight_Source..PropertyTax_Assessment.ReversalPostDate IS NULL&#xA;  AND Insight_Source..PropertyTax_Assessment.ReversalJournalID IS NULL&#xA;  AND PropertyTax_Assessment.Amount = Receivable_Sundry.Amount&#xA;  AND YEAR(PropertyTax_Assessment.LienDate) = YEAR(Receivable_Sundry.DueDate)&#xA;  AND (&#xA;    (&#xA;      Receivable_Sundry.Balance &gt; 0&#xA;      AND Receivable_Sundry.PostDate &lt; '2025-01-01'&#xA;    )&#xA;    OR Receivable_Sundry.PostDate &gt;= '2025-01-01'&#xA;  )&#xA;  AND Inventory_Profile.InventoryStatusID IN (6)&#xA;  AND PropertyTax_Assessment.AssessedValue &gt; 0&#xA;  AND Receivable_Sundry.Amount &gt; 0&#xA;  --Target&#xA;SELECT&#xA;  Assets.Alias AS AssetAlias,&#xA;  PPT.ReportingYear AS ReportingYear,&#xA;  PPT.BillNumber AS BillNumber,&#xA;  PPT.TaxDistrict AS TaxDistrict,&#xA;  PPT.CollectorTitle AS CollectorTitle,&#xA;  CTS.SequenceNumber AS ContractSequenceNumber,&#xA;  PPT.PropertyTaxAmount_Currency AS Amount_Currency,&#xA;  PAR.PartyNumber AS CustomerPartyNumber,&#xA;  PPTDetails.AssessedValue_Amount AS AssessedValue_Amount,&#xA;  PPTDetails.Amount_Amount AS Amount_Amount,&#xA;  R.TotalBalance_Amount AS Balance_Amount,&#xA;  PPT.DueDate AS DueDate,&#xA;  BTO.BillToName AS BillToName,&#xA;  cast(&#xA;    right(&#xA;      UniqueIdentifier,&#xA;      charindex('-', reverse(UniqueIdentifier)) - 1&#xA;    ) AS bigint&#xA;  ) AS PropertyTaxId&#xA;INTO&#xA;  ##TargetPPT&#xA;FROM&#xA;  Insight_UAT..Assets Assets&#xA;  JOIN Insight_UAT..PropertyTaxDetails PPTDetails ON Assets.id = PPTDetails.AssetId&#xA;  JOIN Insight_UAT..PropertyTaxes PPT ON PPT.id = PPTDetails.PropertyTaxId&#xA;  JOIN Insight_UAT..Contracts CTS ON CTS.id = PPT.ContractId&#xA;  JOIN Insight_UAT..LeaseFinances LFS ON LFS.ContractId = CTS.id&#xA;  JOIN Insight_UAT..Customers CUS ON CUS.Id = LFS.CustomerId&#xA;  JOIN Insight_UAT..Parties PAR ON CUS.Id = PAR.Id&#xA;  JOIN Insight_UAT..BillToes BTO ON PPTDetails.BillToId = BTO.Id&#xA;  JOIN Insight_UAT..Receivables R on R.SourceId = PPT.Id&#xA;  AND R.SourceTable = 'PropertyTax'&#xA;SELECT&#xA;  ##SourcePPT.AssetAlias AS 'S_Alias',&#xA;  ##TargetPPT.AssetAlias AS 'T_Alias',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.AssetAlias, 0) &lt;&gt; ISNULL(##TargetPPT.AssetAlias, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AssetAlias_Matched,&#xA;  ##SourcePPT.ReportingYear AS 'S_ReportingYear',&#xA;  ##TargetPPT.ReportingYear AS 'T_ReportingYear',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.ReportingYear, 0) &lt;&gt; ISNULL(##TargetPPT.ReportingYear, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ReportingYear_Matched,&#xA;  ##SourcePPT.BillNumber AS 'S_BillNumber',&#xA;  ##TargetPPT.BillNumber AS 'T_BillNumber',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.BillNumber, 0) &lt;&gt; ISNULL(##TargetPPT.BillNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; BillNumber_Matched,&#xA;  ##SourcePPT.TaxDistrict AS 'S_TaxDistrict',&#xA;  ##TargetPPT.TaxDistrict AS 'T_TaxDistrict',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.TaxDistrict, 0) &lt;&gt; ISNULL(##TargetPPT.TaxDistrict, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; TaxDistrict_Matched,&#xA;  ##SourcePPT.CollectorTitle AS 'S_CollectorTitle',&#xA;  ##TargetPPT.CollectorTitle AS 'T_CollectorTitle',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.CollectorTitle, 0) &lt;&gt; ISNULL(##TargetPPT.CollectorTitle, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CollectorTitle_Matched,&#xA;  ##SourcePPT.ContractSequenceNumber AS 'S_ContractSequenceNumber',&#xA;  ##TargetPPT.ContractSequenceNumber AS 'T_ContractSequenceNumber',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.ContractSequenceNumber, 0) &lt;&gt; ISNULL(##TargetPPT.ContractSequenceNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ContractSequenceNumber_Matched,&#xA;  ##SourcePPT.CustomerPartyNumber AS 'S_CustomerPartyNumber',&#xA;  ##TargetPPT.CustomerPartyNumber AS 'T_CustomerPartyNumber',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.CustomerPartyNumber, 0) &lt;&gt; ISNULL(##TargetPPT.CustomerPartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerPartyNumber_Matched,&#xA;  ##SourcePPT.Amount_Currency AS 'S_Amount_Currency',&#xA;  ##TargetPPT.Amount_Currency AS 'T_Amount_Currency',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.Amount_Currency, 0) &lt;&gt; ISNULL(##TargetPPT.Amount_Currency, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Amount_Currency_Matched,&#xA;  ##SourcePPT.AssessedValue_Amount AS 'S_AssessedValue_Amount',&#xA;  ##TargetPPT.AssessedValue_Amount AS 'T_AssessedValue_Amount',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.AssessedValue_Amount, 0) &lt;&gt; ISNULL(##TargetPPT.AssessedValue_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AssessedValue_Amount_Matched,&#xA;  ##SourcePPT.Amount_Amount AS 'S_Amount_Amount',&#xA;  ##TargetPPT.Amount_Amount AS 'T_Amount_Amount',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.Amount_Amount, 0) &lt;&gt; ISNULL(##TargetPPT.Amount_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Amount_Amount_Matched,&#xA;  ##SourcePPT.Balance_Amount AS 'S_Balance_Amount',&#xA;  ##TargetPPT.Balance_Amount AS 'T_Balance_Amount',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.Balance_Amount, 0) &lt;&gt; ISNULL(##TargetPPT.Balance_Amount, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Balance_Amount_Matched,&#xA;  ##SourcePPT.DueDate AS 'S_DueDate',&#xA;  ##TargetPPT.DueDate AS 'T_DueDate',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.DueDate, '1900-01-01') &lt;&gt; ISNULL(##TargetPPT.DueDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; DueDate_Matched,&#xA;  ##SourcePPT.BillToName AS 'S_BillToName',&#xA;  ##TargetPPT.BillToName AS 'T_BillToName',&#xA;  CASE&#xA;    WHEN ISNULL(##SourcePPT.BillToName, 0) &lt;&gt; ISNULL(##TargetPPT.BillToName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; BillToName_Matched&#xA;into&#xA;  ##PPT&#xA;FROM&#xA;  ##SourcePPT&#xA;  LEFT JOIN ##TargetPPT on ##SourcePPT.PropertyTaxID = ##TargetPPT.PropertyTaxId DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE PropertyTaxRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##PPT'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript&#xA;&#xA;-- 11. PropertyTaxRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.PropertyTaxRecon&#xA;&#xA;--INSERT INTO&#xA;--  PropertyTaxRecon&#xA;&#xA;SELECT 'PropertyTaxRecon' Recon, *&#xA;INTO V5_Recon.dbo.PropertyTaxRecon&#xA;FROM ##PPT&#xA;&#xA;  --SELECT * FROM PropertyTaxRecon&#xA;&#xA;SELECT * &#xA;FROM V5_Recon.dbo.PropertyTaxRecon&#xA;&#xA;DROP TABLE IF EXISTS ##SourcePPT&#xA;DROP TABLE IF EXISTS ##TargetPPT&#xA;DROP TABLE IF EXISTS ##PPT&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
