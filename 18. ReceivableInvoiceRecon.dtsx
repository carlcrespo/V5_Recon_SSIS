  DTS:VersionBuild="3"
  DTS:VersionGUID="{23424E1F-7BC9-47E6-999C-5F20BC8B0541}">
  <DTS:Property
    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\18 ReceivableInvoiceRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{1DEFB63E-AC6E-4716-A8AC-3D705D7C2420}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="18 ReceivableInvoiceRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250930 InvoiceRecon&#xA;&#xA;DROP TABLE IF EXISTS ##InvoiceSource&#xA;DROP TABLE IF EXISTS ##InvoiceTarget&#xA;DROP TABLE IF EXISTS ##InvoiceRecon&#xA;DROP TABLE IF EXISTS InvoiceRecon&#xA;DROP TABLE IF EXISTS #OTPAR&#xA;DROP TABLE IF EXISTS #Lw4LeaseDetails&#xA; &#xA;&#xA;SELECT LP.LeaseID&#xA;&#x9;,LIL.InventoryID&#xA;&#x9;,LPH.ReceivableHeaderID&#xA;&#x9;,LPD.InvoiceID&#xA;&#x9;,Duedate&#xA;&#x9;,CASE &#xA;&#x9;&#x9;WHEN Li.AccountingTreatmentTypeId = 4&#xA;&#x9;&#x9;&#x9;THEN 'OperatingLeaseRental'&#xA;&#x9;&#x9;WHEN Li.AccountingTreatmentTypeId != 4&#xA;&#x9;&#x9;&#x9;THEN 'CapitalLeaseRental'&#xA;&#x9;&#x9;END AS ReceivableType&#xA;&#x9;,LP.CustomerID&#xA;&#x9;,LP.LLCID&#xA;&#x9;,'FixedTerm' AS IncomeType&#xA;&#x9;,LPD.ReceivableID&#xA;INTO #Lw4LeaseDetails&#xA;FROM Insight_Source..Lease_profile LP&#xA;JOIN Insight_Source..Lease_Investment LI ON LI.LeaseId = LP.LeaseID&#xA;&#x9;AND LI.IsActive = 1&#xA;JOIN Insight_Source..Receivable_LeasePaymentHeader LPH ON LPH.LeaseID = LP.LeaseID&#xA;JOIN Insight_Source..Receivable_LeasePaymentDetail LPD ON LPH.ReceivableHeaderID = LPD.ReceivableHeaderID&#xA;&#x9;AND LPD.ReceivableAdjustmentID IS NULL&#xA;&#x9;AND LPD.IsDummy = 0&#xA;JOIN Insight_Source..Lease_InventoryInLease LIL ON LIL.LeaseID = LP.LeaseID&#xA;&#x9;AND LIL.InventoryID = LPD.InventoryID&#xA;&#xA;WHERE LP.StatusId = 2&#xA;&#x9;AND LIL.IsInLease = 1&#xA;&#x9;AND LPH.IsActive = 1&#xA;&#x9;AND LPH.PaymentNumber &gt; 0&#xA;&#x9;AND InvoiceId IS NOT NULL&#xA;&#x9;AND lph.DueDate &gt;= (&#xA;&#x9;&#x9;SELECT DATE&#xA;&#x9;&#x9;FROM Migration_Intermediate..TransactionDate&#xA;&#x9;&#x9;)&#xA;&#xA;GROUP BY LP.LeaseID&#xA;&#x9;,LIL.InventoryID&#xA;&#x9;,LPH.ReceivableHeaderID&#xA;&#x9;,LPD.InvoiceID&#xA;&#x9;,LPH.Duedate&#xA;&#x9;,Li.AccountingTreatmentTypeId&#xA;&#x9;,LP.CustomerID&#xA;&#x9;,LP.LLCID&#xA;&#x9;,LPD.ReceivableID&#xA;&#xA;UNION&#xA;&#xA;SELECT LP.LeaseID&#xA;&#x9;,LIL.InventoryID&#xA;&#x9;,LPH.ReceivableHeaderID&#xA;&#x9;,LPD.InvoiceID&#xA;&#x9;,Duedate&#xA;&#x9;,CASE&#xA;&#x9;&#x9;WHEN LPH.ReceivableTypeID = 2 THEN 'InterimRental'&#xA;&#x9;&#x9;WHEN LPH.ReceivableTypeID = 3 THEN 'OverTermRental'&#xA;&#x9;&#x9;WHEN LPH.ReceivableTypeID = 26 THEN 'LeaseInterimInterest'&#xA;  &#xA;&#x9;END&#xA;&#x9;AS ReceivableType&#xA;&#x9;,LP.CustomerID&#xA;&#x9;,LP.LLCID&#xA;&#x9;,CASE &#xA;&#x9;&#x9;WHEN LPH.ReceivableTypeID = 2&#xA;&#x9;&#x9;&#x9;THEN 'InterimRent'&#xA;&#x9;&#x9;WHEN LPH.ReceivableTypeID = 3&#xA;&#x9;&#x9;&#x9;THEN 'OTP'&#xA;&#x9;&#x9;WHEN LPH.ReceivableTypeID = 26&#xA;&#x9;&#x9;&#x9;THEN 'InterimInterest'&#xA;&#x9;&#x9;END AS IncomeType&#xA;&#x9;,LPD.ReceivableID&#xA;FROM Insight_Source..Lease_profile LP&#xA;JOIN Insight_Source..Lease_Investment LI ON LI.LeaseId = LP.LeaseID&#xA;&#x9;AND LI.IsActive = 1&#xA;JOIN Insight_Source..Receivable_OtherPaymentHeader LPH ON LPH.LeaseID = LP.LeaseID&#xA;JOIN Insight_Source..Receivable_OtherPaymentDetail LPD ON LPH.ReceivableHeaderID = LPD.ReceivableHeaderID&#xA;&#x9;AND LPD.ReceivableAdjustmentID IS NULL&#xA;&#x9;AND LPD.IsDummy = 0&#xA;JOIN Insight_Source..Lease_InventoryInLease LIL ON LIL.LeaseID = LP.LeaseID&#xA;&#x9;AND LIL.InventoryID = LPD.InventoryID&#xA;INNER JOIN Insight_UAT..Assets A on A.Id = LIL.InventoryID&#xA;WHERE LP.StatusId = 2&#xA;&#x9;AND ( A.FinancialType='Deposit'   or LIL.IsInLease=1)&#xA;&#x9;AND LPH.IsActive = 1&#xA;&#x9;AND InvoiceId IS NOT NULL&#xA;&#x9;AND lph.DueDate &gt;= (&#xA;&#x9;&#x9;SELECT DATE&#xA;&#x9;&#x9;FROM Migration_Intermediate..TransactionDate&#xA;&#x9;&#x9;)&#xA;GROUP BY LP.LeaseID&#xA;&#x9;,LIL.InventoryID&#xA;&#x9;,LPH.ReceivableHeaderID&#xA;&#x9;,LPD.InvoiceID&#xA;&#x9;,LPH.Duedate&#xA;&#x9;,Li.AccountingTreatmentTypeId&#xA;&#x9;,LP.CustomerID&#xA;&#x9;,LP.LLCID&#xA;&#x9;,LPH.ReceivableTypeID&#xA;&#x9;,LPD.ReceivableID&#xA;&#xA;&#x9; &#xA;&#xA;&#x9;&#xA;&#x9; --Source&#xA;&#x9; SELECT IR.CustomerID&#xA;&#x9;,Invoice_Number.InvoiceNumber&#xA;&#x9;,InvoiceGroup_profile.InvoiceGroupName&#xA;&#x9;,IR.LLCID&#xA;&#x9;,CAST(Invoice_Header.DueDate AS DATE) AS InvoiceDueDate&#xA;&#x9;,CAST(IR.DueDate AS DATE) AS ReceivableDuedate&#xA;&#x9;,SUM(Invoice_ReceivableDetail.Amount) AS InvoiceAmount&#xA;&#x9;,CAST(CurrencyView.Currency AS NVARCHAR(3)) AS InvoiceAmount_Currency&#xA;&#x9;,SUM(Invoice_ReceivableDetail.TaxAmount) AS InvoiceTaxAmount&#xA;&#x9;,Invoice_BatchHeader.RunDate AS InvoiceRunDate&#xA;&#x9;,Customer_Profile.AccountNumber AS AccountNumber&#xA;&#x9;&#xA;INTO ##InvoiceSource&#xA;FROM #Lw4LeaseDetails IR&#xA;INNER JOIN Insight_Source.dbo.Customer_Profile  ON IR.CustomerID = Customer_Profile.CustomerID&#xA;JOIN Insight_Source..Invoice_Header ON IR.InvoiceID = Invoice_Header.InvoiceID&#xA;&#x9;AND InvoiceStatusID = 1&#xA;JOIN Insight_Source.dbo.CurrencyView  ON  IR.LLCID = CurrencyView.LLCID&#xA;JOIN Insight_Source..Invoice_BatchHeader ON Invoice_Header.InvoiceBatchID = Invoice_BatchHeader.InvoiceBatchID&#xA;JOIN Insight_Source..InvoiceGroup_profile ON Invoice_Header.InvoiceGroupID = InvoiceGroup_profile.InvoiceGroupID&#xA;JOIN Insight_Source..Invoice_Number ON Invoice_Header.InvoiceNumberID = Invoice_Number.InvoiceNumberID&#xA;JOIN Insight_Source..Invoice_DealDetail ON Invoice_DealDetail.InvoiceID = Invoice_Header.InvoiceID&#xA;&#x9;AND EntityTypeID = 5&#xA;JOIN Insight_Source..Invoice_ReceivableDetail ON Invoice_DealDetail.InvoiceDealDetailID = Invoice_ReceivableDetail.InvoiceDealDetailID&#xA;&#x9;AND IR.ReceivableID = Invoice_ReceivableDetail.ReceivableID&#xA;WHERE (&#xA;&#x9;&#x9;Invoice_ReceivableDetail.ReceivableTypeID IN (&#xA;&#x9;&#x9;&#x9;2&#xA;&#x9;&#x9;&#x9;,3&#xA;&#x9;&#x9;&#x9;,26&#xA;&#x9;&#x9;&#x9;)&#xA;&#x9;&#x9;AND IR.IncomeType IN (&#xA;&#x9;&#x9;&#x9;'InterimInterest'&#xA;&#x9;&#x9;&#x9;,'InterimRent'&#xA;&#x9;&#x9;&#x9;,'OTP'&#xA;&#x9;&#x9;&#x9;)&#xA;&#x9;&#x9;)&#xA;&#x9;OR (&#xA;&#x9;&#x9;Invoice_ReceivableDetail.ReceivableTypeID = 1&#xA;&#x9;&#x9;AND IR.IncomeType = 'FixedTerm'&#xA;&#x9;&#x9;)&#xA;GROUP BY IR.CustomerID&#xA;&#x9; &#xA;&#x9; ,CurrencyView.Currency&#xA;&#x9;,IR.LLCID&#xA;&#x9;,Invoice_Number.InvoiceNumber&#xA;&#x9;,InvoiceGroup_profile.InvoiceGroupName&#xA;&#x9;,Invoice_BatchHeader.RunDate&#xA;&#x9;,Invoice_Header.DueDate&#xA;&#x9;,IR.DueDate&#xA;&#x9;,Invoice_Header.InvoiceGroupID&#xA;&#x9;,Customer_Profile.AccountNumber&#xA;&#x9;--Target&#xA;&#x9;&#xA;SELECT&#xA;  Parties.PartyNumber,&#xA;  ReceivableInvoices.Number InvoiceNumber,&#xA;  BillToes.BillToName,&#xA;  ReceivableInvoices.InvoiceAmount_Currency,&#xA;  ReceivableInvoices.DueDate,&#xA;  SUM(ReceivableInvoiceDetails.InvoiceAmount_Amount) AS InvoiceAmount_Amount,&#xA;  SUM(ReceivableInvoiceDetails.InvoiceTaxAmount_Amount) AS InvoiceTaxAmount_Amount&#xA;INTO&#xA;  ##InvoiceTarget&#xA;FROM&#xA;  Insight_UAT..ReceivableInvoices&#xA;  JOIN Insight_UAT..ReceivableInvoiceDetails on ReceivableInvoices.Id = ReceivableInvoiceDetails.ReceivableInvoiceId&#xA;  JOIN Insight_UAT..Receivables R on R.Id = ReceivableInvoiceDetails.ReceivableId and R.IsActive=1 and R.IncomeType &lt;&gt;'_'&#xA;  JOIN Insight_UAT..Parties ON ReceivableInvoices.CustomerId = Parties.Id&#xA;  JOIN Insight_UAT..BillToes ON ReceivableInvoices.BillToId = BillToes.Id&#xA;  JOIN Insight_UAT..LegalEntities ON ReceivableInvoices.LegalEntityId = LegalEntities.Id --AND LegalEntities.BusinessUnitId = 2&#xA;WHERE&#xA;  R.DueDate&gt;=(Select Top 1 Date From Migration_Intermediate..TransactionDate) AND&#xA;  ReceivableInvoices.Number LIKE '%R%'&#xA;  GROUP BY &#xA;  Parties.PartyNumber,&#xA;  ReceivableInvoices.Number ,&#xA;  BillToes.BillToName,&#xA;  ReceivableInvoices.InvoiceAmount_Currency,&#xA;  ReceivableInvoices.DueDate&#xA;&#xA;&#xA;SELECT&#xA;  ##InvoiceSource.AccountNumber AS 'S_AccountNumber',&#xA;  ##InvoiceTarget.PartyNumber AS 'T_PartyNumber',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.AccountNumber, '') &lt;&gt; ISNULL(##InvoiceTarget.PartyNumber, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  ##InvoiceSource.InvoiceNumber AS 'S_InvoiceNumber',&#xA;  ##InvoiceTarget.InvoiceNumber AS 'T_InvoiceNumber',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.InvoiceNumber, '') &lt;&gt; ISNULL(##InvoiceTarget.InvoiceNumber, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceNumber_Matched,&#xA;  ##InvoiceSource.InvoiceGroupName AS 'S_BillToName',&#xA;  ##InvoiceTarget.BillToName AS 'T_BillToName',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.InvoiceGroupName, '') &lt;&gt; ISNULL(##InvoiceTarget.BillToName, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; BillToName_Matched,&#xA;  ##InvoiceSource.InvoiceAmount_Currency AS 'S_InvoiceAmount_Currency',&#xA;  ##InvoiceTarget.InvoiceAmount_Currency AS 'T_InvoiceAmount_Currency',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.InvoiceAmount_Currency, '') &lt;&gt; ISNULL(##InvoiceTarget.InvoiceAmount_Currency, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceAmount_Currency_Matched,&#xA;  ##InvoiceSource.InvoiceDueDate AS 'S_DueDate',&#xA;  ##InvoiceTarget.DueDate AS 'T_DueDate',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.InvoiceDueDate, '') &lt;&gt; ISNULL(##InvoiceTarget.DueDate, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; DueDate_Matched,&#xA;  ##InvoiceSource.InvoiceAmount AS 'S_InvoiceAmount',&#xA;  ##InvoiceTarget.InvoiceAmount_Amount AS 'T_InvoiceAmount_Amount',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.InvoiceAmount, '') &lt;&gt; ISNULL(##InvoiceTarget.InvoiceAmount_Amount, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceAmount_Amount_Matched,&#xA;  ##InvoiceSource.InvoiceTaxAmount AS 'S_InvoiceTaxAmount',&#xA;  ##InvoiceTarget.InvoiceTaxAmount_Amount AS 'T_InvoiceTaxAmount_Amount',&#xA;  CASE&#xA;    WHEN ISNULL(##InvoiceSource.InvoiceTaxAmount, '') &lt;&gt; ISNULL(##InvoiceTarget.InvoiceTaxAmount_Amount, '') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceTaxAmount_Amount_Matched&#xA;INTO ##InvoiceRecon&#xA;FROM&#xA;  ##InvoiceSource&#xA;  JOIN ##InvoiceTarget ON ##InvoiceSource.InvoiceNumber = ##InvoiceTarget.InvoiceNumber&#xA;  &#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE InvoiceRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##InvoiceRecon'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_EXECutesql @CreateTableScript&#xA;&#xA;-- 18. ReceivableInvoiceRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.InvoiceRecon&#xA;&#xA;--INSERT INTO&#xA;--  InvoiceRecon&#xA;&#xA;SELECT 'InvoiceRecon' Recon, *&#xA;INTO V5_Recon.dbo.InvoiceRecon&#xA;FROM ##InvoiceRecon&#xA;&#xA;--SELECT&#xA;--  *&#xA;--FROM&#xA;--  InvoiceRecon&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.InvoiceRecon&#xA;&#xA;DROP TABLE IF EXISTS ##InvoiceSource&#xA;DROP TABLE IF EXISTS ##InvoiceTarget&#xA;GO&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
