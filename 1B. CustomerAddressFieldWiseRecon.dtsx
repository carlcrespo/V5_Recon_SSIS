  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\1B CustomerAddressFieldWiseRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{24D12C9D-5F5D-4200-8A39-A97F5EFB007A}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="1B CustomerAddressFieldWiseRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 CustomerAddressRecon&#xA;DROP TABLE IF EXISTS ##CustomerAddressSource&#xA;DROP TABLE IF EXISTS ##CustomerAddressTarget&#xA;DROP TABLE IF EXISTS ##CustomerAddress&#xA;DROP TABLE IF EXISTS CustomerAddressRecon&#xA;--Source&#xA;SELECT&#xA;  CP.AccountNumber 'PartyNumber',&#xA;  ca.ContactAddressId 'UniqueIdentifier',&#xA;  TRIM(ca.Address) 'AddressLine1',&#xA;  IIF(LTRIM(ca.Address2) = '', NULL, LTRIM(ca.Address2)) 'AddressLine2',&#xA;  ca.City,&#xA;  IIF(ca.County = '', NULL, ca.County) 'County',&#xA;  IIF(ca.ZIP = '', NULL, TRIM(CA.ZIP)) 'PostalCode',&#xA;  ca.Description,&#xA;  ca.IsMainAddress 'IsMain',&#xA;(CASE WHEN SSCM.StateID IS NOT NULL THEN SSCM.LW5StateShortName&#xA;&#x9;&#x9;ELSE StateShortName&#xA;&#x9;&#x9;END) AS State,&#xA;  ca.CountryShortCode as Country,&#xA;  ca.IsForDocumentation,&#xA;  ca.EntityId 'PartyId'&#xA;INTO&#xA;  ##CustomerAddressSource&#xA;FROM&#xA;  Insight_Source..ContactAddressView ca&#xA;  INNER JOIN Insight_Source..Contact_Address c ON ca.ContactAddressID = c.ContactAddressID&#xA;  INNER JOIN Insight_Source..Customer_Profile CP ON CP.CustomerId = ca.EntityId&#xA;  LEFT JOIN Migration_Intermediate.dbo.StatesShortCodeMapping SSCM on SSCM.StateID = ca.StateID&#xA;  AND CP.customerstatusid = 1&#xA;WHERE&#xA;  ca.EntityTypeId = 1&#xA;  AND c.IsActive = 1&#xA;  --Target&#xA;SELECT&#xA;  p.PartyNumber,&#xA;  pa.UNIQUEIDENTIFIER,&#xA;  TRIM(pa.AddressLine1) AS AddressLine1,&#xA;  pa.AddressLine2,&#xA;  pa.City,&#xA;  pa.Division 'County',&#xA;  tRIM(pa.PostalCode) AS PostalCode,&#xA;  pa.Description,&#xA;  pa.IsMain,&#xA;  s.ShortName as State,&#xA;  cc.ShortName as Country,&#xA;  pa.IsForDocumentation,&#xA;  pa.PartyId&#xA;INTO&#xA;  ##CustomerAddressTarget&#xA;FROM&#xA;  Insight_UAT..Partyaddresses pa&#xA;  INNER JOIN Insight_UAT..Parties p ON pa.PartyId = p.Id&#xA;  INNER JOIN Insight_UAT..Customers c ON c.Id = p.Id&#xA;  AND p.PortfolioId = 1&#xA;  INNER JOIN Insight_UAT..States s ON s.Id = pa.StateId&#xA;  INNER JOIN Insight_UAT..Countries cc on cc.id = s.countryid&#xA;  --Recon&#xA;SELECT&#xA;  source.PartyNumber AS 'S_PartyNumber',&#xA;  target.PartyNumber AS 'T_PartyNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PartyNumber, 0) &lt;&gt; ISNULL(Target.PartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  source.UNIQUEIDENTIFIER AS 'S_UniqueIdentifier',&#xA;  target.UNIQUEIDENTIFIER AS 'T_UniqueIdentifier',&#xA;  CASE&#xA;    WHEN ISNULL(Source.UNIQUEIDENTIFIER, 0) &lt;&gt; ISNULL(Target.UNIQUEIDENTIFIER, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; UniqueIdentifier_Matched,&#xA;  source.AddressLine1 AS 'S_AddressLine1',&#xA;  target.AddressLine1 AS 'T_AddressLine1',&#xA;  CASE&#xA;    WHEN ISNULL(Source.AddressLine1, 0) &lt;&gt; ISNULL(Target.AddressLine1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AddressLine1_Matched,&#xA;  source.AddressLine2 AS 'S_AddressLine2',&#xA;  target.AddressLine2 AS 'T_AddressLine2',&#xA;  CASE&#xA;    WHEN ISNULL(Source.AddressLine2, 0) &lt;&gt; ISNULL(Target.AddressLine2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AddressLine2_Matched,&#xA;  source.City AS 'S_City',&#xA;  target.City AS 'T_City',&#xA;  CASE&#xA;    WHEN ISNULL(Source.City, 0) &lt;&gt; ISNULL(Target.City, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; City_Matched,&#xA;  source.County AS 'S_County',&#xA;  target.County 'T_County',&#xA;  CASE&#xA;    WHEN ISNULL(Source.County, 0) &lt;&gt; ISNULL(Target.County, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; County_Matched,&#xA;  source.PostalCode AS 'S_PostalCode',&#xA;  target.PostalCode AS 'T_PostalCode',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PostalCode, 0) &lt;&gt; ISNULL(Target.PostalCode, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PostalCode_Matched,&#xA;  source.Description AS 'S_Description',&#xA;  target.Description AS 'T_Description',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Description, 0) &lt;&gt; ISNULL(Target.Description, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Description_Matched,&#xA;  source.IsMain AS 'S_IsMain',&#xA;  target.IsMain AS 'T_IsMain',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsMain, 0) &lt;&gt; ISNULL(Target.IsMain, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsMain_Matched,&#xA;  source.State AS 'S_State',&#xA;  target.State AS 'T_State',&#xA;  CASE&#xA;    WHEN ISNULL(Source.State, 0) &lt;&gt; ISNULL(Target.State, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; State_Matched,&#xA;  source.Country AS 'S_Country',&#xA;  target.Country AS 'T_Country',&#xA;  CASE&#xA;    WHEN ISNULL(Source.Country, 0) &lt;&gt; ISNULL(Target.Country, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Country_Matched,&#xA;  source.IsForDocumentation AS 'S_IsForDocumentation',&#xA;  target.IsForDocumentation AS 'T_IsForDocumentation',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsForDocumentation, 0) &lt;&gt; ISNULL(Target.IsForDocumentation, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsForDocumentation_Matched&#xA;INTO&#xA;  ##CustomerAddress&#xA;FROM&#xA;  ##CustomerAddressSource source&#xA;  INNER JOIN ##CustomerAddressTarget target ON source.PartyNumber = target.PartyNumber&#xA;  AND source.UNIQUEIDENTIFIER = target.UNIQUEIDENTIFIER&#xA;  AND source.PartyNumber = target.PartyNumber &#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE CustomerAddressRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##CustomerAddress'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_Executesql @CreateTableScript&#xA;&#xA;-- 1B. CustomerAddressFieldWiseRecon&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.CustomerAddressRecon&#xA;&#xA;--INSERT INTO&#xA;  --CustomerAddressRecon&#xA;&#xA;SELECT 'CustomerAddressRecon' Recon, *&#xA;INTO V5_Recon.dbo.CustomerAddressRecon&#xA;FROM   ##CustomerAddress&#xA;&#xA;--SELECT * FROM CustomerAddressRecon&#xA;SELECT *&#xA;FROM V5_Recon.dbo.CustomerAddressRecon&#xA;&#xA;DROP TABLE IF EXISTS ##CustomerAddressSource&#xA;DROP TABLE IF EXISTS ##CustomerAddressTarget&#xA;DROP TABLE IF EXISTS ##CustomerAddress&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
