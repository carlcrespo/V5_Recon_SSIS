  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\15A DiscountingSource"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F87F995E-4533-4271-9EEF-A84767868E96}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="15A DiscountingSource"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 15A. DiscountingSource_20250929.sql&#xA;&#xA;--CREATE OR ALTER PROC [dbo].[SourceDiscountingsRecon]&#xA;--AS&#xA;--BEGIN&#xA;&#xA;DECLARE @MigrationCutoffDate DATE = (SELECT TOP (1) Date FROM Migration_Intermediate..Transactiondate)&#xA;DROP TABLE IF EXISTS #SourceDiscountingDetails&#xA;DROP TABLE IF EXISTS #LastPaymentDueDate&#xA;DROP TABLE IF EXISTS #DiscountTemp&#xA;DROP TABLE IF EXISTS #DiscountingAmort&#xA;DROP TABLE IF EXISTS #DiscountingAmortSummary&#xA;DROP TABLE IF EXISTS #DiscountingAmortDetail&#xA;DROP TABLE IF EXISTS #DiscountingAmortDetailSummary&#xA;SELECT&#xA;  max(discountloanid) MaxDiscountId,&#xA;  entityid&#xA;into&#xA;  #DiscountTemp&#xA;FROM&#xA;  Insight_Source..DiscountLoan_Deal d&#xA;  JOIN Insight_Source..lease_profile lp on lp.leaseid = d.entityid&#xA;  AND entitytypeid = 5&#xA;  AND lp.statusid = 2&#xA;  AND (&#xA;    deactivatedreasonid = 4&#xA;    OR isactive = 1&#xA;  )&#xA;  AND d.bookingstatusid = 2&#xA;GROUP BY&#xA;  entityid&#xA;&#xA;&#x9;CREATE TABLE #SourceDiscountingDetails&#xA;&#x9;(&#xA;&#x9;&#x9;DiscountLoanID bigint,&#xA;&#x9;&#x9;DiscountLoanFSId bigint,&#xA;&#x9;&#x9;FunderId bigint,&#xA;&#xA;&#x9;&#x9;S_AssociatedLeaseSequenceNumber nvarchar(max),&#xA;&#x9;&#x9;S_DiscountingSequenceNumber nvarchar(max),&#xA;&#x9;&#x9;S_LoanNumber nvarchar(max),&#xA;&#x9;&#x9;S_FundingSourceNumber nvarchar(50),&#xA;&#x9;&#x9;S_FundingSource nvarchar(max),&#xA;&#x9;&#x9;S_BookingStatus nvarchar(max),&#xA;&#x9;&#x9;S_RepaymentFrequency nvarchar(max),&#xA;&#x9;&#x9;S_IsAutoPaymentAllowed bit,&#xA;&#x9;&#x9;S_DiscountRate decimal(14,9) DEFAULT (0),&#xA;&#x9;&#x9;S_DueDay Int,&#xA;&#x9;&#x9;S_Advance Bit,&#xA;&#x9;&#x9;S_CompoundingFrequency NVarChar(13) NULL,&#xA;&#x9;&#x9;S_CommencementDate datetime,&#xA;&#x9;&#x9;S_MaturityDate datetime,&#xA;&#x9;&#x9;S_ProcessThroughDate datetime,&#xA;&#x9;&#x9;S_LoanAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_TotalPaymentAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingPaymentAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_TotalPrincipalAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingPrincipalAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_TotalInterestAccrualAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_AccumulatedInterestAccrualAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingInterestAccrualAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_DebtFinancingCostAmount  decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_AccumulatedDebtFinancingCostAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingDebtFinancingCostAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_Currency Nvarchar(40) NULL,&#xA;&#x9;&#x9;S_LastPaymentDueDate datetime,&#xA;&#x9;&#x9;S_AccruedInterestBalance decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_LegalEntityNumber Nvarchar(40) NULL,&#xA;&#x9;&#x9;S_LoanDate DateTime,&#xA;&#x9;&#x9;S_NetTermBasis Nvarchar(6) ,&#xA;&#x9;&#x9;S_NetTerms INT,&#xA;&#x9;&#x9;S_TValueComputeMethod Nvarchar(8),&#xA;&#x9;&#x9;S_TValueDateCounting  Nvarchar(13),&#xA;&#x9;&#x9;S_RRPPaymentsFrom INT,&#xA;&#x9;&#x9;S_RRPPaymentFrequency  Nvarchar(13),&#xA;&#x9;&#x9;S_RRPRegularPaymentAmount_Amount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_PerfectPayPool BIT&#xA;&#xA;&#xA;&#x9;) &#xA;&#xA;&#x9;INSERT INTO #SourceDiscountingDetails&#xA;&#x9;(&#xA;&#x9;&#x9;DiscountLoanID&#xA;&#x9; &#xA;&#x9;&#x9;,S_IsAutoPaymentAllowed&#xA;&#xA;&#x9;&#x9;,S_RepaymentFrequency&#xA;&#x9;&#x9;,S_BookingStatus&#xA;&#x9;&#x9;,S_AssociatedLeaseSequenceNumber&#xA;&#x9;&#x9;,S_DiscountingSequenceNumber&#xA;&#x9;&#x9;,S_Advance&#xA;&#x9;&#x9;,S_CompoundingFrequency&#xA;&#xA;&#x9;&#x9;,DiscountLoanFSId&#xA;&#x9;&#x9;,S_LoanNumber&#xA;&#x9;&#x9;,FunderId&#xA;&#x9;&#x9;,S_FundingSourceNumber&#xA;&#x9;&#x9;,S_FundingSource&#xA;&#xA;&#x9;&#x9;,S_CommencementDate&#xA;&#x9;&#x9;,S_MaturityDate&#xA;&#x9;&#x9;,S_ProcessThroughDate&#xA;&#x9;&#x9;,S_DueDay&#xA;&#x9;&#x9;,S_DiscountRate&#xA;&#x9;&#x9;,S_LoanAmount&#xA;&#x9;&#x9;,S_DebtFinancingCostAmount&#xA;&#x9;&#x9;,S_Currency&#xA;&#x9;&#x9;,S_LegalEntityNumber&#xA;&#x9;&#x9;,S_LoanDate&#xA;&#x9;&#x9;,S_NetTermBasis&#xA;&#x9;&#x9;,S_NetTerms&#xA;&#x9;&#x9;,S_TValueComputeMethod&#xA;&#x9;&#x9;,S_TValueDateCounting&#xA;&#x9;&#x9;,S_RRPPaymentsFrom&#xA;&#x9;&#x9;,S_RRPPaymentFrequency&#xA;&#x9;&#x9;,S_RRPRegularPaymentAmount_Amount&#xA;&#x9;&#x9;,S_PerfectPayPool &#xA;&#x9;)&#xA;&#x9;SELECT &#xA;&#x9;&#x9;SrcDiscountLoan_Deal.DiscountLoanID,&#xA;&#x9;&#x9; &#xA;&#x9;&#x9;SrcDiscountLoan_Deal.IsAutoPaymentAllowed,&#xA;&#xA;&#x9;&#x9;SrcDeal_RentalFrequency_Cnfg.Description AS RepaymentFrequency,&#xA;&#x9;&#x9;CASE WHEN SrcDeal_BookingStatus_Cnfg.Description = 'Completed' THEN 'Approved'ELSE 'Pending' END BookingStatus,&#xA;&#x9;&#x9;SrcLease_Profile.SequenceNumber AS S_AssociatedLeaseSequenceNumber,&#xA;&#x9;&#x9;SrcLease_Profile.SequenceNumber AS S_DiscountingSequenceNumber,&#xA;&#x9;&#x9;COALESCE(SRCDiscountFunderView.Advance, 0) AS S_Advance,&#xA;&#x9;&#x9;SrcDeal_RentalFrequency_Cnfg.Description AS S_CompoundingFrequency,&#xA;&#xA;&#x9;&#x9;SrcDiscountLoan_FundingSourceDetail.DiscountLoanFSId,&#xA;&#x9;&#x9;CASE WHEN SrcDiscountLoan_FundingSourceDetail.LoanNumber IS NULL THEN '' ELSE LTRIM(SrcDiscountLoan_FundingSourceDetail.LoanNumber) END AS S_LoanNumber,&#xA;&#x9;&#x9;SrcFundingSource_Profile.FundingSourceID AS FunderId,&#x9;&#x9;&#xA;&#x9; &#xA;&#x9;&#x9;(CAST(SrcFundingSource_Profile.FundingSourceNumber AS nvarchar(40)))  AS S_FundingSourceNumber ,&#xA;&#x9;&#x9;SrcFundingSource_Profile.Company   AS S_FundingSource,&#xA;&#x9;&#x9;CAST(&#xA;&#x9;&#x9; DRS.StartDate AS date&#xA;&#x9;&#x9;) AS S_CommencementDate,&#xA;&#x9;&#x9;SrcDiscountLoan_FundingSourceDetail.LoanMaturityDate AS S_MaturityDate,&#xA;&#x9;&#x9;NULL AS S_ProcessThroughDate,&#xA;&#x9;&#x9;ISNULL(DAY(SRCDiscountFunderView.FrequencyStartDate),1) AS S_DueDay,&#xA;&#x9;&#x9;CASE&#xA;&#x9;&#x9;WHEN SRCDiscountFunderView.IsRegularPaymentStream = 0 THEN (&#xA;&#x9;&#x9;  CAST(&#xA;&#x9;&#x9;&#x9;SrcDiscountLoan_FundingSourceDetail.InterestRate AS Decimal(14, 9)&#xA;&#x9;&#x9;  )&#xA;&#x9;&#x9;)&#xA;&#x9;&#x9;ELSE 0&#xA;        END AS S_DiscountRate,&#xA;&#x9;&#x9;SrcDiscountLoan_FundingSourceDetail.LoanAmount AS S_LoanAmount,&#xA;&#x9;&#x9;SrcDiscountLoan_FundingSourceDetail.DebtFinancingCostAmount AS S_DebtFinancingCostAmount,&#xA;&#x9;&#x9;(CAST(SrcCurrencyView.Currency AS nvarchar(3))) AS S_Currency,&#xA;&#x9;&#x9;LEL.LegalEntityNumber AS S_LegalEntityNumber,&#xA;&#x9;&#x9;CAST(&#xA;&#x9;&#x9;  SrcDiscountLoan_FundingSourceDetail.LoanDate AS date&#xA;&#x9;&#x9;) AS LoanDate,&#xA;&#x9;&#x9;CAST('Days' AS NVARCHAR(6)) AS NetTermBasis,&#xA;&#x9;&#x9;CAST(1 AS INT) AS NetTerms,&#xA;&#x9;&#x9;CAST('Normal' AS NVARCHAR(8)) AS TValueComputeMethod,&#xA;&#x9;&#x9;CAST('Normal' AS NVARCHAR(13)) AS TValueDateCounting,&#xA;&#x9;&#x9;ISNULL(Discounting1818.RRPPaymentsFrom,0) AS RRPPaymentsFrom,&#xA;&#x9;&#x9;ISNULL(Discounting1818.RRPPaymentFrequency,'_') AS RRPPaymentFrequency,&#xA;&#x9;&#x9;ISNULL(Discounting1818.RRPRegularPaymentAmount,0.00) AS RRPRegularPaymentAmount_Amount,&#xA;&#x9;&#x9;ISNULL(CASE WHEN Discounting1818.IsPerfectPayPool='Y' THEN 1 ELSE 0 END,0) AS PerfectPayPool &#xA;&#x9;FROM &#xA;&#x9;&#x9;SrcDiscountLoan_Deal&#xA;&#xA;&#x9;&#x9;INNER JOIN SrcDiscountLoan_FundingSourceDetail&#xA;&#x9;&#x9;&#x9;ON SrcDiscountLoan_Deal.DiscountLoanID = SrcDiscountLoan_FundingSourceDetail.DiscountLoanID&#xA;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;INNER JOIN #DiscountTemp DT on DT.MaxDiscountId = SrcDiscountLoan_Deal.DiscountLoanID&#xA;&#x9;&#x9;AND DT.EntityID = SrcDiscountLoan_Deal.EntityID&#xA;&#x9;&#x9;INNER JOIN SrcFundingSource_Profile&#xA;&#x9;&#x9;&#x9;ON SrcFundingSource_Profile.FundingSourceId = SrcDiscountLoan_FundingSourceDetail.FundingSourceID&#xA;&#xA;&#x9;&#x9;INNER JOIN SrcDeal_RentalFrequency_Cnfg&#xA;&#x9;&#x9;&#x9;ON SrcDeal_RentalFrequency_Cnfg.FrequencyId = SrcDiscountLoan_Deal.RepaymentFrequencyID&#xA;&#xA;&#x9;&#x9;INNER JOIN SrcLease_Profile&#xA;&#x9;&#x9;&#x9;ON SrcDiscountLoan_Deal.Entitytypeid = 5 /* Lease */&#xA;&#x9;&#x9;&#x9;AND SrcLease_Profile.LeaseId = SrcDiscountLoan_Deal.EntityId&#xA;&#xA;&#x9;&#x9;INNER JOIN SRCCurrencyView&#xA;&#x9;&#x9;&#x9;ON SrcDiscountLoan_Deal.LLCID = SrcCurrencyView.LLCID&#xA;&#x9;    INNER JOIN Insight_Source..DiscountLoan_RepaymentSchedule DRS ON SrcDiscountLoan_Deal.Discountloanid = DRS.DiscountLoanId&#xA;&#x9;&#x9;AND DRS.LoanRepaymentNumber = 1&#xA;&#x9;&#x9;AND DRS.IsActive = 1&#xA;&#xA;&#x9;&#x9;INNER JOIN SrcDeal_BookingStatus_Cnfg&#xA;&#x9;&#x9;&#x9;ON SrcDeal_BookingStatus_Cnfg.BookingStatusID = SrcDiscountLoan_Deal.BookingStatusID&#xA;&#xA;&#x9;&#x9;INNER JOIN SRCDiscountFunderView&#xA;&#x9;&#x9;&#x9;ON SRCDiscountFunderView.DiscountLoanID = SrcDiscountLoan_Deal.DiscountLoanID&#xA;&#x9;&#x9;INNER Join Migration_Intermediate..LegalEntityLease LEL on LEL.LeaseId=SrcLease_Profile.LeaseId&#xA;&#x9;&#x9;LEFT JOIN Migration_Intermediate..Discounting1818mapping Discounting1818 ON Discounting1818.DiscountLoanId =  SRCDiscountLoan_Deal.Discountloanid&#xA;&#x9;WHERE&#xA;&#x9;SrcLease_Profile.StatusId = 2 &#xA;&#x9;&#xA;&#x9;/* START Discounting Amortization */&#xA;&#x9;SELECT&#xA;&#x9;&#x9;SourceDiscountingDetails.DiscountLoanFSId,&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;SRCDiscountLoan_Amortization.DiscountLoanAmortizationID,&#xA;&#x9;&#x9;SRCDiscountLoan_Amortization.PaymentAmount AS PaymentAmount, &#xA;&#x9;&#x9;SRCDiscountLoan_Amortization.PrincipalAmount AS PrincipalAmount,&#xA;&#x9;&#x9;SRCDiscountLoan_Amortization.DebtFinancingCostAmount AS DebtFinancingCostAmount,&#xA;&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_Amortization.PaymentDate &gt; @MigrationCutoffDate THEN SRCDiscountLoan_Amortization.PaymentAmount ELSE 0 END AS RemainingPaymentAmount,&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_Amortization.PaymentDate &gt; @MigrationCutoffDate THEN SRCDiscountLoan_Amortization.PrincipalAmount ELSE 0 END AS RemainingPrincipalAmount&#xA;&#x9;INTO #DiscountingAmort&#xA;&#x9;FROM &#xA;&#x9;&#x9;#SourceDiscountingDetails SourceDiscountingDetails&#xA;&#x9;&#x9;INNER JOIN SRCDiscountLoan_Amortization&#xA;&#x9;&#x9;&#x9;ON SourceDiscountingDetails.DiscountLoanFSId= SRCDiscountLoan_Amortization.DiscountLoanFSId&#xA;&#x9;SELECT &#xA;&#x9;&#x9;DiscountingAmort.DiscountLoanFSId&#xA;&#x9;&#x9;, SUM(DiscountingAmort.DebtFinancingCostAmount) AS TotalDebtFinancingCostAmount &#xA;&#xA;&#x9;&#x9;, SUM(DiscountingAmort.PaymentAmount) AS TotalPaymentAmount &#xA;&#x9;&#x9;, SUM(DiscountingAmort.PrincipalAmount) AS TotalPrincipalAmount &#xA;&#x9;&#x9;, SUM(DiscountingAmort.RemainingPaymentAmount) AS RemainingPaymentAmount &#xA;&#x9;&#x9;, SUM(DiscountingAmort.RemainingPrincipalAmount) AS RemainingPrincipalAmount &#xA;&#x9;INTO #DiscountingAmortSummary&#xA;&#x9;FROM &#xA;&#x9;&#x9;#DiscountingAmort DiscountingAmort&#xA;&#x9;GROUP BY &#xA;&#x9;&#x9;DiscountingAmort.DiscountLoanFSId&#xA;&#xA;&#x9;UPDATE #SourceDiscountingDetails &#xA;&#x9;&#x9;SET S_TotalPaymentAmount = DiscountingAmortSummary.TotalPaymentAmount,&#xA;&#x9;&#x9;&#x9;S_TotalPrincipalAmount = DiscountingAmortSummary.TotalPrincipalAmount,&#xA;&#x9;&#x9;&#x9;S_DebtFinancingCostAmount = DiscountingAmortSummary.TotalDebtFinancingCostAmount,&#xA;&#x9;&#x9;&#x9;S_RemainingPaymentAmount = DiscountingAmortSummary.RemainingPaymentAmount,&#xA;&#x9;&#x9;&#x9;S_RemainingPrincipalAmount = DiscountingAmortSummary.RemainingPrincipalAmount&#xA;&#xA;&#x9;FROM &#xA;&#x9;&#x9;#SourceDiscountingDetails &#xA;&#x9;&#x9;INNER JOIN #DiscountingAmortSummary DiscountingAmortSummary&#xA;&#x9;&#x9;&#x9;ON DiscountingAmortSummary.DiscountLoanFSId = #SourceDiscountingDetails.DiscountLoanFSId &#xA;&#xA;&#x9;/* END Discounting Amortization */&#xA;&#xA;&#x9;/* START Discounting Amortization Details*/&#xA;&#x9;SELECT &#xA;&#x9;&#x9;DiscountingAmort.DiscountLoanFSId, &#xA;&#x9;&#x9;SRCDiscountLoan_AmortizationDetail.DiscountLoanAmortizationID,&#xA;&#x9;&#x9;SRCDiscountLoan_AmortizationDetail.InterestAccrualAmount,&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_AmortizationDetail.InterestDate &lt;= @MigrationCutoffDate THEN SRCDiscountLoan_AmortizationDetail.InterestDate ELSE NULL END InterestDate,&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_AmortizationDetail.InterestDate &gt; @MigrationCutoffDate THEN SRCDiscountLoan_AmortizationDetail.InterestAccrualAmount ELSE 0 END RemainingInterestAccrualAmount,&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_AmortizationDetail.InterestDate &lt;= @MigrationCutoffDate THEN SRCDiscountLoan_AmortizationDetail.InterestAccrualAmount ELSE 0 END AccumulatedInterestAccrualAmount,&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_AmortizationDetail.InterestDate &gt; @MigrationCutoffDate THEN SRCDiscountLoan_AmortizationDetail.DebtFinancingCostAmount ELSE 0 END RemainingDebtFinancingCostAmount,&#xA;&#x9;&#x9;CASE WHEN SRCDiscountLoan_AmortizationDetail.InterestDate &lt;= @MigrationCutoffDate THEN SRCDiscountLoan_AmortizationDetail.DebtFinancingCostAmount ELSE 0 END AccumulatedDebtFinancingCostAmount,&#xA;&#x9;&#x9;SRCDiscountLoan_AmortizationDetail.PostDate AS PostDate&#xA;&#x9;&#x9;--CASE WHEN SRCDiscountLoan_AmortizationDetail.InterestDate &lt;= @MigrationCutoffDate THEN SRCDiscountLoan_AmortizationDetail.EndAccruedInterestAmount ELSE 0 END AS AcruedInterestBalance&#xA;&#x9;INTO #DiscountingAmortDetail&#xA;&#x9;FROM &#xA;&#x9;&#x9;#DiscountingAmort DiscountingAmort&#xA;&#xA;&#x9;&#x9;INNER JOIN SRCDiscountLoan_AmortizationDetail&#xA;&#x9;&#x9;&#x9;ON SRCDiscountLoan_AmortizationDetail.DiscountLoanAmortizationID = DiscountingAmort.DiscountLoanAmortizationID&#xA;&#x9;SELECT &#xA;&#x9;&#x9;DiscountingAmortDetail.DiscountLoanFSId&#xA;&#x9;&#x9;, MAX(DiscountingAmortDetail.InterestDate) AS ProcessThroughDate&#xA;&#x9;&#x9;, SUM(DiscountingAmortDetail.InterestAccrualAmount) AS TotalInterestAccrualAmount &#xA;&#x9;&#x9;, SUM(DiscountingAmortDetail.RemainingInterestAccrualAmount) AS RemainingInterestAccrualAmount&#xA;&#x9;&#x9;, SUM(DiscountingAmortDetail.AccumulatedInterestAccrualAmount) AS AccumulatedInterestAccrualAmount&#xA;&#x9;&#x9;, SUM(DiscountingAmortDetail.RemainingDebtFinancingCostAmount) AS RemainingDebtFinancingCostAmount&#xA;&#x9;&#x9;, SUM(DiscountingAmortDetail.AccumulatedDebtFinancingCostAmount) AS AccumulatedDebtFinancingCostAmount&#xA;&#x9;&#xA;&#x9;&#x9;,MAX(DiscountingAmortDetail.PostDate) AS MaxPostDate&#xA;&#x9;INTO #DiscountingAmortDetailSummary&#xA;&#x9;FROM &#xA;&#x9;&#x9;#DiscountingAmortDetail DiscountingAmortDetail&#xA;&#x9;GROUP BY &#xA;&#x9;&#x9;DiscountLoanFSId&#xA;&#x9;&#x9;&#xA;&#xA;&#x9;UPDATE #SourceDiscountingDetails&#xA;&#x9;&#x9;SET S_AccruedInterestBalance = SRCDiscountLoan_AmortizationDetail.EndAccruedInterestAmount&#xA;&#x9;FROM&#xA;&#x9;&#x9;#SourceDiscountingDetails &#xA;&#x9;&#x9;INNER JOIN #DiscountingAmortDetailSummary DiscountingAmortDetailSummary&#xA;&#x9;&#x9;&#x9;ON DiscountingAmortDetailSummary.DiscountLoanFSId = #SourceDiscountingDetails.DiscountLoanFSId &#xA;&#x9;&#x9;INNER JOIN #DiscountingAmort DiscountingAmort&#xA;&#x9;&#x9;&#x9;ON DiscountingAmort.DiscountLoanFSId = #SourceDiscountingDetails.DiscountLoanFSId&#xA;&#x9;&#x9;INNER JOIN SRCDiscountLoan_AmortizationDetail&#xA;&#x9;&#x9;&#x9;ON SRCDiscountLoan_AmortizationDetail.DiscountLoanAmortizationID = DiscountingAmort.DiscountLoanAmortizationID&#xA;&#x9;&#x9;&#x9;AND SRCDiscountLoan_AmortizationDetail.InterestDate = @MigrationCutoffDate&#xA;        INNER JOIN&#xA;            (&#xA;                SELECT SRCDiscountLoan_Amortization.DiscountLoanFSId,&#xA;                    MAX(InterestTerm) InterestTerm&#xA;                FROM SRCDiscountLoan_AmortizationDetail&#xA;                    JOIN SRCDiscountLoan_Amortization&#xA;                        ON SRCDiscountLoan_AmortizationDetail.DiscountLoanAmortizationID = SRCDiscountLoan_Amortization.DiscountLoanAmortizationID&#xA;                WHERE SRCDiscountLoan_AmortizationDetail.InterestDate = @MigrationCutoffDate&#xA;                GROUP BY SRCDiscountLoan_Amortization.DiscountLoanFSId&#xA;            ) AmortizationDetail&#xA;                ON DiscountingAmort.DiscountLoanFSId = AmortizationDetail.DiscountLoanFSId&#xA;                AND SRCDiscountLoan_AmortizationDetail.InterestTerm = AmortizationDetail.InterestTerm&#xA;&#xA;&#x9;UPDATE #SourceDiscountingDetails &#xA;&#x9;&#x9;SET S_ProcessThroughDate = DiscountingAmortDetailSummary.ProcessThroughDate,&#xA;&#x9;&#x9;&#x9;S_TotalInterestAccrualAmount = DiscountingAmortDetailSummary.TotalInterestAccrualAmount,&#xA;&#x9;&#x9;&#x9;S_RemainingInterestAccrualAmount = DiscountingAmortDetailSummary.RemainingInterestAccrualAmount,&#xA;&#x9;&#x9;&#x9;S_AccumulatedInterestAccrualAmount = DiscountingAmortDetailSummary.AccumulatedInterestAccrualAmount,&#xA;&#x9;&#x9;&#x9;S_RemainingDebtFinancingCostAmount = DiscountingAmortDetailSummary.RemainingDebtFinancingCostAmount,&#xA;&#x9;&#x9;&#x9;S_AccumulatedDebtFinancingCostAmount = DiscountingAmortDetailSummary.AccumulatedDebtFinancingCostAmount&#xA;&#x9;&#x9;&#x9; &#xA;&#x9;FROM &#xA;&#x9;&#x9;#SourceDiscountingDetails &#xA;&#x9;&#x9;INNER JOIN #DiscountingAmortDetailSummary DiscountingAmortDetailSummary&#xA;&#x9;&#x9;&#x9;ON DiscountingAmortDetailSummary.DiscountLoanFSId = #SourceDiscountingDetails.DiscountLoanFSId &#xA;&#x9;/* END Discounting Amortization Detail */&#xA;&#xA;&#xA;&#x9;&#x9;SELECT &#xA;&#x9;&#x9;SrcDiscountLoan_Deal.DiscountLoanID AS DiscountLoanID,&#xA;&#x9;&#x9;MAX(SrcDiscountLoan_RepaymentSchedule.LoanRepaymentNumber) AS LastPaymentNumber&#xA;&#x9;INTO &#xA;&#x9;&#x9;#LastPaymentDueDate&#xA;&#x9;FROM &#xA;&#x9;&#x9;SrcDiscountLoan_Deal&#xA;&#x9;&#x9;INNER JOIN SrcDiscountLoan_RepaymentSchedule&#xA;&#x9;&#x9;ON SrcDiscountLoan_RepaymentSchedule.DiscountLoanID = SrcDiscountLoan_Deal.DiscountLoanID&#xA;&#x9;GROUP BY&#xA;&#x9;&#x9;SrcDiscountLoan_Deal.DiscountLoanID&#xA;&#xA;&#x9;UPDATE #SourceDiscountingDetails &#xA;&#x9;&#x9;SET&#xA;&#x9;&#x9;&#x9;S_LastPaymentDueDate = SrcDiscountLoan_RepaymentSchedule.DueDate,&#xA;&#x9;&#x9;&#x9;S_MaturityDate = SrcDiscountLoan_RepaymentSchedule.DueDate&#xA;&#x9;FROM &#xA;&#x9;&#x9;#SourceDiscountingDetails&#xA;&#xA;&#x9;&#x9;INNER JOIN #LastPaymentDueDate ON #SourceDiscountingDetails.DiscountLoanID = #LastPaymentDueDate.DiscountLoanID&#xA;&#xA;&#x9;&#x9;INNER JOIN SrcDiscountLoan_RepaymentSchedule&#xA;&#x9;&#x9;&#x9;ON #SourceDiscountingDetails.DiscountLoanID = SrcDiscountLoan_RepaymentSchedule.DiscountLoanID&#xA;&#x9;&#x9;&#x9;AND #LastPaymentDueDate.LastPaymentNumber = SrcDiscountLoan_RepaymentSchedule.LoanRepaymentNumber&#xA;&#x9;&#x9;&#x9; &#xA;&#x9;--SELECT * FROM #SourceDiscountingDetails&#xA;&#xA;-- 15A. DiscountingSource_20250929.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.SourceDiscountingDetailsRecon&#xA;&#xA;SELECT 'SourceDiscountingDetails' Recon, * &#xA;INTO V5_Recon.dbo.SourceDiscountingDetailsRecon&#xA;FROM #SourceDiscountingDetails&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.SourceDiscountingDetailsRecon&#xA;&#x9;&#x9;&#xA;&#x9;DROP TABLE #SourceDiscountingDetails&#xA;&#x9;DROP TABLE #DiscountingAmort&#xA;&#x9;DROP TABLE #DiscountingAmortDetail&#xA;&#x9;DROP TABLE #DiscountingAmortSummary&#xA;&#x9;DROP TABLE #DiscountingAmortDetailSummary&#xA;&#x9;&#xA;&#xA;&#xA;--END&#xA;--GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
  <DTS:DesignTimeProperties><![CDATA[<?xml version="1.0"?>
