  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\1A CustomerFieldWiseRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{9AD53E7C-3622-490A-8083-A22393B266AE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="1A CustomerFieldWiseRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="--CustomerFieldWiseRecon:&#xA;DROP TABLE IF EXISTS ##customersource&#xA;DROP TABLE IF EXISTS ##customertarget&#xA;DROP TABLE IF EXISTS ##CustomerRecon&#xA;DROP TABLE IF EXISTS CustomerRecon&#xA;--Source&#xA;SELECT&#xA;  CP.AccountNumber AS 'PartyNumber',&#xA;  cp.Alias AS 'AlsoKnownAs',&#xA;  CP.CustomerName AS 'PartyName',&#xA;  CP.CreationDate,&#xA;  Convert(DATE, CP.ActivationDate) AS ActivationDate,&#xA;  CP.InvoiceLeadDays,&#xA;  CP.InvoiceTransitDays,&#xA;  CP.InvoiceGraceDays,&#xA;  CASE&#xA;    WHEN CP.IsIndividual = 1 THEN 0&#xA;    ELSE 1&#xA;  &#xA;END&#xA; IsCorporate,&#xA;  ('9999') AS OrganizationID,&#xA;  CP.IncorporationDate,&#xA;  IIF(CP.FirstName = '', NULL, CP.FirstName) AS FirstName,&#xA;  IIF(CP.LastName = '', NULL, CP.LastName) AS LastName,&#xA;  CP.CompanyName,&#xA;  ISNULL(Customer_Class_Cnfg.Description, 'Exempt') CustomerClass,&#xA;  IIF(cp.InvoiceComment = '', NULL, cp.InvoiceComment) AS InvoiceComment,&#xA;  cp.IsBankrupt,&#xA;  Insight_UAT.[dbo].[Encrypt] (&#xA;    'nvarchar',&#xA;    cp.TaxID,&#xA;    'M4WHMOVTTT74UP6EL71GWMU4NTXQLLN5'&#xA;  ) AS 'VATRegistrationNumber',&#xA;  IIF(cp.CustomerURL = '', NULL, cp.CustomerURL) CompanyURL,&#xA;  cp.LastLoanReviewDate AS 'NextReviewDate',&#xA;  cp.LastLoanReviewDate AS 'AnnualCreditReviewDate',&#xA;  cp.IsRelatedToLessor,&#xA;  cp.IsACHConsolidated AS 'IsConsolidated',&#xA;  ISNULL(&#xA;    (&#xA;      CASE&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 1 THEN 'January'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 2 THEN 'February'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 3 THEN 'March'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 4 THEN 'April'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 5 THEN 'May'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 6 THEN 'June'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 7 THEN 'July'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 8 THEN 'August'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 9 THEN 'September'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 10 THEN 'October'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 11 THEN 'November'&#xA;        WHEN Customer_CreditSummaryCustomer.FiscalYearEndMonthNo = 12 THEN 'December'&#xA;      &#xA;END&#xA;&#xA;    ),&#xA;    NULL&#xA;  ) AS 'FiscalYearEndMonth',&#xA;  NULL AS 'ParentCustomerNumber',&#xA;  Customer_UCCDetailCustomer.IsUCCRequired AS 'IsLienFilingRequired',&#xA;  (&#xA;    CASE&#xA;      WHEN Customer_CreditSummaryCustomer.OwnershipTypeID = 1 THEN 'Public'&#xA;      WHEN Customer_CreditSummaryCustomer.OwnershipTypeID = 2 THEN 'Private'&#xA;      WHEN Customer_CreditSummaryCustomer.OwnershipTypeID = 3 THEN 'Partnership'&#xA;      ELSE '_'&#xA;    &#xA;END&#xA;&#xA;  ) AS 'OwnershipType',&#xA;  CP.CustomerName AS 'SalesForceCustomerName',&#xA;  (CASE WHEN SSCM.StateID IS NOT NULL THEN SSCM.LW5StateShortName&#xA;&#x9;&#x9;ELSE Insight_Source.dbo.Template_State_CnfgLocale.StateShortName&#xA;&#x9;&#x9;END) AS StateOfIncorporation,&#xA;  (&#xA;    CASE&#xA;      WHEN CP.CustomerStatusId = 1 THEN 'Active'&#xA;      WHEN CP.CustomerStatusId = 2 THEN 'Inactive'&#xA;      WHEN CP.CustomerStatusId = 0 THEN 'Pending'&#xA;      ELSE 'Active'&#xA;    &#xA;END&#xA;&#xA;  ) AS 'CustomerStatus'&#xA;INTO&#xA;  ##customersource&#xA;FROM&#xA;  Insight_Source..Customer_profile CP&#xA;  LEFT JOIN Insight_Source..Customer_Class_Cnfg ON CP.CustomerClassID = Customer_Class_Cnfg.CustomerClassID&#xA;  LEFT JOIN Insight_Source.dbo.Customer_CreditSummary Customer_CreditSummaryCustomer ON CP.CustomerId = Customer_CreditSummaryCustomer.CustomerId&#xA;  LEFT JOIN Insight_Source.dbo.Customer_Profile Customer_ProfileCustomer ON CP.ParentCustomerID = Customer_ProfileCustomer.CustomerId&#xA;  LEFT JOIN Insight_Source.dbo.Customer_UCCDetail Customer_UCCDetailCustomer ON CP.CustomerId = Customer_UCCDetailCustomer.CustomerId&#xA;  LEFT JOIN Insight_Source.dbo.Template_State_Cnfg ON Customer_UCCDetailCustomer.UCCStateId = Template_State_Cnfg.StateID&#xA;  LEFT JOIN Insight_Source.dbo.Template_State_CnfgLocale ON Template_State_Cnfg.StateID = Template_State_CnfgLocale.StateID&#xA;  LEFT JOIN Insight_Source.dbo.Template_Country_Cnfg ON Insight_Source.dbo.Template_State_Cnfg.CountryID = Template_Country_Cnfg.CountryID&#xA;  LEFT JOIN Insight_Source.dbo.Template_Country_CnfgLocale ON Insight_Source.dbo.Template_Country_CnfgLocale.CountryID = Template_State_Cnfg.CountryID&#xA;  LEFT JOIN Migration_Intermediate.dbo.StatesShortCodeMapping SSCM on SSCM.StateID = Template_State_CnfgLocale.StateID&#xA;WHERE&#xA;  CP.customerstatusid = 1&#xA;ORDER BY&#xA;  CP.AccountNumber&#xA;  --Target&#xA;SELECT&#xA;  P.PartyNumber,&#xA;  c.AlsoKnownAs AS 'AlsoKnownAs',&#xA;  P.PartyName,&#xA;  P.CreationDate,&#xA;  C.ActivationDate,&#xA;  C.InvoiceLeadDays,&#xA;  C.InvoiceTransitDays,&#xA;  C.InvoiceGraceDays,&#xA;  P.IsCorporate,&#xA;  p.OrganizationID,&#xA;  p.IncorporationDate,&#xA;  IIF(p.FirstName = '', NULL, p.FirstName) AS FirstName,&#xA;  IIF(p.LastName = '', NULL, p.LastName) AS LastName,&#xA;  p.CompanyName,&#xA;  Replace(CustomerClasses.Class, ' ', '') CustomerClass,&#xA;  IIF(c.InvoiceComment = '', NULL, c.InvoiceComment) InvoiceComment,&#xA;  c.IsBankrupt,&#xA;  p.UniqueIdentificationNumber_CT AS 'VATRegistrationNumber',&#xA;  IIF(c.CompanyURL = '', NULL, c.CompanyURL) AS 'CompanyURL',&#xA;  c.NextReviewDate,&#xA;  c.AnnualCreditReviewDate,&#xA;  c.IsRelatedToLessor,&#xA;  c.IsConsolidated,&#xA;  c.FiscalYearEndMonth AS 'FiscalYearEndMonth',&#xA;  ParentParties.PartyNumber AS 'ParentCustomerNumber',&#xA;  c.IsLienFilingRequired AS 'IsLienFilingRequired',&#xA;  c.OwnershipType AS 'OwnershipType',&#xA;  c.SalesForceCustomerName AS 'SalesForceCustomerName',&#xA;  S.ShortName AS 'StateOfIncorporation',&#xA;  c.STATUS AS 'CustomerStatus'&#xA;INTO&#xA;  ##customertarget&#xA;FROM&#xA;  Insight_UAT..customers c&#xA;  INNER JOIN Insight_UAT..CustomerClasses ON c.CustomerClassId = CustomerClasses.Id&#xA;  INNER JOIN Insight_UAT..parties p ON c.id = p.id&#xA;  AND p.portfolioid = 1&#xA;  AND P.PartyNumber IN (&#xA;    SELECT&#xA;      CP.AccountNumber&#xA;    FROM&#xA;      Insight_Source..Customer_profile CP&#xA;    WHERE&#xA;      customerstatusid = 1&#xA;  )&#xA;  LEFT JOIN Insight_UAT..States AS S ON p.StateOfIncorporationId = S.Id&#xA;  LEFT JOIN Insight_UAT..PArties ParentParties ON ParentParties.id = p.PArentPartyId&#xA;ORDER BY&#xA;  P.PartyNumber&#xA;  --Recon&#xA;SELECT&#xA;  Source.PartyNumber AS 'S_PartyNumber',&#xA;  Target.PartyNumber AS 'T_PartyNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PartyNumber, 0) &lt;&gt; ISNULL(Target.PartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  Source.AlsoKnownAs AS 'S_AlsoKnownAs',&#xA;  Target.AlsoKnownAs AS 'T_AlsoKnownAs',&#xA;  CASE&#xA;    WHEN ISNULL(Source.AlsoKnownAs, 0) &lt;&gt; ISNULL(Target.AlsoKnownAs, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AlsoKnownAs_Matched,&#xA;  Source.PartyName AS 'S_PartyName',&#xA;  Target.PartyName AS 'T_PartyName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.PartyName, 0) &lt;&gt; ISNULL(Target.PartyName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyName_Matched,&#xA;  Source.CreationDate AS 'S_CreationDate',&#xA;  Target.CreationDate AS 'T_CreationDate',&#xA;  CASE&#xA;    WHEN ISNULL(CAST(Source.CreationDate AS DATE), '1900-01-01') &lt;&gt; ISNULL(Target.CreationDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CreationDate_Matched,&#xA;  Source.ActivationDate AS 'S_ActivationDate',&#xA;  Target.ActivationDate AS 'T_ActivationDate',&#xA;  CASE&#xA;    WHEN ISNULL(Source.ActivationDate, '1900-01-01') &lt;&gt; ISNULL(Target.ActivationDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ActivationDate_Matched,&#xA;  Source.InvoiceLeadDays AS 'S_InvoiceLeadDays',&#xA;  Target.InvoiceLeadDays AS 'T_InvoiceLeadDays',&#xA;  CASE&#xA;    WHEN ISNULL(Source.InvoiceLeadDays, 0) &lt;&gt; ISNULL(Target.InvoiceLeadDays, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceLeadDays_Matched,&#xA;  Source.InvoiceTransitDays AS 'S_InvoiceTransitDays',&#xA;  Target.InvoiceTransitDays AS 'T_InvoiceTransitDays',&#xA;  CASE&#xA;    WHEN ISNULL(Source.InvoiceTransitDays, 0) &lt;&gt; ISNULL(Target.InvoiceTransitDays, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceTransitDays_Matched,&#xA;  Source.InvoiceGraceDays AS 'S_InvoiceGraceDays',&#xA;  Target.InvoiceGraceDays AS 'T_InvoiceGraceDays',&#xA;  CASE&#xA;    WHEN ISNULL(Source.InvoiceGraceDays, 0) &lt;&gt; ISNULL(Target.InvoiceGraceDays, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceGraceDays_Matched,&#xA;  Source.IsCorporate AS 'S_IsCorporate',&#xA;  Target.IsCorporate AS 'T_IsCorporate',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsCorporate, 0) &lt;&gt; ISNULL(Target.IsCorporate, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsCorporate_Matched,&#xA;  Source.OrganizationID AS 'S_OrganizationID',&#xA;  Target.OrganizationID AS 'T_OrganizationID',&#xA;  CASE&#xA;    WHEN ISNULL(Source.OrganizationID, 0) &lt;&gt; ISNULL(Target.OrganizationID, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; OrganizationID_Matched,&#xA;  Source.IncorporationDate AS 'S_IncorporationDate',&#xA;  Target.IncorporationDate AS 'T_IncorporationDate',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IncorporationDate, '1900-01-01') &lt;&gt; ISNULL(Target.IncorporationDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IncorporationDate_Matched,&#xA;  Source.FirstName AS 'S_FirstName',&#xA;  Target.FirstName AS 'T_FirstName',&#xA;  CASE&#xA;    WHEN ISNULL(NULLIF(Source.FirstName, ''), 0) &lt;&gt; ISNULL(Target.FirstName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; FirstName_Matched,&#xA;  Source.LastName AS 'S_LastName',&#xA;  Target.LastName AS 'T_LastName',&#xA;  CASE&#xA;    WHEN ISNULL(NULLIF(Source.LastName, ''), 0) &lt;&gt; ISNULL(Target.LastName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LastName_Matched,&#xA;  Source.CompanyName AS 'S_CompanyName',&#xA;  Target.CompanyName AS 'T_CompanyName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.CompanyName, 0) &lt;&gt; ISNULL(Target.CompanyName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CompanyName_Matched,&#xA;  Source.CustomerClass AS 'S_CustomerClass',&#xA;  Target.CustomerClass AS 'T_CustomerClass',&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerClass, 0) &lt;&gt; ISNULL(Target.CustomerClass, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerClass_Matched,&#xA;  Source.InvoiceComment AS 'S_InvoiceComment',&#xA;  Target.InvoiceComment AS 'T_InvoiceComment',&#xA;  CASE&#xA;    WHEN ISNULL(Source.InvoiceComment, 0) &lt;&gt; ISNULL(Target.InvoiceComment, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; InvoiceComment_Matched,&#xA;  Source.IsBankrupt AS 'S_IsBankrupt',&#xA;  Target.IsBankrupt AS 'T_IsBankrupt',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsBankrupt, 0) &lt;&gt; ISNULL(Target.IsBankrupt, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsBankrupt_Matched,&#xA;  Source.CompanyURL AS 'S_CompanyURL',&#xA;  Target.CompanyURL AS 'T_CompanyURL',&#xA;  CASE&#xA;    WHEN ISNULL(Source.CompanyURL, 0) &lt;&gt; ISNULL(Target.CompanyURL, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CompanyURL_Matched,&#xA;  Source.NextReviewDate AS 'S_NextReviewDate',&#xA;  Target.NextReviewDate AS 'T_NextReviewDate',&#xA;  CASE&#xA;    WHEN ISNULL(Source.NextReviewDate, '1900-01-01') &lt;&gt; ISNULL(Target.NextReviewDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; NextReviewDate_Matched,&#xA;  Source.AnnualCreditReviewDate AS 'S_AnnualCreditReviewDate',&#xA;  Target.AnnualCreditReviewDate AS 'T_AnnualCreditReviewDate',&#xA;  CASE&#xA;    WHEN ISNULL(Source.AnnualCreditReviewDate, '1900-01-01') &lt;&gt; ISNULL(Target.AnnualCreditReviewDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AnnualCreditReviewDate_Matched,&#xA;  Source.IsConsolidated AS 'S_IsConsolidated',&#xA;  Target.IsConsolidated AS 'T_IsConsolidated',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsConsolidated, 0) &lt;&gt; ISNULL(Target.IsConsolidated, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsConsolidated_Matched,&#xA;  Source.IsRelatedToLessor AS 'S_IsRelatedToLessor',&#xA;  Target.IsRelatedToLessor AS 'T_IsRelatedToLessor',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsRelatedToLessor, 0) &lt;&gt; ISNULL(Target.IsRelatedToLessor, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsRelatedToLessor_Matched,&#xA;  Source.FiscalYearEndMonth AS 'S_FiscalYearEndMonth',&#xA;  Target.FiscalYearEndMonth AS 'T_FiscalYearEndMonth',&#xA;  CASE&#xA;    WHEN ISNULL(Source.FiscalYearEndMonth, 0) &lt;&gt; ISNULL(Target.FiscalYearEndMonth, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; FiscalYearEndMonth_Matched,&#xA;  Source.ParentCustomerNumber AS 'S_ParentCustomerNumber',&#xA;  Target.ParentCustomerNumber AS 'T_ParentCustomerNumber',&#xA;  CASE&#xA;    WHEN ISNULL(Source.ParentCustomerNumber, 0) &lt;&gt; ISNULL(Target.ParentCustomerNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; ParentCustomerNumber_Matched,&#xA;  Source.IsLienFilingRequired AS 'S_IsLienFilingRequired',&#xA;  Target.IsLienFilingRequired AS 'T_IsLienFilingRequired',&#xA;  CASE&#xA;    WHEN ISNULL(Source.IsLienFilingRequired, 0) &lt;&gt; ISNULL(Target.IsLienFilingRequired, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; IsLienFilingRequired_Matched,&#xA;  Source.OwnershipType AS 'S_OwnershipType',&#xA;  Target.OwnershipType AS 'T_OwnershipType',&#xA;  CASE&#xA;    WHEN ISNULL(Source.OwnershipType, 0) &lt;&gt; ISNULL(Target.OwnershipType, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; OwnershipType_Matched,&#xA;  Source.SalesForceCustomerName AS 'S_SalesForceCustomerName',&#xA;  Target.SalesForceCustomerName AS 'T_SalesForceCustomerName',&#xA;  CASE&#xA;    WHEN ISNULL(Source.SalesForceCustomerName, 0) &lt;&gt; ISNULL(Target.SalesForceCustomerName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; SalesForceCustomerName_Matched,&#xA;  Source.StateOfIncorporation AS 'S_StateOfIncorporation',&#xA;  Target.StateOfIncorporation AS 'T_StateOfIncorporation',&#xA;  CASE&#xA;    WHEN ISNULL(Source.StateOfIncorporation, 0) &lt;&gt; ISNULL(Target.StateOfIncorporation, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; StateOfIncorporation_Matched,&#xA;  Source.CustomerStatus AS 'S_CustomerStatus',&#xA;  Target.CustomerStatus AS 'T_CustomerStatus',&#xA;  CASE&#xA;    WHEN ISNULL(Source.CustomerStatus, 0) &lt;&gt; ISNULL(Target.CustomerStatus, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CustomerStatus_Matched&#xA;INTO&#xA;  ##CustomerRecon&#xA;FROM&#xA;  ##customersource Source&#xA;  INNER JOIN ##customertarget Target ON Source.PartyNumber = Target.PartyNumber&#xA;  DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE CustomerRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##CustomerRecon'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_Executesql @CreateTableScript&#xA;INSERT INTO&#xA;  CustomerRecon&#xA;SELECT&#xA;  *&#xA;FROM&#xA;  ##CustomerRecon&#xA;  SELECT * FROM customerRecon&#xA;DROP TABLE IF EXISTS ##customersource&#xA;DROP TABLE IF EXISTS ##customertarget&#xA;DROP TABLE IF EXISTS ##CustomerRecon&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
