  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\4 LocationFieldWiseRecon"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{1DAB6C17-28A8-4A6A-9183-D1BC226EF044}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="4 LocationFieldWiseRecon"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 Location Recon&#xA;&#xA;DROP TABLE IF EXISTS ##LocationSource&#xA;DROP TABLE IF EXISTS ##LocationTarget&#xA;DROP TABLE IF EXISTS ##Location&#xA;DROP TABLE IF EXISTS LocationRecon&#xA;--Field Wise Recon&#xA;--Source Data&#xA;SELECT&#xA;  lt.Address 'AddressLine1',&#xA;  lt.Address2 'AddressLine2',&#xA;  lt.City 'City',&#xA;  lt.LocationCode 'Code',&#xA;  CASE WHEN tc.CountryShortCode='HKG' THEN 'CHN' ELSE tc.CountryShortCode END 'CountryShortName',&#xA;  lt.Description 'Description',&#xA;  lt.County 'Division',&#xA;  lt.LocationName1 'LocationName',&#xA;  CASE&#xA;    WHEN ISNULL(lt.LocationName2, '') = '' THEN NULL&#xA;    ELSE lt.LocationName2&#xA;  &#xA;END&#xA; AS 'LocationName2',&#xA;  lt.EntityTypeID,&#xA;  cp.AccountNumber 'PartyNumber',&#xA;  lt.ZIP 'PostalCode',&#xA;  (CASE WHEN SSCM.StateID IS NOT NULL THEN SSCM.LW5StateShortName&#xA;&#x9;&#x9;ELSE sll.StateShortName&#xA;&#x9;&#x9;END)  AS State,&#xA;  ISNULL(LTAH.TaxAreaEffectiveDate, '1999-01-01') AS TaxAreaVerifiedTillDate,&#xA;  LTAH.TaxAreaId 'TaxAreaId'&#xA;INTO&#xA;  ##LocationSource&#xA;FROM&#xA;  Insight_Source.dbo.Inventory_LocationTemplate lt&#xA;  LEFT JOIN Insight_Source.dbo.Customer_Profile cp ON lt.EntityId = cp.CustomerId&#xA;  INNER JOIN Insight_Source.dbo.LocationTaxAreaHistoriesView LTAH on LTAH.LocationTemplateID = lt.LocationTemplateID&#xA;  AND lt.TaxAreaID = LTAH.TaxAreaId&#xA;  AND LTAH.rn = 1&#xA;  INNER JOIN Insight_Source.dbo.Template_State_Cnfg sl ON lt.StateID = sl.StateID&#xA;  INNER JOIN Insight_Source.dbo.Template_State_CnfgLocale sll on sl.stateid = sll.stateid&#xA;  INNER JOIN Insight_Source.dbo.Template_Country_CnfgLocale tc ON tc.CountryID = sl.CountryID&#xA;  LEFT JOIN Insight_Source.dbo.LocationTemplateView LocationTemplateViewLocation ON lt.LocationTemplateID = LocationTemplateViewLocation.LocationTemplateID&#xA;LEFT JOIN Migration_Intermediate..StatesShortCodeMapping SSCM on SSCM.StateID = sll.StateID&#xA;&#xA;WHERE&#xA;  lt.EntityTypeId IN (1, 2)&#xA;  AND (&#xA;    cp.CustomerID IS NULL&#xA;    OR cp.CustomerStatusID = 1&#xA;  )&#xA;  --Target Data&#xA;SELECT&#xA;  l.AddressLine1,&#xA;  l.AddressLine2,&#xA;  l.City,&#xA;  l.Code,&#xA;  c.ShortName 'CountryShortName',&#xA;  l.Description,&#xA;  l.Division,&#xA;  l.Name 'LocationName',&#xA;  CASE&#xA;    WHEN ISNULL(l.NameTwo, '') = '' THEN NULL&#xA;    ELSE l.NameTwo&#xA;  &#xA;END&#xA; AS 'LocationName2',&#xA;  p.PartyNumber,&#xA;  l.PostalCode,&#xA;  s.ShortName AS 'state',&#xA;  l.TaxAreaId 'TaxAreaId',&#xA;  l.TaxAreaVerifiedTillDate&#xA;INTO&#xA;  ##LocationTarget&#xA;FROM&#xA;  Insight_UAT..Locations l&#xA;  LEFT JOIN Insight_UAT..Parties p ON l.CustomerId = p.Id&#xA;  JOIN Insight_UAT..States s ON s.Id = l.StateId&#xA;  JOIN Insight_UAT..Countries c ON c.Id = s.CountryId&#xA;WHERE&#xA;  l.PortfolioId = 1&#xA;SELECT&#xA;  Source.Code S_LocationCode,&#xA;  Target.Code T_LocationCode,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Code, 0) &lt;&gt; ISNULL(Target.Code, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LocationCode_Matched,&#xA;  Source.LocationName S_LocationName,&#xA;  Target.LocationName T_LocationName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.LocationName, 0) &lt;&gt; ISNULL(Target.LocationName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LocationName_Matched,&#xA;  Source.LocationName2 S_LocationNameTwo,&#xA;  Target.LocationName2 T_LocationNameTwo,&#xA;  CASE&#xA;    WHEN ISNULL(Source.LocationName2, 0) &lt;&gt; ISNULL(Target.LocationName2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; LocationNameTwo_Matched,&#xA;  Source.PartyNumber S_PartyNumber,&#xA;  Target.PartyNumber T_PartyNumber,&#xA;  CASE&#xA;    WHEN ISNULL(Source.PartyNumber, 0) &lt;&gt; ISNULL(Target.PartyNumber, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PartyNumber_Matched,&#xA;  Source.AddressLine1 S_AddressLine1,&#xA;  Target.AddressLine1 T_AddressLine1,&#xA;  CASE&#xA;    WHEN ISNULL(Source.AddressLine1, 0) &lt;&gt; ISNULL(Target.AddressLine1, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AddressLine1_Matched,&#xA;  Source.AddressLine2 S_AddressLine2,&#xA;  Target.AddressLine2 T_AddressLine2,&#xA;  CASE&#xA;    WHEN ISNULL(Source.AddressLine2, 0) &lt;&gt; ISNULL(Target.AddressLine2, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; AddressLine2_Matched,&#xA;  Source.City S_City,&#xA;  Target.City T_City,&#xA;  CASE&#xA;    WHEN ISNULL(Source.City, 0) &lt;&gt; ISNULL(Target.City, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; City_Matched,&#xA;  Source.Division S_Division,&#xA;  Target.Division T_Division,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Division, 0) &lt;&gt; ISNULL(Target.Division, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Division_Matched,&#xA;  Source.Description S_Description,&#xA;  Target.Description T_Description,&#xA;  CASE&#xA;    WHEN ISNULL(Source.Description, 0) &lt;&gt; ISNULL(Target.Description, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; Description_Matched,&#xA;  Source.PostalCode S_PostalCode,&#xA;  Target.PostalCode T_PostalCode,&#xA;  CASE&#xA;    WHEN ISNULL(Source.PostalCode, 0) &lt;&gt; ISNULL(Target.PostalCode, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; PostalCode_Matched,&#xA;  Source.TaxAreaId S_TaxAreaId,&#xA;  Target.TaxAreaId T_TaxAreaId,&#xA;  CASE&#xA;    WHEN ISNULL(Source.TaxAreaId, 0) &lt;&gt; ISNULL(Target.TaxAreaId, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; TaxAreaId_Matched,&#xA;  Source.CountryShortName S_CountryShortName,&#xA;  Target.CountryShortName T_CountryShortName,&#xA;  CASE&#xA;    WHEN ISNULL(Source.CountryShortName, 0) &lt;&gt; ISNULL(Target.CountryShortName, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; CountryShortName_Matched,&#xA;  Source.TaxAreaVerifiedTillDate S_TaxAreaVerifiedTillDate,&#xA;  Target.TaxAreaVerifiedTillDate T_TaxAreaVerifiedTillDate,&#xA;  CASE&#xA;    WHEN ISNULL(Source.TaxAreaVerifiedTillDate, '1900-01-01') &lt;&gt; ISNULL(Target.TaxAreaVerifiedTillDate, '1900-01-01') THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; TaxAreaVerifiedTillDate_Matched,&#xA;  Source.State S_State,&#xA;  Target.State T_State,&#xA;  CASE&#xA;    WHEN ISNULL(Source.State, 0) &lt;&gt; ISNULL(Target.State, 0) THEN 'FALSE'&#xA;    ELSE 'TRUE'&#xA;  &#xA;END&#xA; State_Matched&#xA;into&#xA;  ##Location&#xA;FROM&#xA;  ##LocationSource Source&#xA;  INNER JOIN ##LocationTarget Target ON Source.Code = Target.Code&#xA;  AND (&#xA;    (&#xA;      Source.PartyNumber IS NULL&#xA;      AND target.PartyNumber IS NULL&#xA;    )&#xA;    OR Source.PartyNumber = Target.PartyNumber&#xA;  ) DECLARE @CreateTableScript NVARCHAR(max);&#xA;&#xA;SET&#xA;  @CreateTableScript = (&#xA;    SELECT&#xA;      'CREATE TABLE LocationRecon  (' + STRING_AGG(&#xA;        COLUMN_NAME + ' ' + DATA_TYPE + CASE&#xA;          WHEN DATA_TYPE LIKE 'nvarchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE LIKE 'varchar%' THEN '(' + CAST(CHARACTER_MAXIMUM_LENGTH AS VARCHAR(5)) + ')'&#xA;          WHEN DATA_TYPE IN ('decimal', 'numeric') THEN '(' + CAST(NUMERIC_PRECISION AS VARCHAR(3)) + ',' + CAST(NUMERIC_SCALE AS VARCHAR(3)) + ')'&#xA;          ELSE ''&#xA;        &#xA;END&#xA;,&#xA;        ', '&#xA;      ) + ');'&#xA;    FROM&#xA;      tempdb.INFORMATION_SCHEMA.COLUMNS&#xA;    WHERE&#xA;      TABLE_NAME = '##Location'&#xA;  );&#xA;&#xA;&#xA;EXEC sp_Executesql @CreateTableScript&#xA;&#xA;-- 4. LocationFieldWiseRecon.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.LocationRecon&#xA;&#xA;--INSERT INTO&#xA;--  LocationRecon&#xA;&#xA;SELECT 'LocationRecon' Recon, *&#xA;INTO V5_Recon.dbo.LocationRecon&#xA;FROM ##Location&#xA;&#xA;  --SELECT distinct * FROM LocationRecon&#xA;&#xA;SELECT distinct * &#xA;FROM V5_Recon.dbo.LocationRecon&#xA;&#xA;DROP TABLE IF EXISTS ##LocationSource&#xA;DROP TABLE IF EXISTS ##LocationTarget&#xA;DROP TABLE IF EXISTS ##Location&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
