      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{1092E1CA-43B4-4317-8186-049CB537D513}"
          SQLTask:SqlStatementSource="-- 20250929 SPHC_Discounting_Reconciliation&#xA;&#xA;&#xA;--CREATE OR ALTER PROC [dbo].[SPHC_Discounting_Reconciliation]&#xA;--(&#xA;--&#x9;@ResultOption NVARCHAR(20)&#xA;--)&#xA;--AS&#xA;--BEGIN&#xA;&#xA;&#x9;DROP TABLE IF EXISTS Insight_UAT..DiscountingFinReconExtract&#xA;&#x9;CREATE TABLE #SourceDiscountingDetails&#xA;&#x9;(   DiscountLoanID bigint,&#xA;&#x9;&#x9;DiscountLoanFSId bigint,&#xA;&#x9;&#x9;FunderId bigint,&#xA;&#x9;&#x9;S_AssociatedLeaseSequenceNumber nvarchar(max),&#xA;&#x9;&#x9;S_DiscountingSequenceNumber nvarchar(max),&#xA;&#x9;&#x9;S_LoanNumber nvarchar(max),&#xA;&#x9;&#x9;S_FundingSourceNumber nvarchar(50),&#xA;&#x9;&#x9;S_FundingSource nvarchar(max),&#xA;&#x9;&#x9;S_BookingStatus nvarchar(max),&#xA;&#x9;&#x9;S_RepaymentFrequency nvarchar(max),&#xA;&#x9;&#x9;S_IsAutoPaymentAllowed bit,&#xA;&#x9;&#x9;S_DiscountRate decimal(14,9) DEFAULT (0),&#xA;&#x9;&#x9;S_DueDay Int,&#xA;&#x9;&#x9;S_Advance Bit,&#xA;&#x9;&#x9;S_CompoundingFrequency NVarChar(13) NULL,&#xA;&#x9;&#x9;S_CommencementDate datetime,&#xA;&#x9;&#x9;S_MaturityDate datetime,&#xA;&#x9;&#x9;S_ProcessThroughDate datetime,&#xA;&#x9;&#x9;S_LoanAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_TotalPaymentAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingPaymentAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_TotalPrincipalAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingPrincipalAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_TotalInterestAccrualAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_AccumulatedInterestAccrualAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingInterestAccrualAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_DebtFinancingCostAmount  decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_AccumulatedDebtFinancingCostAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_RemainingDebtFinancingCostAmount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_Currency Nvarchar(40) NULL,&#xA;&#x9;&#x9;S_LastPaymentDueDate datetime,&#xA;&#x9;&#x9;S_AccruedInterestBalance decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_LegalEntityNumber Nvarchar(40) NULL,&#xA;&#x9;&#x9;S_LoanDate DateTime,&#xA;&#x9;&#x9;S_NetTermBasis Nvarchar(6) ,&#xA;&#x9;&#x9;S_NetTerms INT,&#xA;&#x9;&#x9;S_TValueComputeMethod Nvarchar(8),&#xA;&#x9;&#x9;S_TValueDateCounting  Nvarchar(13),&#xA;&#x9;&#x9;S_RRPPaymentsFrom INT,&#xA;&#x9;&#x9;S_RRPPaymentFrequency  Nvarchar(13),&#xA;&#x9;&#x9;S_RRPRegularPaymentAmount_Amount decimal(16,2) DEFAULT (0),&#xA;&#x9;&#x9;S_PerfectPayPool BIT&#xA;&#x9;)&#xA;&#x9;INSERT INTO #SourceDiscountingDetails&#xA;&#x9;EXEC SourceDiscountingsRecon&#xA;&#x9;&#xA;&#x9;CREATE TABLE #TargetDiscountingDetails&#xA;&#x9;(&#xA;&#x9;&#x9;  DiscountingId bigint &#xA;&#x9;&#x9;, DiscountingFinanceId bigint&#xA;&#x9;&#x9;, FunderId bigint&#xA;&#x9;&#x9;,T_AssociatedLeaseSequenceNumber nvarchar(max)&#xA;&#x9;&#x9;,T_DiscountingSequenceNumber nvarchar(max) &#xA;&#x9;&#x9;,T_LoanNumber nvarchar(max)&#xA;&#x9;&#x9;,T_FundingSourceNumber nvarchar(50)&#xA;&#x9;&#x9;,T_FundingSource nvarchar(max)&#xA;&#x9;&#x9;,T_BookingStatus nvarchar(max)&#xA;&#x9;&#x9;,T_RepaymentFrequency nvarchar(max)&#xA;&#x9;&#x9;,T_IsAutoPaymentAllowed bit&#xA;&#x9;&#x9;,T_DiscountRate decimal(14,9) DEFAULT (0)&#xA;&#x9;&#x9;,T_DueDay Int&#xA;&#x9;&#x9;,T_Advance bit&#xA;&#x9;&#x9;,T_CompoundingFrequency NVarChar(13) NULL&#xA;&#x9;&#x9;,T_Yield decimal(14,9) DEFAULT (0)&#xA;&#x9;&#x9;,T_CommencementDate datetime&#xA;&#x9;&#x9;,T_MaturityDate datetime&#xA;&#x9;&#x9;,T_FacilityExpirationDate datetime&#xA;&#x9;&#x9;,T_ProcessThroughDate datetime &#xA;&#x9;&#x9;,T_LoanAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalPaymentAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingPaymentAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalPrincipalAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalCapitalizedInterestAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingPrincipalAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingCapitalizedInterestAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_TotalInterestAccrualAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_AccumulatedInterestAccrualAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingInterestAccrualAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_DebtFinancingCostAmount  decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_AccumulatedDebtFinancingCostAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_RemainingDebtFinancingCostAmount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_Currency Nvarchar(40) NULL&#xA;&#x9;&#x9;,T_LastPaymentDueDate datetime&#xA;&#x9;&#x9;,T_AccruedInterestBalance decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_LegalEntityNumber Nvarchar(40) NULL&#xA;&#x9;&#x9;,T_LoanDate DateTime&#xA;&#x9;&#x9;,T_NetTermBasis Nvarchar(6) &#xA;&#x9;&#x9;,T_NetTerms INT&#xA;&#x9;&#x9;,T_TValueComputeMethod Nvarchar(8)&#xA;&#x9;&#x9;,T_TValueDateCounting  Nvarchar(13)&#xA;&#x9;&#x9;,T_RRPPaymentsFrom INT&#xA;&#x9;&#x9;,T_RRPPaymentFrequency  Nvarchar(13)&#xA;&#x9;&#x9;,T_RRPRegularPaymentAmount_Amount decimal(16,2) DEFAULT (0)&#xA;&#x9;&#x9;,T_PerfectPayPool BIT&#xA;&#xA;&#x9;)&#xA;&#x9;INSERT INTO #TargetDiscountingDetails&#xA;&#x9;EXEC TargetDiscountingsRecon&#xA;&#x9;&#xA;&#x9;SELECT &#xA;&#x9;&#x9;S_AssociatedLeaseSequenceNumber,&#xA;&#x9;&#x9;T_AssociatedLeaseSequenceNumber,&#xA;&#x9;&#x9;CASE WHEN S_AssociatedLeaseSequenceNumber = T_AssociatedLeaseSequenceNumber THEN 1 ELSE 0 END  IsAssociatedLeaseSequenceNumber,&#xA;&#xA;&#x9;&#x9;S_DiscountingSequenceNumber,&#xA;&#x9;&#x9;T_DiscountingSequenceNumber,&#xA;&#x9;&#x9;CASE WHEN S_DiscountingSequenceNumber = T_DiscountingSequenceNumber THEN 1 ELSE 0 END IsDiscountingSequenceNumber,&#xA;&#xA;&#x9;&#x9;S_LoanNumber,&#xA;&#x9;&#x9;T_LoanNumber,&#xA;&#x9;&#x9;CASE WHEN S_LoanNumber = T_LoanNumber THEN 1 ELSE 0 END IsLoanNumberMatched,&#xA;&#xA;&#x9;&#x9;S_FundingSourceNumber,&#xA;&#x9;&#x9;T_FundingSourceNumber,&#xA;&#x9;&#x9;CASE WHEN S_FundingSourceNumber = T_FundingSourceNumber THEN 1 ELSE 0 END IsFundingSourceNumberMatched,&#xA;&#xA;&#x9;&#x9;S_FundingSource,&#xA;&#x9;&#x9;T_FundingSource,&#xA;&#x9;&#x9;CASE WHEN S_FundingSource = T_FundingSource THEN 1 ELSE 0 END IsFundingSourceMatched,&#xA;&#xA;&#x9;&#x9;S_BookingStatus,&#xA;&#x9;&#x9;T_BookingStatus,&#xA;&#x9;&#x9;CASE WHEN S_BookingStatus = T_BookingStatus THEN 1 ELSE 0 END IsBookingStatusMatched,&#xA;&#xA;&#x9;&#x9;S_CommencementDate,&#xA;&#x9;&#x9;T_CommencementDate,&#xA;&#x9;&#x9;CASE WHEN S_CommencementDate = T_CommencementDate THEN 1 ELSE 0 END IsCommencementDateMatched,&#xA;&#xA;&#x9;&#x9; &#xA;&#xA;&#x9;&#x9;S_MaturityDate,&#xA;&#x9;&#x9;T_MaturityDate,&#xA;&#x9;&#x9;CASE WHEN S_MaturityDate = T_MaturityDate THEN 1 ELSE 0 END  IsMaturityDateMatched,&#xA;&#xA;&#x9;&#x9; &#xA;&#xA;&#x9;&#x9;S_ProcessThroughDate,&#xA;&#x9;&#x9;T_ProcessThroughDate,&#xA;&#x9;&#x9;CASE WHEN ISNULL(S_ProcessThroughDate, 0) = ISNULL(T_ProcessThroughDate, 0) THEN 1 ELSE 0 END IsProcessThroughDateMatched,&#xA;&#xA;&#x9;&#x9;S_RepaymentFrequency,&#xA;&#x9;&#x9;T_RepaymentFrequency,&#xA;&#x9;&#x9;CASE WHEN S_RepaymentFrequency = T_RepaymentFrequency THEN 1 ELSE 0 END IsRepaymentFrequencyMatched,&#xA;&#xA;&#x9;&#x9;S_CompoundingFrequency,&#xA;&#x9;&#x9;T_CompoundingFrequency,&#xA;&#x9;&#x9;CASE WHEN S_CompoundingFrequency = T_CompoundingFrequency THEN 1 ELSE 0 END IsCompoundingFrequencyMatched,&#xA;&#xA;&#x9;&#x9;S_IsAutoPaymentAllowed,&#xA;&#x9;&#x9;T_IsAutoPaymentAllowed,&#xA;&#x9;&#x9;CASE WHEN S_IsAutoPaymentAllowed  = T_IsAutoPaymentAllowed  THEN 1 ELSE 0 END IsAutoPaymentAllowedMatched,&#xA;&#xA;&#x9;&#x9;S_Advance,&#xA;&#x9;&#x9;T_Advance,&#xA;&#x9;&#x9;CASE WHEN S_Advance = T_Advance THEN 1 ELSE 0 END IsAdvanceMatched,&#xA;&#xA;&#x9;&#x9;S_DueDay,&#xA;&#x9;&#x9;T_DueDay,&#xA;&#x9;&#x9;CASE WHEN S_DueDay = T_DueDay THEN 1 ELSE 0 END IsDueDayMatched,&#xA;&#xA;&#x9;&#x9;S_DiscountRate,&#xA;&#x9;&#x9;T_DiscountRate,&#xA;&#x9;&#x9;CASE WHEN S_DiscountRate = T_DiscountRate THEN 1 ELSE 0 END IsDiscountRateMatched,&#xA;&#xA;&#x9;&#x9;S_DiscountRate AS S_InterestRate,&#xA;&#x9;&#x9;T_Yield,&#xA;&#x9;&#x9;CASE WHEN S_DiscountRate = T_Yield THEN 1 ELSE 0 END IsInterestRateAndYieldMatched,&#xA; &#xA;&#x9;&#x9;S_LoanAmount,&#xA;&#x9;&#x9;T_LoanAmount,&#xA;&#x9;&#x9;CASE WHEN S_LoanAmount = T_LoanAmount THEN 1 ELSE 0 END IsLoanAmountMatched,&#xA;&#xA;&#x9;&#x9;S_DebtFinancingCostAmount,&#xA;&#x9;&#x9;T_DebtFinancingCostAmount, &#xA;&#x9;&#x9;CASE WHEN S_DebtFinancingCostAmount = T_DebtFinancingCostAmount THEN 1 ELSE 0 END IsDebtFinancingCostAmountMatched,&#xA;&#xA;&#x9;&#x9;S_AccumulatedDebtFinancingCostAmount,&#xA;&#x9;&#x9;T_AccumulatedDebtFinancingCostAmount,&#xA;&#x9;&#x9;CASE WHEN S_AccumulatedDebtFinancingCostAmount = T_AccumulatedDebtFinancingCostAmount THEN 1 ELSE 0 END IsAccumulatedDebtFinancingCostAmountMatched,&#xA;&#xA;&#x9;&#x9;S_RemainingDebtFinancingCostAmount,&#xA;&#x9;&#x9;T_RemainingDebtFinancingCostAmount,&#xA;&#x9;&#x9;CASE WHEN S_RemainingDebtFinancingCostAmount = T_RemainingDebtFinancingCostAmount THEN 1 ELSE 0 END IsRemainingDebtFinancingCostAmountMatched,&#xA;&#xA;&#x9;&#x9;S_TotalPaymentAmount, &#xA;&#x9;&#x9;T_TotalPaymentAmount, &#xA;&#x9;&#x9;CASE WHEN S_TotalPaymentAmount = T_TotalPaymentAmount THEN 1 ELSE 0 END IsTotalPaymentAmountMatched,&#xA;&#xA;&#x9;&#x9;COALESCE(S_RemainingPaymentAmount, 0) S_RemainingPaymentAmount,&#xA;&#x9;&#x9;COALESCE(T_RemainingPaymentAmount, 0) T_RemainingPaymentAmount,&#xA;&#x9;&#x9;CASE WHEN COALESCE(S_RemainingPaymentAmount, 0) = COALESCE(T_RemainingPaymentAmount, 0) THEN 1 ELSE 0 END IsRemainingPaymentAmountMatched,&#xA;&#xA;&#x9;&#x9;S_TotalPrincipalAmount, &#xA;&#x9;&#x9;T_TotalPrincipalAmount, &#xA;&#x9;&#x9;T_TotalCapitalizedInterestAmount,&#xA;&#x9;&#x9;CASE WHEN S_TotalPrincipalAmount = (T_TotalPrincipalAmount - T_TotalCapitalizedInterestAmount) THEN 1 ELSE 0 END IsTotalPrincipalAmountMatched,&#xA;&#xA;&#x9;&#x9;S_RemainingPrincipalAmount,&#xA;&#x9;&#x9;T_RemainingPrincipalAmount,&#xA;&#x9;&#x9;T_RemainingCapitalizedInterestAmount,&#xA;&#x9;&#x9;CASE WHEN S_RemainingPrincipalAmount = (T_RemainingPrincipalAmount - T_RemainingCapitalizedInterestAmount) THEN 1 ELSE 0 END IsRemainingPrincipalAmountMatched,&#xA;&#xA;&#x9;&#x9;S_TotalInterestAccrualAmount,&#xA;&#x9;&#x9;T_TotalInterestAccrualAmount,&#xA;&#x9;&#x9;T_TotalCapitalizedInterestAmount T_TotalInterestCapitalizedAmount,&#xA;&#x9;&#x9;CASE WHEN S_TotalInterestAccrualAmount = (T_TotalInterestAccrualAmount + T_TotalCapitalizedInterestAmount) THEN 1 ELSE 0 END IsTotalInterestAccrualAmountMatched,&#xA;&#xA;&#x9;&#x9;S_AccumulatedInterestAccrualAmount, &#xA;&#x9;&#x9;T_AccumulatedInterestAccrualAmount,&#xA;&#x9;&#x9;CASE WHEN S_AccumulatedInterestAccrualAmount = T_AccumulatedInterestAccrualAmount THEN 1 ELSE 0 END IsAccumulatedInterestAccrualAmountMatched,&#xA;&#xA;&#x9;&#x9;S_RemainingInterestAccrualAmount, &#xA;&#x9;&#x9;T_RemainingInterestAccrualAmount,&#xA;&#x9;&#x9;CASE WHEN S_RemainingInterestAccrualAmount = T_RemainingInterestAccrualAmount THEN 1 ELSE 0 END IsRemainingInterestAccrualAmountMatched,&#xA;&#xA;&#x9;&#x9;S_Currency,&#xA;&#x9;&#x9;T_Currency,&#xA;&#x9;&#x9;CASE WHEN S_Currency = T_Currency THEN 1 ELSE 0 END IsCurrencyMatched,&#xA;&#xA;&#xA;&#x9;&#x9;S_AccruedInterestBalance,&#xA;&#x9;&#x9;T_AccruedInterestBalance,&#xA;&#x9;&#x9;CASE WHEN S_AccruedInterestBalance = T_AccruedInterestBalance THEN 1 ELSE 0 END IsAccruedInterestBalanceMatched,&#xA;&#xA;&#x9;&#x9;S_LastPaymentDueDate,&#xA;&#x9;&#x9;T_LastPaymentDueDate,&#xA;&#x9;&#x9;CASE WHEN S_LastPaymentDueDate = T_LastPaymentDueDate THEN 1 ELSE 0 END IsLastPaymentDueDateMatched,&#xA;&#xA;&#x9;&#x9;S_LegalEntityNumber,&#xA;&#x9;&#x9;T_LegalEntityNumber,&#xA;&#x9;&#x9;CASE WHEN S_LegalEntityNumber = T_LegalEntityNumber THEN 1 ELSE 0 END IsLegalEntityMatched,&#xA;&#xA;&#x9;&#x9;S_LoanDate,&#xA;&#x9;&#x9;T_LoanDate,&#xA;&#x9;&#x9;CASE WHEN S_LoanDate = T_LoanDate THEN 1 ELSE 0 END IsLoanDateMatched,&#xA;&#x9;&#x9;&#xA;&#x9;&#x9;S_NetTermBasis,&#xA;&#x9;&#x9;T_NetTermBasis,&#xA;&#x9;&#x9;CASE WHEN S_NetTermBasis = T_NetTermBasis THEN 1 ELSE 0 END IsNetTermBasisMatched,&#xA;&#xA;&#x9;&#x9;S_NetTerms,&#xA;&#x9;&#x9;T_NetTerms,&#xA;&#x9;&#x9;CASE WHEN S_NetTerms = T_NetTerms THEN 1 ELSE 0 END IsNetTermsMatched,&#xA;&#xA;&#x9;&#x9;S_TValueComputeMethod,&#xA;&#x9;&#x9;T_TValueComputeMethod,&#xA;&#x9;&#x9;CASE WHEN S_TValueComputeMethod = T_TValueComputeMethod THEN 1 ELSE 0 END IsTValueComputeMethodMatched,&#xA;&#xA;&#x9;&#x9;S_TValueDateCounting,&#xA;&#x9;&#x9;T_TValueDateCounting,&#xA;&#x9;&#x9;CASE WHEN S_TValueDateCounting = T_TValueDateCounting THEN 1 ELSE 0 END IsTValueDateCountingMatched,&#xA;&#x9;&#x9;&#x9;&#x9;&#xA;&#x9;&#x9;S_RRPPaymentsFrom,&#xA;&#x9;&#x9;T_RRPPaymentsFrom,&#xA;&#x9;&#x9;CASE WHEN S_RRPPaymentsFrom = T_RRPPaymentsFrom THEN 1 ELSE 0 END IsRRPPaymentsFromMatched,&#xA;&#xA;&#x9;&#x9;S_RRPPaymentFrequency,&#xA;&#x9;&#x9;T_RRPPaymentFrequency,&#xA;&#x9;&#x9;CASE WHEN S_RRPPaymentFrequency = T_RRPPaymentFrequency THEN 1 ELSE 0 END IsRRPPaymentFrequencyMatched,&#xA;&#xA;&#x9;&#x9;S_RRPRegularPaymentAmount_Amount,&#xA;&#x9;&#x9;T_RRPRegularPaymentAmount_Amount,&#xA;&#x9;&#x9;CASE WHEN S_RRPRegularPaymentAmount_Amount = T_RRPRegularPaymentAmount_Amount THEN 1 ELSE 0 END IsRRPRegularPaymentAmountMatched,&#xA;&#xA;&#x9;&#x9;S_PerfectPayPool,&#xA;&#x9;&#x9;T_PerfectPayPool,&#xA;&#x9;&#x9;CASE WHEN S_PerfectPayPool = T_PerfectPayPool THEN 1 ELSE 0 END IsPerfectPayPoolMatched,&#xA;&#xA;&#x9;&#x9;'Not Problem Record' Result&#xA;INTO #DiscountingRecon &#xA;FROM &#xA;&#x9;#SourceDiscountingDetails S&#xA;&#x9;&#xA;&#x9;LEFT JOIN #TargetDiscountingDetails T&#xA;&#x9;&#x9;ON (S.S_AssociatedLeaseSequenceNumber = T.T_AssociatedLeaseSequenceNumber&#xA;&#x9;&#x9;&#x9;OR S.S_DiscountingSequenceNumber = T.T_DiscountingSequenceNumber)&#xA;--WHERE &#xA;--&#x9;S.S_AssociatedLeaseSequenceNumber = T.T_AssociatedLeaseSequenceNumber&#xA;--&#x9;OR&#xA;--&#x9;&#x9;(&#xA;--&#x9;&#x9;S.S_AssociatedLeaseSequenceNumber IS NOT NULL&#xA;--&#x9;&#x9;AND T.T_AssociatedLeaseSequenceNumber IS NULL&#xA;--&#x9;&#x9;AND T.T_LoanNumber = S.S_AssociatedLeaseSequenceNumber&#xA;--&#x9;&#x9;)&#xA;UPDATE #DiscountingRecon&#xA;&#x9;SET Result =&#xA;&#x9;&#x9;CASE WHEN &#xA;&#x9;&#x9;&#x9;(IsAssociatedLeaseSequenceNumber = 0&#xA;                OR IsDiscountingSequenceNumber = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsLoanNumberMatched  = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsFundingSourceNumberMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsFundingSourceMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsBookingStatusMatched  = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsCommencementDateMatched  = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsMaturityDateMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsLoanAmountMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsProcessThroughDateMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsRepaymentFrequencyMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsAutoPaymentAllowedMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsDiscountRateMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsAdvanceMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsDueDayMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsCompoundingFrequencyMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsInterestRateAndYieldMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsDebtFinancingCostAmountMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsAccumulatedDebtFinancingCostAmountMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsRemainingDebtFinancingCostAmountMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsTotalPaymentAmountMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsRemainingPaymentAmountMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsTotalPrincipalAmountMatched= 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsRemainingPrincipalAmountMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsTotalInterestAccrualAmountMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsAccumulatedInterestAccrualAmountMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsRemainingInterestAccrualAmountMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsCurrencyMatched = 0 &#xA;&#x9;&#x9;&#x9;&#x9;OR IsAccruedInterestBalanceMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsLastPaymentDueDateMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsLegalEntityMatched = 0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsLoanDateMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsNetTermBasisMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsNetTermsMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsTValueComputeMethodMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsTValueDateCountingMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsRRPPaymentsFromMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsRRPPaymentFrequencyMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsRRPRegularPaymentAmountMatched=0&#xA;&#x9;&#x9;&#x9;&#x9;OR IsPerfectPayPoolMatched=0&#xA;&#xA;&#x9;&#x9;&#x9;&#x9;) &#xA;&#x9;&#x9;THEN&#xA;&#x9;&#x9;&#x9;'Problem Record'&#xA;&#x9;&#x9;ELSE&#xA;&#x9;&#x9;&#x9;'Not Problem Record'&#xA;&#x9;&#x9;END&#xA;&#xA;-- 15C. DiscountingReconResult.sql&#xA;&#xA;DROP TABLE IF EXISTS V5_Recon.dbo.DiscountingRecon&#xA;&#xA;SELECT 'DiscountingRecon' Recon, *&#xA;INTO V5_Recon.dbo.DiscountingRecon&#xA;FROM&#x9;#DiscountingRecon&#xA;ORDER BY S_AssociatedLeaseSequenceNumber&#xA;&#xA;SELECT *&#xA;FROM V5_Recon.dbo.DiscountingRecon&#xA;&#xA;&#x9;--IF (@ResultOption = 'All')&#xA;&#x9;--BEGIN&#xA;&#x9;&#x9;--SELECT * INTO Insight_UAT..DiscountingFinReconExtract&#xA;&#x9;&#x9;--FROM &#xA;&#x9;&#x9;--&#x9;#DiscountingRecon&#xA;&#x9;&#x9;--ORDER BY S_AssociatedLeaseSequenceNumber;&#xA;&#x9;--END&#xA;&#xA;&#x9;--IF (@ResultOption = 'Failed')&#xA;&#x9;--BEGIN&#xA;&#x9;--&#x9;SELECT *&#xA;&#x9;--&#x9;FROM &#xA;&#x9;--&#x9;&#x9;#DiscountingRecon&#xA;&#x9;--&#x9;WHERE &#xA;&#x9;--&#x9;&#x9;Result = 'Problem Record'&#xA;&#x9;--&#x9;ORDER BY S_AssociatedLeaseSequenceNumber;&#xA;&#x9;--END&#xA;&#xA;&#x9;--IF (@ResultOption = 'Passed')&#xA;&#x9;--BEGIN&#xA;&#x9;--&#x9;SELECT *&#xA;&#x9;--&#x9;FROM #DiscountingRecon&#xA;&#x9;--&#x9;WHERE Result = 'Not Problem Record'&#xA;&#x9;--&#x9;ORDER BY S_AssociatedLeaseSequenceNumber;&#xA;&#x9;--END&#xA;&#xA;&#x9;DROP TABLE #SourceDiscountingDetails&#xA;&#x9;DROP TABLE #TargetDiscountingDetails&#xA;&#x9;DROP TABLE #DiscountingRecon&#xA;--END&#xA;--GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
